---
import type { TimelineEvent } from '../content/config';

export interface Props {
  event: TimelineEvent;
}

const { event } = Astro.props;

const categoryColors: Record<string, string> = {
  political: '#3b82f6',
  military: '#ef4444',
  cultural: '#ec4899',
  economic: '#22c55e',
  scientific: '#f97316',
};

const catColor = categoryColors[event.category] || '#94a3b8';
---

<a
  href={`/evenements/${event.id}`}
  class="era-event-card group"
  style={{ '--card-accent': catColor }}
>
  <div class="era-event-card__year">{event.yearDisplay}</div>
  <h3 class="era-event-card__title">{event.title}</h3>
  <span class="era-event-card__category" style={{ '--cat-color': catColor }}>
    {event.category}
  </span>
  <p class="era-event-card__summary">{event.preview.summary}</p>
</a>

<style>
  .era-event-card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  }

  .era-event-card:hover {
    border-color: var(--card-accent, var(--color-french-blue));
    background: rgba(17, 24, 39, 0.9);
    transform: translateY(-2px);
  }

  .era-event-card__year {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .era-event-card__title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-light);
    line-height: 1.3;
    margin: 0;
  }

  .era-event-card__category {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1px var(--gap-xs);
    border-radius: var(--radius-sm);
    border: 1px solid var(--cat-color, var(--color-border));
    color: var(--cat-color, var(--color-text-muted));
    align-self: flex-start;
  }

  .era-event-card__summary {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>
