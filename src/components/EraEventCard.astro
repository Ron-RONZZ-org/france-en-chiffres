---
import type { TimelineEvent } from '../content/config';

export interface Props {
  event: TimelineEvent;
}

const { event } = Astro.props;

// Truncate description for card display
const summary = event.description
  ? event.description.length > 120
    ? event.description.slice(0, 120) + '…'
    : event.description
  : '';
---

<a
  href={`/histoire/${event.id}`}
  class="era-event-card group"
>
  <div class="era-event-card__year">{event.yearDisplay}</div>
  <h3 class="era-event-card__title">{event.title}</h3>
  {summary && <p class="era-event-card__summary">{summary}</p>}
</a>

<style>
  .era-event-card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  }

  .era-event-card:hover {
    border-color: var(--color-french-blue);
    background: rgba(17, 24, 39, 0.9);
    transform: translateY(-2px);
  }

  .era-event-card__year {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .era-event-card__title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-light);
    line-height: 1.3;
    margin: 0;
  }

  .era-event-card__summary {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>