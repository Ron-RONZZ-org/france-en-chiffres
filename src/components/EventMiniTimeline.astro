---
import type { TimelineEntry } from '../content/config';

export interface Props {
  entries: TimelineEntry[];
  eventStart: number;
  eventEnd: number;
}

const { entries, eventStart, eventEnd } = Astro.props;

interface PlacedEntry extends TimelineEntry {
  leftPercent: number;
  widthPercent: number;
  track: number;
}

/**
 * Greedy track assignment for overlapping horizontal bars.
 * Sorts by start year, places each entry on the lowest track
 * whose last bar ends before this entry starts.
 */
function assignTracks(sorted: TimelineEntry[]): { track: number; totalTracks: number }[] {
  const trackEnds: number[] = [];
  const result: { track: number; totalTracks: number }[] = [];

  for (const entry of sorted) {
    let track = 0;
    while (track < trackEnds.length && entry.start < trackEnds[track]) {
      track++;
    }
    if (track >= trackEnds.length) {
      trackEnds.push(entry.end);
    } else {
      trackEnds[track] = entry.end;
    }
    result.push({ track, totalTracks: 0 }); // will patch below
  }

  const totalTracks = Math.max(trackEnds.length, 1);
  for (const r of result) {
    r.totalTracks = totalTracks;
  }
  return result;
}

// ── Compute layout ──────────────────────────────────────────────────

const range = eventEnd - eventStart;
let placed: PlacedEntry[] = [];

if (range > 0 && entries.length > 0) {
  // Sort by start (then end) for track assignment
  const indexed = entries.map((e, i) => ({ ...e, originalIndex: i }));
  const sorted = [...indexed].sort((a, b) => a.start - b.start || a.end - b.end);
  const assignments = assignTracks(sorted);

  // Build placed entries in original order
  placed = entries.map((e, i) => {
    const idx = indexed.findIndex((x) => x.originalIndex === i);
    const { track, totalTracks } = assignments[idx];
    const rawWidth = ((e.end - e.start) / range) * 100;
    return {
      ...e,
      leftPercent: ((e.start - eventStart) / range) * 100,
      widthPercent: Math.max(rawWidth, 1.5), // minimum 1.5% for visibility
      track,
      totalTracks,
    };
  });
}
---

{placed.length > 0 && (
<div class="mini-timeline">
  <div class="mini-timeline__header">
    <svg class="mini-timeline__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <rect x="1" y="3" width="18" height="3" rx="1.5" fill="currentColor" opacity="0.3"/>
      <rect x="1" y="8.5" width="18" height="3" rx="1.5" fill="currentColor" opacity="0.6"/>
      <rect x="1" y="14" width="18" height="3" rx="1.5" fill="currentColor" opacity="0.9"/>
    </svg>
    <span class="mini-timeline__label">Chronologie</span>
  </div>

  <!-- Time axis -->
  <div class="mini-timeline__axis">
    <span class="mini-timeline__axis-label mini-timeline__axis-label--start">{eventStart}</span>
    <div class="mini-timeline__axis-line" aria-hidden="true">
      <div class="mini-timeline__axis-tick"></div>
      <div class="mini-timeline__axis-tick mini-timeline__axis-tick--end"></div>
    </div>
    <span class="mini-timeline__axis-label mini-timeline__axis-label--end">{eventEnd}</span>
  </div>

  <!-- Bars grouped by track -->
  <div class="mini-timeline__tracks" style={`--tracks: ${placed[0].totalTracks}`}>
    {Array.from({ length: placed[0].totalTracks }, (_, trackIdx) => {
      const rowEntries = placed.filter((p) => p.track === trackIdx);
      return (
        <div class="mini-timeline__track">
          {rowEntries.map((entry) => (
            <a
              href={`#${entry.sectionId || entry.id}`}
              class="mini-timeline__bar"
              style={`left: ${entry.leftPercent}%; width: ${entry.widthPercent}%`}
              data-section-id={entry.sectionId || entry.id}
            >
              <span class="mini-timeline__bar-inner">
                <span class="mini-timeline__bar-title">{entry.title}</span>
                {entry.end !== entry.start && (
                  <span class="mini-timeline__bar-years">
                    {entry.start}&ndash;{entry.end}
                  </span>
                )}
              </span>
            </a>
          ))}
        </div>
      );
    })}
  </div>
</div>
)}

<style>
  .mini-timeline {
    margin: var(--gap-lg) 0;
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
  }

  /* ── Header ── */
  .mini-timeline__header {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    margin-bottom: var(--gap-md);
  }

  .mini-timeline__icon {
    width: 20px;
    height: 20px;
    color: var(--color-french-blue);
    flex-shrink: 0;
  }

  .mini-timeline__label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  /* ── Time axis ── */
  .mini-timeline__axis {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    margin-bottom: var(--gap-sm);
    padding: 0 2px;
  }

  .mini-timeline__axis-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mini-timeline__axis-line {
    flex: 1;
    height: 2px;
    background: var(--color-border);
    border-radius: 1px;
    position: relative;
  }

  .mini-timeline__axis-tick {
    position: absolute;
    top: -3px;
    left: 0;
    width: 2px;
    height: 8px;
    background: var(--color-border);
    border-radius: 1px;
  }

  .mini-timeline__axis-tick--end {
    left: auto;
    right: 0;
  }

  /* ── Track rows ── */
  .mini-timeline__tracks {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 32px;
  }

  .mini-timeline__track {
    position: relative;
    height: 32px;
  }

  /* ── Bars ── */
  .mini-timeline__bar {
    position: absolute;
    top: 0;
    height: 100%;
    text-decoration: none;
    display: block;
    z-index: 1;
    transition: z-index var(--transition-fast);
  }

  .mini-timeline__bar-inner {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 100%;
    padding: 0 8px;
    background: var(--color-french-blue);
    border-radius: 4px;
    opacity: 0.7;
    transition: opacity var(--transition-fast), background var(--transition-fast);
    overflow: hidden;
    white-space: nowrap;
    cursor: pointer;
  }

  .mini-timeline__bar:hover .mini-timeline__bar-inner {
    opacity: 1;
    background: #5b9cf5;
  }

  .mini-timeline__bar[data-active] .mini-timeline__bar-inner {
    opacity: 1;
    background: #5b9cf5;
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
  }

  .mini-timeline__bar-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.2;
  }

  .mini-timeline__bar-years {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .mini-timeline {
      padding: var(--gap-sm);
    }

    .mini-timeline__bar-inner {
      padding: 0 4px;
    }

    .mini-timeline__bar-title {
      font-size: 0.65rem;
    }

    .mini-timeline__bar-years {
      display: none;
    }
  }
</style>

<script>
  (() => {
    const bars = document.querySelectorAll('.mini-timeline__bar');
    if (!bars.length) return;

    const sectionIds = Array.from(bars).map(
      (bar) => bar.getAttribute('data-section-id')
    ).filter(Boolean);

    // Bail if no sections to observe
    if (sectionIds.length === 0) return;

    // Build a map: sectionId → bar element
    const barMap = new Map();
    bars.forEach((bar) => {
      const id = bar.getAttribute('data-section-id');
      if (id) barMap.set(id, bar);
    });

    // Smooth scroll with reduced-motion respect
    bars.forEach((bar) => {
      bar.addEventListener('click', (e) => {
        const id = bar.getAttribute('data-section-id');
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;

        e.preventDefault();

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        target.scrollIntoView({
          behavior: prefersReduced ? 'auto' : 'smooth',
          block: 'start',
        });

        // Update URL hash without causing a jump
        history.pushState(null, '', `#${id}`);
      });
    });

    // IntersectionObserver for scroll-spy highlighting
    const sectionElements = sectionIds
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    if (sectionElements.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const bar = barMap.get(entry.target.id);
          if (!bar) return;

          if (entry.isIntersecting) {
            bar.setAttribute('data-active', '');
          } else {
            bar.removeAttribute('data-active');
          }
        });
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      }
    );

    sectionElements.forEach((el) => observer.observe(el));
  })();
</script>
