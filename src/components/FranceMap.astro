---
// FranceMap.astro — Realistic SVG outline of France including Corsica and DOM-COM
// Source: France_departements.svg → src/data/france-map-data.json
import { france, dom } from '../data/france-map-data.json';

const leftInsets = dom.filter((d) => ['Guadeloupe', 'Martinique', 'Guyane'].includes(d.id));
const rightInsets = dom.filter((d) => ['Réunion', 'Mayotte'].includes(d.id));
---

<div class="france-map-layout">
  <div class="france-map-layout__sidebar france-map-layout__sidebar--left">
    {leftInsets.map((territory, i) => (
      <div class="dom-insets__item" style={`--i: ${i}`}>
        <svg
          class="dom-insets__svg"
          viewBox={`${territory.viewBox.x} ${territory.viewBox.y} ${territory.viewBox.width} ${territory.viewBox.height}`}
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-label={territory.label}
          role="img"
        >
          <path
            class="dom-insets__path"
            d={territory.path}
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span class="dom-insets__label">{territory.label}</span>
      </div>
    ))}
  </div>

  <div class="france-map-layout__center">
    <svg
      class="france-map"
      viewBox={`${france.viewBox.x} ${france.viewBox.y} ${france.viewBox.width} ${france.viewBox.height}`}
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Carte de la France — métropole, Corse et outre-mer"
      role="img"
    >
      <path
        class="france-map__glow"
        d={france.path}
        stroke="currentColor"
        stroke-width="8"
        stroke-linecap="round"
        stroke-linejoin="round"
        opacity="0.15"
      />
      <path
        class="france-map__outline"
        d={france.path}
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>

  <div class="france-map-layout__sidebar france-map-layout__sidebar--right">
    {rightInsets.map((territory, i) => (
      <div class="dom-insets__item" style={`--i: ${i + leftInsets.length}`}>
        <svg
          class="dom-insets__svg"
          viewBox={`${territory.viewBox.x} ${territory.viewBox.y} ${territory.viewBox.width} ${territory.viewBox.height}`}
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-label={territory.label}
          role="img"
        >
          <path
            class="dom-insets__path"
            d={territory.path}
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span class="dom-insets__label">{territory.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  /* ===== Layout ===== */
  .france-map-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-md);
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .france-map-layout__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    flex-shrink: 0;
  }

  .france-map-layout__center {
    flex-shrink: 0;
  }

  /* ===== Main map ===== */
  .france-map {
    width: 280px;
    height: auto;
    color: var(--color-accent-gold);
    filter: drop-shadow(0 0 16px rgba(212, 168, 67, 0.35));
  }

  .france-map__outline {
    stroke-dasharray: 10000;
    stroke-dashoffset: 10000;
    animation: draw-france 4s ease-out forwards;
  }

  .france-map__glow {
    stroke-dasharray: 10000;
    stroke-dashoffset: 10000;
    animation: draw-france 4s ease-out forwards;
  }

  @keyframes draw-france {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* ===== DOM-COM insets ===== */
  .dom-insets__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    opacity: 0;
    animation: fade-up-dom 0.6s ease-out calc(0.8s + var(--i, 0) * 0.15s) forwards;
  }

  @keyframes fade-up-dom {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .dom-insets__svg {
    width: 50px;
    height: 50px;
    color: var(--color-accent-gold);
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .dom-insets__svg:hover {
    opacity: 1;
  }

  .dom-insets__path {
    stroke-dasharray: 3000;
    stroke-dashoffset: 3000;
    animation: draw-dom 2s ease-out calc(0.6s + var(--i, 0) * 0.2s) forwards;
  }

  @keyframes draw-dom {
    to {
      stroke-dashoffset: 0;
    }
  }

  .dom-insets__label {
    font-size: 0.55rem;
    color: var(--color-text-muted);
    text-align: center;
    white-space: nowrap;
  }

  /* ===== Reduced motion ===== */
  @media (prefers-reduced-motion: reduce) {
    .france-map__outline,
    .france-map__glow {
      stroke-dashoffset: 0;
      animation: none;
    }
    .dom-insets__path {
      stroke-dashoffset: 0;
      animation: none;
    }
    .dom-insets__item {
      opacity: 1;
      animation: none;
    }
  }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .france-map-layout {
      flex-wrap: wrap;
      max-width: 320px;
      gap: var(--gap-sm);
    }

    .france-map-layout__sidebar {
      flex-direction: row;
      gap: var(--gap-xs);
    }

    .france-map-layout__sidebar--left {
      order: 1;
      flex-basis: 100%;
      justify-content: flex-end;
      padding-right: var(--gap-xs);
    }

    .france-map-layout__sidebar--right {
      order: 2;
      flex-basis: 100%;
      justify-content: flex-start;
      padding-left: var(--gap-xs);
    }

    .france-map-layout__center {
      order: 0;
    }

    .france-map {
      width: 240px;
    }

    .dom-insets__svg {
      width: 40px;
      height: 40px;
    }
  }

  /* On very small screens, show all insets in a single row below */
  @media (max-width: 400px) {
    .france-map-layout {
      flex-direction: column;
      align-items: center;
    }

    .france-map-layout__sidebar {
      flex-direction: row;
      flex-basis: auto;
      justify-content: center;
      padding: 0;
      order: 1;
    }

    .france-map-layout__sidebar--left,
    .france-map-layout__sidebar--right {
      padding: 0;
    }

    .france-map {
      width: 200px;
    }

    .dom-insets__svg {
      width: 35px;
      height: 35px;
    }
  }

</style>
