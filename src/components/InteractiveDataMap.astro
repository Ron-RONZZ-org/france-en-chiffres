---
// InteractiveDataMap.astro — Leaflet-based interactive geo map with toggle layers
// Uses Leaflet for the base map, tile layers, and GeoJSON overlays.
// One script per page per AGENTS.md conventions.
// Data files (GeoJSON + density JSON) are lazy-fetched from /data/ on toggle.
---

<section class="data-map-section">
  <div class="data-map-section__info">
    <p class="data-map-section__desc">
      Carte interactive de la France — survolez les départements, activez les couches
      thématiques ci-dessous. Données géographiques : © les contributeurs d'OpenStreetMap,
      © IGN. Données statistiques : © INSEE.
    </p>
  </div>

  <div id="interactive-map" class="data-map" role="application" aria-label="Carte interactive de la France">
    <noscript>
      <div class="data-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>

  <div id="map-legend" class="data-map__legend" aria-hidden="true">
    <p class="data-map__legend-title">Légende</p>
    <div id="map-legend-content" class="data-map__legend-content">
      <p class="data-map__legend-placeholder">Sélectionnez une couche pour voir la légende.</p>
    </div>
  </div>
</section>

