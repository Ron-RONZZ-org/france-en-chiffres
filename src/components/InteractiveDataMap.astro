    font-size: 0.9rem;
    pointer-events: none;
  }

  .data-map__loading--visible {
    display: flex;
  }

  .data-map__loading-spinner {
    width: 20px;
    height: 20px;
    border: 2.5px solid var(--color-border);
    border-top-color: var(--color-accent-gold, #d4a843);
    border-radius: 50%;
    animation: data-map-spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  .data-map__loading-text {
    white-space: nowrap;
  }

  @keyframes data-map-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Legend ── */
  .data-map__legend {
    margin-top: var(--gap-md);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .data-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
