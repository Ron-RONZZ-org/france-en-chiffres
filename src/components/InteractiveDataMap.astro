              layer.setStyle(DEPT_HIGHLIGHT);
              currentHighlight = layer;
            });

            layer.on('mouseout', () => {
              if (currentHighlight) {
                currentHighlight.setStyle(DEPT_STYLE);
                currentHighlight = null;
              }
            });

            layer.on('click', () => {
              map.fitBounds(layer.getBounds(), { padding: [40, 40], maxZoom: 10 });
