---
// InteractiveDataMap.astro — Leaflet-based interactive geo map with toggle layers
// Uses Leaflet for the base map, tile layers, and GeoJSON overlays.
// One script per page per AGENTS.md conventions.
// Data files (GeoJSON + density JSON) are lazy-fetched from /data/ on toggle.
---

<section class="data-map-section">
  <div id="interactive-map" class="data-map" role="application" aria-label="Carte interactive de la France">
    <noscript>
      <div class="data-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>

  <div id="map-legend" class="data-map__legend" aria-hidden="true">
    <p class="data-map__legend-title">Légende</p>
    <div id="map-legend-content" class="data-map__legend-content">
      <p class="data-map__legend-placeholder">Sélectionnez une couche pour voir la légende.</p>
    </div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    // ── Constants ──
    const FRANCE_CENTER = [46.6, 2.5];
    const DEFAULT_ZOOM = 6;
    const MIN_ZOOM = 5;
    const MAX_ZOOM = 12;

    const DEPT_STYLE = {
      color: '#475569',
      weight: 1.2,
      fillColor: '#1e293b',
      fillOpacity: 0.15,
    };

    const DEPT_HIGHLIGHT = {
      color: '#d4a843',
      weight: 2.5,
      fillColor: '#d4a843',
      fillOpacity: 0.2,
    };

    // ── Initialize map ──
    const mapEl = document.getElementById('interactive-map');
    if (!mapEl) return;

    const map = L.map(mapEl, {
      center: FRANCE_CENTER,
      zoom: DEFAULT_ZOOM,
      minZoom: MIN_ZOOM,
      maxZoom: MAX_ZOOM,
      zoomControl: true,
      attributionControl: true,
      preferCanvas: true,
    });

    // ── Custom panes for z-ordering ──
    // polygon-pane (z-index 300): density, communes — renders BELOW line features
    // line-pane (z-index 400): waterways, roads — renders ABOVE polygons
    map.createPane('polygon-pane');
    map.getPane('polygon-pane').style.zIndex = 300;
    map.createPane('line-pane');
    map.getPane('line-pane').style.zIndex = 400;

    // ── Base tile layer (OSM) ──
    const osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── State ──
    let deptLayer = null;
    let densityLayer = null;
    let densityAttributionAdded = false;
    let densityLoading = false;      // true while async fetch in progress
    let densityCancel = false;       // set true to cancel pending load
    let elevationLayer = null;
    let roadsLayer = null;
    let railwaysLayer = null;
    let waterwaysLayer = null;
    let communesLayer = null;
    let currentHighlight = null;

    // ── Helpers ──
    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function makeTooltip(feature) {
      const code = feature.properties.code || '';
      const name = feature.properties.nom || '';
      return `<strong>${escapeHtml(name)}</strong> (${escapeHtml(code)})`;
    }

    function getDensityColor(density) {
      if (density === null || density === undefined) return '#1e293b';
      const breaks = [0, 30, 60, 100, 150, 300, 500, 1000, 5000];
      const colors = [
        '#f7fcf0', '#e0f3db', '#ccebc5', '#a8ddb5',
        '#7bccc4', '#4eb3d3', '#2b8cbe', '#0868ac', '#084081',
      ];
      for (let i = 0; i < breaks.length; i++) {
        if (density <= breaks[i]) return colors[i];
      }
      return colors[colors.length - 1];
    }

    function getDensityLabel(density) {
      if (density === null || density === undefined) return 'N/A';
      return density.toLocaleString('fr-FR') + ' hab/km²';
    }

    // ── Tippy: layer controls with HTML descriptions ──
    function setupTippy() {
      const items = document.querySelectorAll('.layer-controls__item[data-description]');
      items.forEach((el) => {
        const html = el.getAttribute('data-description');
        if (!html) return;
        tippy(el, {
          content: html,
          allowHTML: true,
          placement: 'top',
          animation: 'shift-away',
          theme: 'dark',
          maxWidth: 320,
          delay: [200, 0],
          interactive: true,  // allow clicking citation links
        });
      });
    }

    // ── Department base layer (static) ──
    async function loadDepartments() {
      try {
        const resp = await fetch('/data/departements.geojson');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();

        deptLayer = L.geoJSON(data, {
          style: DEPT_STYLE,
          onEachFeature: (feature, layer) => {
            layer.bindTooltip(makeTooltip(feature), {
              sticky: true,
              direction: 'top',
              offset: L.point(0, -8),
              className: 'dept-tooltip',
            });

            layer.on('mouseover', () => {
              if (currentHighlight) {
                currentHighlight.setStyle(DEPT_STYLE);
              }
              layer.setStyle(DEPT_HIGHLIGHT);
              currentHighlight = layer;
            });

            layer.on('mouseout', () => {
              if (currentHighlight) {
                currentHighlight.setStyle(DEPT_STYLE);
                currentHighlight = null;
              }
            });

            layer.on('click', () => {
              map.fitBounds(layer.getBounds(), { padding: [40, 40], maxZoom: 10 });
            });
          },
        });

        deptLayer.addTo(map);
        console.log('✓ Départements layer loaded');
      } catch (err) {
        console.error('Failed to load department GeoJSON:', err);
      }
    }

    // ── Density overlay (commune-level choropleth) ──
    function setLegendContent(html) {
      const normalEl = document.getElementById('map-legend-content');
      const infoLegend = document.getElementById('map-info-legend');
      if (normalEl) normalEl.innerHTML = html;
      if (infoLegend) infoLegend.innerHTML = html;
    }

    function clearLegend() {
      setLegendContent(
        '<p class="data-map__legend-placeholder">Sélectionnez une couche pour voir la légende.</p>'
      );
    }

    function clearDensityLayer() {
      // Cancel any in-flight load
      if (densityLoading) densityCancel = true;
      densityLoading = false;
      // Remove existing layer if present
      if (densityLayer) {
        map.removeLayer(densityLayer);
        densityLayer = null;
      }
      clearLegend();
    }

    function makeDensityLegend() {
      const breaks = [0, 30, 60, 100, 150, 300, 500, 1000, 5000];
      const colors = [
        '#f7fcf0', '#e0f3db', '#ccebc5', '#a8ddb5',
        '#7bccc4', '#4eb3d3', '#2b8cbe', '#0868ac', '#084081',
      ];
      const labels = ['0', '30', '60', '100', '150', '300', '500', '1 000', '5 000+'];
      return labels.map((label, i) => `
        <span class="density-legend__item">
          <span class="density-legend__swatch" style="background:${colors[i]}"></span>
          ${label}
        </span>
      `).join('');
    }

    function setLoading(labelEl, loading) {
      if (labelEl) labelEl.toggleAttribute('data-loading', loading);
    }

    async function applyCommuneDensity() {
      // Cancel any previous loading
      if (densityLoading) densityCancel = true;

      clearDensityLayer();
      if (!deptLayer) return;

      const checkbox = document.getElementById('toggle-density');
      if (!checkbox || !checkbox.checked) return;

      const labelEl = checkbox.closest('.layer-controls__item');
      setLoading(labelEl, true);
      densityLoading = true;
      densityCancel = false;

      setLegendContent(
        '<p class="data-map__legend-subtitle">Densit\u00e9 de population</p><p class="data-map__legend-loading">Chargement des donn\u00e9es...</p>');

      try {
        const resp = await fetch('/data/density-simple.geojson');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();

        // Guard: cancelled or user unchecked while loading
        if (densityCancel || !checkbox.checked) return;

        densityLayer = L.geoJSON(data, {
          pane: 'polygon-pane',
          style: (feature) => {
            const density = feature.properties.density || 0;
            return {
              color: '#475569',
              weight: 0.3,
              fillColor: getDensityColor(density),
              fillOpacity: 0.7,
            };
          },
          onEachFeature: (feature, layer) => {
            const name = feature.properties.nom || '';
            const code = feature.properties.code || '';
            const density = feature.properties.density || 0;
            const pop = feature.properties.population || 0;
            const tooltipHtml = `
              <strong>${escapeHtml(name)}</strong> (${escapeHtml(code)})<br>
              <strong>${getDensityLabel(density)}</strong><br>
              Population: ${pop.toLocaleString('fr-FR')}
            `;
            layer.bindTooltip(tooltipHtml, {
              sticky: true,
              className: 'dept-tooltip dept-tooltip--density',
            });
          },
        });

        // Guard after layer creation
        if (densityCancel || !checkbox.checked) {
          densityLayer = null;  // discard unneeded layer
          return;
        }

        densityLayer.addTo(map);

        const densities = data.features.map(f => f.properties.density || 0);
        const maxDen = Math.max(...densities).toLocaleString('fr-FR');
        const legendHtml = `
          <p class="data-map__legend-subtitle">Densité de population</p>
          <p>Par commune — ${data.features.length} communes. Maximale : ${maxDen} hab/km².</p>
          <div class="density-legend">
            ${makeDensityLegend()}
          </div>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/insee-2024" data-source-id="insee-2024" title="Source : insee-2024">[1]</a></sup></p>
        `;
        setLegendContent(legendHtml);
        if (!densityAttributionAdded) {
          map.attributionControl.addAttribution('Données population : <a href="https://geo.api.gouv.fr/">INSEE — api.gouv.fr</a>');
          densityAttributionAdded = true;
        }
        console.log('✓ Commune-level density loaded');
      } catch (err) {
        console.error('Failed to load commune density:', err);
      } finally {
        setLoading(labelEl, false);
        densityLoading = false;
      }
    }

    // ── Elevation (tile overlay) ──
    function toggleElevation(enabled) {
      if (enabled) {
        if (!elevationLayer) {
          elevationLayer = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://opentopomap.org/about">OpenTopoMap</a> (<a href="https://creativecommons.org/licenses/by-sa/3.0/">CC-BY-SA</a>)',
            maxZoom: 17,
            opacity: 0.7,
          });
        }
        map.addLayer(elevationLayer);
        setLegendContent(`
          <p class="data-map__legend-subtitle">Relief</p>
          <p>Carte topographique avec courbes de niveau et ombrage du terrain.</p>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/opentopomap" data-source-id="opentopomap" title="Source : opentopomap">[4]</a></sup></p>
        `);
      } else {
        if (elevationLayer) {
          map.removeLayer(elevationLayer);
        }
        clearLegend();
      }
    }

    // ── Roads (GeoJSON overlay) ──
    let roadsFetched = false;

    async function fetchRoads() {
      if (roadsFetched) return;
      const roadsLabel = document.querySelector('[data-map-toggle="roads"]');
      setLoading(roadsLabel, true);
      try {
        const resp = await fetch('/data/roads.geojson');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();
        roadsFetched = true;

        const roadStyle = (feature) => ({
          color: feature.properties.highway === 'motorway' ? '#ef4444' : '#f97316',
          weight: feature.properties.highway === 'motorway' ? 1.8 : 1.2,
          opacity: 0.8,
        });

        roadsLayer = L.geoJSON(data, {
          pane: 'line-pane',
          minZoom: 7,
          style: roadStyle,
          onEachFeature: (feature, layer) => {
            const name = feature.properties.name || feature.properties.ref || '';
            const cls = feature.properties.highway === 'motorway' ? 'Autoroute' : 'Route nationale';
            if (name) {
              layer.bindTooltip(`${cls}: ${escapeHtml(name)}`, {
                sticky: true, className: 'dept-tooltip',
              });
            }
          },
        });

        map.addLayer(roadsLayer);

        const legendHtml = `
          <p class="data-map__legend-subtitle">Réseau routier</p>
          <p class="data-map__legend-hint">Visible à partir du zoom 7 (rapprochez-vous).</p>
          <div class="roads-legend">
            <div class="roads-legend__item">
              <span class="roads-legend__line roads-legend__line--motorway"></span>
              Autoroutes
            </div>
            <div class="roads-legend__item">
              <span class="roads-legend__line roads-legend__line--trunk"></span>
              Routes nationales
            </div>
          </div>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/openstreetmap" data-source-id="openstreetmap" title="Source : openstreetmap">[3]</a></sup></p>
        `;
        setLegendContent(legendHtml);
        map.attributionControl.addAttribution('Réseau routier : <a href="https://www.openstreetmap.org/copyright">© contributeurs OSM</a>');
        console.log('✓ Roads layer loaded');
      } catch (err) {
        console.error('Failed to load roads:', err);
        setLegendContent(`
          <p class="data-map__legend-subtitle">Réseau routier</p>
          <p>Données non disponibles. Générez avec : <code>node scripts/fetch-roads.js</code></p>
        `);
      } finally {
        setLoading(roadsLabel, false);
      }
    }

    function toggleRoads(enabled) {
      if (enabled) {
        fetchRoads();
      } else {
        if (roadsLayer) {
          map.removeLayer(roadsLayer);
          roadsLayer = null;
        }
        clearLegend();
      }
    }

    // ── Railways (tile overlay — OpenRailwayMap) ──
    function toggleRailways(enabled) {
      if (enabled) {
        if (!railwaysLayer) {
          railwaysLayer = L.tileLayer('https://{s}.tiles.openrailwaymap.org/standard/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openrailwaymap.org/">OpenRailwayMap</a> (<a href="https://creativecommons.org/licenses/by-sa/3.0/">CC-BY-SA</a>)',
            maxZoom: 19,
            opacity: 0.75,
          });
        }
        map.addLayer(railwaysLayer);
        setLegendContent(`
          <p class="data-map__legend-subtitle">Réseau ferroviaire</p>
          <p>Réseau ferré français — lignes principales, secondaires et de fret.</p>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/openrailwaymap" data-source-id="openrailwaymap" title="Source : openrailwaymap">[5]</a></sup></p>
        `);
      } else {
        if (railwaysLayer) {
          map.removeLayer(railwaysLayer);
          railwaysLayer = null;
        }
        clearLegend();
      }
    }

    // ── Waterways (GeoJSON overlay with zoom-based filtering) ──
    let waterwaysFetched = false;
    let waterwaysData = null;       // cached GeoJSON data
    let waterwaysVisible = false;   // whether the toggle is on

    function renderWaterwaysLayer() {
      // Remove existing layer if any
      if (waterwaysLayer) {
        map.removeLayer(waterwaysLayer);
        waterwaysLayer = null;
      }
      if (!waterwaysData) return;
      if (!waterwaysVisible) return;

      const currentZoom = map.getZoom();

      // Show features whose minZoom <= current zoom
      const filteredFeatures = waterwaysData.features.filter(
        (f) => (f.properties.minZoom || 10) <= currentZoom,
      );

      if (filteredFeatures.length === 0) {
        clearLegend();
        return;
      }

      const filteredData = { ...waterwaysData, features: filteredFeatures };

      const waterwayStyle = (feature) => {
        const isCanal = feature.properties.waterway === 'canal';
        return {
          color: isCanal ? '#06b6d4' : '#0ea5e9',
          weight: isCanal ? 2.5 : 1.8,
          opacity: isCanal ? 0.85 : 0.7,
          // Solid lines only — dashArray is expensive on canvas at low zooms
        };
      };

      waterwaysLayer = L.geoJSON(filteredData, {
        pane: 'line-pane',
        style: waterwayStyle,
        onEachFeature: (feature, layer) => {
          const name = feature.properties.name || '';
          const waterway = feature.properties.waterway === 'canal' ? 'Canal' : 'Rivière navigable';
          if (name) {
            const lenKm = feature.properties.lengthKm;
            const lenStr = lenKm ? ` — ${lenKm} km` : '';
            layer.bindTooltip(`${waterway}: <strong>${escapeHtml(name)}</strong>${lenStr}`, {
              sticky: true, className: 'dept-tooltip',
            });
          }
        },
      });

      waterwaysLayer.addTo(map);
    }

    async function fetchWaterways() {
      if (waterwaysFetched && waterwaysData) return;
      const waterwaysLabel = document.querySelector('[data-map-toggle="waterways"]');
      setLoading(waterwaysLabel, true);
      try {
        const resp = await fetch('/data/waterways.geojson');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        waterwaysData = await resp.json();
        waterwaysFetched = true;

        renderWaterwaysLayer();

        // Update legend
        const canalCount = waterwaysData.features.filter(f => f.properties.waterway === 'canal').length;
        const riverCount = waterwaysData.features.filter(f => f.properties.waterway === 'river').length;
        const atZoom = map.getZoom();
        const visibleCount = waterwaysData.features.filter(
          (f) => (f.properties.minZoom || 10) <= atZoom,
        ).length;
        const legendHtml = `
          <p class="data-map__legend-subtitle">Voies navigables</p>
          <p class="data-map__legend-hint">Affichage progressif selon le niveau de zoom&nbsp;: ${visibleCount} voies visibles (zoom ${atZoom}).</p>
          <div class="waterways-legend">
            <div class="waterways-legend__item">
              <span class="waterways-legend__line waterways-legend__line--canal"></span>
              Canaux
            </div>
            <div class="waterways-legend__item">
              <span class="waterways-legend__line waterways-legend__line--river"></span>
              Rivières navigables
            </div>
          </div>
          <p>${canalCount} canaux, ${riverCount} rivières navigables (${waterwaysData.features.length} segments après fusion).</p>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/openstreetmap" data-source-id="openstreetmap" title="Source : openstreetmap">[3]</a></sup></p>
        `;
        setLegendContent(legendHtml);
        map.attributionControl.addAttribution('Voies navigables : <a href="https://www.openstreetmap.org/copyright">© contributeurs OSM</a>');
        console.log(`✓ Waterways layer loaded (${waterwaysData.features.length} features, ${visibleCount} visible at zoom ${atZoom})`);
      } catch (err) {
        console.error('Failed to load waterways:', err);
        setLegendContent(`
          <p class="data-map__legend-subtitle">Voies navigables</p>
          <p>Données non disponibles. Générez avec : <code>node scripts/fetch-waterways.js</code> puis <code>node scripts/simplify-line-layers.js</code></p>
        `);
      } finally {
        setLoading(waterwaysLabel, false);
      }
    }

    function toggleWaterways(enabled) {
      waterwaysVisible = enabled;
      if (enabled) {
        fetchWaterways();
      } else {
        if (waterwaysLayer) {
          map.removeLayer(waterwaysLayer);
          waterwaysLayer = null;
        }
        clearLegend();
      }
    }

    // ── Zoom listener: rebuild waterways layer when zoom changes ──
    map.on('zoomend', () => {
      if (waterwaysVisible && waterwaysData) {
        renderWaterwaysLayer();
        // Update visible count in legend
        const zoom = map.getZoom();
        const visibleCount = waterwaysData.features.filter(
          (f) => (f.properties.minZoom || 10) <= zoom,
        ).length;
        const hintEl = document.querySelector('.data-map__legend-hint');
        if (hintEl) {
          hintEl.textContent = `Affichage progressif selon le niveau de zoom : ${visibleCount} voies visibles (zoom ${zoom}).`;
        }
      }
    });

    // ── Communes (GeoJSON overlay) ──
    let communesFetched = false;

    async function fetchCommunes() {
      if (communesFetched) return;
      const communesLabel = document.querySelector('[data-map-toggle="communes"]');
      setLoading(communesLabel, true);
      try {
        const resp = await fetch('/data/communes-density.geojson');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();
        communesFetched = true;

        communesLayer = L.geoJSON(data, {
          pane: 'polygon-pane',
          minZoom: 9,
          style: {
            color: '#6366f1',
            weight: 0.4,
            fillOpacity: 0,
          },
          onEachFeature: (feature, layer) => {
            const name = feature.properties.nom || '';
            const code = feature.properties.code || '';
            const pop = feature.properties.population || 0;
            if (name) {
              layer.bindTooltip(`${escapeHtml(name)} (${escapeHtml(code)})<br>Population: ${pop.toLocaleString('fr-FR')}`, {
                sticky: true, className: 'dept-tooltip',
              });
            }
          },
        });

        map.addLayer(communesLayer);

        setLegendContent(`
          <p class="data-map__legend-subtitle">Communes</p>
          <p class="data-map__legend-hint">Visible à partir du zoom 9.</p>
          <p>Limites des ${data.features.length} communes de France.</p>
          <p class="data-map__legend-source"><sup class="citation"><a href="/bibliographie/france-geojson" data-source-id="france-geojson" title="Source : france-geojson">[6]</a></sup></p>
        `);
        map.attributionControl.addAttribution('Limites communales : <a href="https://github.com/gregoiredavid/france-geojson">france-geojson</a>');
        console.log('✓ Communes layer loaded');
      } catch (err) {
        console.error('Failed to load communes:', err);
        setLegendContent(`
          <p class="data-map__legend-subtitle">Communes</p>
          <p>Données non disponibles. Générez avec : <code>node scripts/build-density-grid.js</code></p>
        `);
      } finally {
        setLoading(communesLabel, false);
      }
    }

    function toggleCommunes(enabled) {
      if (enabled) {
        fetchCommunes();
      } else {
        if (communesLayer) {
          map.removeLayer(communesLayer);
          communesLayer = null;
        }
        clearLegend();
      }
    }

    // ── Layer toggles (custom UI) ──
    function setupToggles() {
      const toggles = document.querySelectorAll('[data-map-toggle]');
      toggles.forEach((toggle) => {
        toggle.addEventListener('change', async (e) => {
          const layer = e.target.dataset.mapToggle;

          switch (layer) {
            case 'density':
              if (e.target.checked) {
                await applyCommuneDensity();
              } else {
                clearDensityLayer();
              }
              break;
            case 'elevation':
              toggleElevation(e.target.checked);
              break;
            case 'roads':
              toggleRoads(e.target.checked);
              break;
            case 'railways':
              toggleRailways(e.target.checked);
              break;
            case 'waterways':
              toggleWaterways(e.target.checked);
              break;
            case 'communes':
              toggleCommunes(e.target.checked);
              // Show/hide density suboption
              const densityRow = document.querySelector('.layer-controls__suboption');
              const densityCheck = document.getElementById('toggle-density');
              if (e.target.checked) {
                if (densityRow) densityRow.classList.remove('layer-controls__suboption--hidden');
              } else {
                if (densityRow) densityRow.classList.add('layer-controls__suboption--hidden');
                if (densityCheck && densityCheck.checked) {
                  densityCheck.checked = false;
                  clearDensityLayer();
                }
              }
              break;
          }
        });
      });
    }

    // ── Fullscreen control ──
    const fullscreenControl = L.control({ position: 'topright' });
    let isFullscreen = false;

    fullscreenControl.onAdd = function () {
      const btn = L.DomUtil.create('button', 'leaflet-control-zoom leaflet-control-fullscreen');
      btn.setAttribute('type', 'button');
      btn.setAttribute('aria-label', 'Plein écran');
      btn.setAttribute('title', 'Plein écran');
      btn.innerHTML = '<span class="fullscreen-icon">⛶</span>';
      btn.style.cssText = `
        font-size: 18px; line-height: 30px; text-align: center;
        cursor: pointer; width: 30px; height: 30px;
        background: #1e293b; border: 1px solid #334155; border-radius: 4px;
      `;

      btn.addEventListener('click', () => {
        const wrapper = document.getElementById('map-page-wrapper');
        if (!wrapper) return;

        if (!document.fullscreenElement) {
          wrapper.requestFullscreen().catch(() => {});
        } else {
          document.exitFullscreen().catch(() => {});
        }
      });

      return btn;
    };

    fullscreenControl.addTo(map);

    // Track fullscreen state to resize map, move legend, toggle panels
    document.addEventListener('fullscreenchange', () => {
      isFullscreen = !!document.fullscreenElement;
      map.invalidateSize();
      // Toggle class on wrapper and controls for overlay mode
      const wrapper = document.getElementById('map-page-wrapper');
      if (wrapper) {
        wrapper.classList.toggle('is-fullscreen', isFullscreen);
      }
      const controls = document.querySelector('.layer-controls');
      if (controls) {
        controls.classList.toggle('layer-controls--fullscreen', isFullscreen);
        if (!isFullscreen) controls.classList.remove('layer-controls--collapsed');
      }
      // Move legend content between normal and fullscreen containers
      const legendContent = document.getElementById('map-legend-content');
      const infoLegend = document.getElementById('map-info-legend');
      if (isFullscreen && legendContent && infoLegend) {
        infoLegend.innerHTML = legendContent.innerHTML;
        legendContent.innerHTML = '';
      } else if (!isFullscreen && infoLegend && legendContent) {
        legendContent.innerHTML = infoLegend.innerHTML;
        infoLegend.innerHTML = '';
      }
      // When entering fullscreen, auto-show panels
      if (isFullscreen) {
        document.body.classList.add('has-fullscreen-map');
        const infoPanel = document.getElementById('map-info-panel');
        if (infoPanel) infoPanel.classList.remove('interactive-page__info-panel--collapsed');
      } else {
        document.body.classList.remove('has-fullscreen-map');
      }
      // Update button icon
      const btn = document.querySelector('.leaflet-control-fullscreen');
      if (btn) {
        btn.innerHTML = isFullscreen
          ? '<span class="fullscreen-icon">✕</span>'
          : '<span class="fullscreen-icon">⛶</span>';
        btn.setAttribute('aria-label', isFullscreen ? 'Quitter le plein écran' : 'Plein écran');
        btn.setAttribute('title', isFullscreen ? 'Quitter le plein écran' : 'Plein écran');
      }
    });

    // ── Fullscreen: layer panel collapse toggle ──
    function setupFullscreenCollapse() {
      const collapseBtn = document.querySelector('.layer-controls__collapse');
      const controls = document.querySelector('.layer-controls');
      if (!collapseBtn || !controls) return;

      collapseBtn.addEventListener('click', () => {
        const isCollapsed = controls.classList.toggle('layer-controls--collapsed');
        collapseBtn.setAttribute('aria-label', isCollapsed ? 'Afficher les couches' : 'Masquer les couches');
        collapseBtn.setAttribute('title', isCollapsed ? 'Afficher les couches' : 'Masquer les couches');
        collapseBtn.innerHTML = isCollapsed ? '<span>☰</span>' : '<span>◀</span>';
        // Re-trigger map size recalculation
        map.invalidateSize();
      });
    }

    // ── Fullscreen: info panel collapse toggle ──
    function setupInfoPanelToggle() {
      const header = document.querySelector('.interactive-page__info-panel-header');
      const panel = document.getElementById('map-info-panel');
      if (!header || !panel) return;

      header.addEventListener('click', () => {
        const isCollapsed = panel.classList.toggle('interactive-page__info-panel--collapsed');
        const toggleBtn = panel.querySelector('.interactive-page__info-panel-toggle');
        if (toggleBtn) {
          toggleBtn.setAttribute('aria-label', isCollapsed ? 'Afficher le panneau d\'information' : 'Masquer le panneau d\'information');
          toggleBtn.setAttribute('title', isCollapsed ? 'Afficher le panneau d\'information' : 'Masquer le panneau d\'information');
        }
        map.invalidateSize();
      });
    }

    // ── Init ──
    loadDepartments();
    setupToggles();
    setupTippy();
    setupFullscreenCollapse();
    setupInfoPanelToggle();

    // Invalidate map size when container becomes visible (Astro navigation)
    setTimeout(() => map.invalidateSize(), 200);

    // Handle Astro View Transitions
    document.addEventListener('astro:after-swap', () => {
      setTimeout(() => map.invalidateSize(), 200);
    });
  })();
</script>

