<style>
  .data-map-section {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--gap-lg);
  }

  .data-map-section__info {
    margin-bottom: var(--gap-md);
  }

  .data-map-section__desc {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .data-map {
    width: 100%;
    height: 600px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: #1e293b;
  }

  .data-map__noscript {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-text-muted);
    font-size: 1rem;
    padding: var(--gap-lg);
    text-align: center;
  }

  /* ── Legend ── */
  .data-map__legend {
    margin-top: var(--gap-md);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .data-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .data-map__legend-content {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .data-map__legend-placeholder {
    font-style: italic;
  }

  .data-map__legend-subtitle {
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .data-map__legend-source {
    margin-top: var(--gap-xs);
    font-size: 0.75rem;
  }

  .data-map__legend-source a {
    color: var(--color-french-blue);
    text-decoration: none;
  }

  .data-map__legend-source a:hover {
    text-decoration: underline;
  }

  /* ── Density legend ── */
  .density-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    margin: var(--gap-xs) 0;
  }

  .density-legend__item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .density-legend__swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.1);
    flex-shrink: 0;
  }

  /* ── Roads legend ── */
  .roads-legend {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: var(--gap-xs) 0;
  }

  .roads-legend__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .roads-legend__line {
    display: inline-block;
    height: 4px;
    width: 28px;
    border-radius: 1px;
    flex-shrink: 0;
  }

  .roads-legend__line--motorway {
    background: #ef4444;
  }

  .roads-legend__line--trunk {
    background: #f97316;
  }

  .data-map__legend-warning {
    color: var(--color-accent-gold, #d4a843);
    font-size: 0.75rem;
    margin-top: var(--gap-xs);
  }

  /* ── Leaflet overrides ── */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #1e293b;
  }

  :global(.leaflet-control-zoom a) {
    background: #1e293b;
    color: #e2e8f0;
    border-color: #334155;
