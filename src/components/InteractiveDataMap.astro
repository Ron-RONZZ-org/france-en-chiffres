    text-decoration: none;
    font-weight: 600;
  }

  .data-map__legend-content sup.citation a:hover {
    text-decoration: underline;
  }

  /* ── Leaflet overrides ── */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #1e293b;
  }

  :global(.leaflet-control-zoom a),
  :global(.leaflet-control-fullscreen) {
    background: #1e293b;
    color: #e2e8f0;
    border-color: #334155;
  }

  :global(.leaflet-control-zoom a:hover),
  :global(.leaflet-control-fullscreen:hover) {
    background: #334155;
    color: #d4a843;
  }

  :global(.leaflet-control-attribution) {
    background: rgba(15, 23, 42, 0.85) !important;
    color: #64748b;
    font-size: 0.65rem;
  }

  :global(.leaflet-control-attribution a) {
    color: #94a3b8;
  }

  /* ── Tooltip ── */
  :global(.dept-tooltip) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
    padding: 0.35rem 0.6rem;
    white-space: nowrap;
  }

  :global(.dept-tooltip::before) {
    border-top-color: #1e293b;
  }

  :global(.dept-tooltip--density) {
    font-size: 0.85rem;
  }

  :global(.dept-tooltip--density strong) {
    color: #d4a843;
  }

  /* ── Tippy dark theme ── */
  :global(.tippy-box[data-theme~="dark"]) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-arrow) {
    color: #111827;
    stroke: #1e293b;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-content) {
    padding: 0.5rem 0.65rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .data-map {
      height: 400px;
    }
