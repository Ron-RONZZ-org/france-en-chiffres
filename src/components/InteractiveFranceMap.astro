---
// InteractiveFranceMap.astro — Department-level interactive map
// Props: variant = "hero" | "geography"
import { france, dom } from '../data/france-map-data.json';
import departmentsData from '../data/france-departments.json';

export interface Props {
  variant?: 'hero' | 'geography';
}

const { variant = 'geography' } = Astro.props;
const isHero = variant === 'hero';
const departments = departmentsData.departments;
const deptTransform = departmentsData.transform;
---

{
  isHero ? (
    <div class="france-map-layout">
      <div class="france-map-layout__center">
        <svg class="france-map"
          viewBox={`${france.viewBox.x} ${france.viewBox.y} ${france.viewBox.width} ${france.viewBox.height}`}
          fill="none" xmlns="http://www.w3.org/2000/svg"
          aria-label="Carte de la France — métropole, Corse et départements"
          role="img">
          <path class="france-map__glow" d={france.path}
            stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" opacity="0.15" />
          <path class="france-map__outline" d={france.path}
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />

          <g class="departments departments--hero" transform={deptTransform}>
            {departments.map((dept) => (
              <path key={dept.num} class="department" d={dept.path}
                data-num={dept.num} data-name={dept.name}
                fill="rgba(0,0,0,0)" stroke="currentColor" stroke-width="1.2"
                stroke-linecap="round" stroke-linejoin="round">
                <title>{dept.name} ({dept.num})</title>
              </path>
            ))}
          </g>
        </svg>

        <div class="france-map-layout__dom-row">
          {dom.map((territory, i) => (
            <div class="dom-insets__item" style={`--i: ${i}`}>
              <svg class="dom-insets__svg"
                viewBox={`${territory.viewBox.x} ${territory.viewBox.y} ${territory.viewBox.width} ${territory.viewBox.height}`}
                fill="none" xmlns="http://www.w3.org/2000/svg"
                aria-label={`${territory.label} (${territory.num})`} role="img">
                <title>{territory.label} ({territory.num})</title>
                <path class="dom-insets__path" d={territory.path}
                  stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="dom-insets__label">{territory.label} ({territory.num})</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  ) : (
    <div class="geography-layout">
      <div class="geography-layout__main">
        <svg class="geography-map"
          viewBox={`${france.viewBox.x} ${france.viewBox.y} ${france.viewBox.width} ${france.viewBox.height}`}
          fill="none" xmlns="http://www.w3.org/2000/svg"
          aria-label="Carte des départements français"
          role="img">
          <g class="departments" transform={deptTransform}>
            {departments.map((dept) => (
              <path key={dept.num} class="department department--geography" d={dept.path}
                data-num={dept.num} data-name={dept.name}
                data-preview-num={dept.num} data-preview-name={dept.name}
                stroke="currentColor" stroke-width="1"
                stroke-linecap="round" stroke-linejoin="round">
              </path>
            ))}
          </g>
        </svg>

        <div class="geography-layout__dom">
          {dom.map((territory) => (
            <div class="dom-insets__item dom-insets__item--geography"
              data-preview-name={territory.label} data-preview-num={territory.num}>
              <svg class="dom-insets__svg dom-insets__svg--geography"
                viewBox={`${territory.viewBox.x} ${territory.viewBox.y} ${territory.viewBox.width} ${territory.viewBox.height}`}
                fill="none" xmlns="http://www.w3.org/2000/svg"
              aria-label={`${territory.label} (${territory.num})`} role="img">
              <title>{territory.label} ({territory.num})</title>
              <path class="dom-insets__path" d={territory.path}
                stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="dom-insets__label">{territory.label} ({territory.num})</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}

<script>
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const isGeo = document.querySelector('.geography-layout') !== null;
    if (!isGeo) return;

    const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    const ACCENT = '#d4a843'; // gold accent for geography

    const escapeHTML = (str) => {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    };

    const buildPreviewHTML = (el) => {
      const name = el.dataset.previewName || '';
      const num = el.dataset.previewNum || '';
      return `
        <div class="geog-preview" style="--accent:${ACCENT}">
          <span class="geog-preview__num">${escapeHTML(num)}</span>
          <h4 class="geog-preview__title">${escapeHTML(name)}</h4>
        </div>
      `;
    };

    // ── Departments ──
    const depts = document.querySelectorAll('.department--geography');
    depts.forEach((path) => {
      tippy(path, {
        content: buildPreviewHTML(path),
        allowHTML: true,
        trigger: isTouch ? 'click' : 'mouseenter',
        interactive: false,
        hideOnClick: isTouch,
        placement: 'top',
        maxWidth: 280,
        theme: 'dark',
        animation: 'shift-away',
        duration: [250, 150],
        appendTo: document.body,
        onShow(instance) {
          // Hide all other tippies
          depts.forEach((other) => {
            if (other !== path && other._tippy) {
              other._tippy.hide();
            }
          });
        },
      });
    });

    // ── DOM-COM territories ──
    const domItems = document.querySelectorAll('.dom-insets__item--geography');
    domItems.forEach((item) => {
      tippy(item, {
        content: buildPreviewHTML(item),
        allowHTML: true,
        trigger: isTouch ? 'click' : 'mouseenter',
        interactive: false,
        hideOnClick: isTouch,
        placement: 'top',
        maxWidth: 280,
        theme: 'dark',
        animation: 'shift-away',
        duration: [250, 150],
        appendTo: document.body,
        onShow(instance) {
          domItems.forEach((other) => {
            if (other !== item && other._tippy) {
              other._tippy.hide();
            }
          });
        },
      });
    });
  })();
</script>

<style>
  /* ===== Shared ===== */
  .department {
    cursor: pointer;
    pointer-events: all;
    transition: fill var(--transition-fast), stroke-width var(--transition-fast), stroke var(--transition-fast);
  }

  .department:hover {
    fill: rgba(212, 168, 67, 0.2);
    stroke: var(--color-accent-gold);
    stroke-width: 2;
  }

  .dom-insets__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .dom-insets__svg {
    width: 40px;
    height: 40px;
    color: var(--color-accent-gold);
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .dom-insets__svg:hover {
    opacity: 1;
  }

  .dom-insets__path {
    transition: stroke var(--transition-fast), stroke-width var(--transition-fast);
    cursor: pointer;
  }

  .dom-insets__path:hover {
    stroke: var(--color-accent-gold);
    stroke-width: 4;
  }

  .dom-insets__label {
    font-size: 0.55rem;
    color: var(--color-text-muted);
    text-align: center;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .france-map__outline,
    .france-map__glow,
    .departments--hero .department {
      animation: none;
    }
  }

  /* ===== Hero variant ===== */
  .france-map-layout {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .france-map-layout__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-md);
  }

  .france-map-layout__dom-row {
    display: flex;
    justify-content: center;
    gap: var(--gap-md);
  }

  .france-map {
    width: 280px;
    height: auto;
    color: var(--color-accent-gold);
    filter: drop-shadow(0 0 16px rgba(212, 168, 67, 0.35));
  }

  .france-map__outline {
    stroke-dasharray: 10000;
    stroke-dashoffset: 10000;
    animation: draw-france 4s ease-out forwards;
  }

  .france-map__glow {
    stroke-dasharray: 10000;
    stroke-dashoffset: 10000;
    animation: draw-france 4s ease-out forwards;
  }

  @keyframes draw-france {
    to { stroke-dashoffset: 0; }
  }

  .departments--hero {
    opacity: 0;
    animation: fade-depts 0.8s ease-out 4.2s forwards;
  }

  @keyframes fade-depts {
    to { opacity: 1; }
  }

  .dom-insets__item {
    opacity: 0;
    animation: fade-up-dom 0.6s ease-out calc(0.8s + var(--i, 0) * 0.15s) forwards;
  }

  @keyframes fade-up-dom {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }


  /* ===== Geography variant ===== */
  .geography-layout {
    width: 100%;
  }

  .geography-layout__main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-lg);
  }

  .geography-map {
    width: 100%;
    max-width: 800px;
    height: auto;
    color: var(--color-text-muted);
  }

  .geography-layout__dom {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--gap-md);
  }

  .dom-insets__svg--geography {
    width: 55px;
    height: 55px;
  }

  .department--geography {
    fill: rgba(212, 168, 67, 0.05);
    stroke: var(--color-text-muted);
  }

  .dom-insets__item--geography {
    cursor: pointer;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .france-map-layout {
      max-width: 320px;
    }
    .france-map-layout__dom-row {
      flex-wrap: wrap;
      gap: var(--gap-sm);
    }
    .france-map { width: 240px; }
    .dom-insets__svg { width: 35px; height: 35px; }
    .dom-insets__svg--geography { width: 48px; height: 48px; }
    .geography-map { max-width: 100%; }
  }

  @media (max-width: 400px) {
    .france-map { width: 200px; }
    .dom-insets__svg { width: 30px; height: 30px; }
    .dom-insets__svg--geography { width: 40px; height: 40px; }
  }
</style>

<!-- Global popup styles (unscoped — Tippy renders at <body> level) -->
<style is:global>
  /* Reuse dark theme from history page */
  .tippy-box[data-theme~="dark"] {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
    color: #e2e8f0;
  }

  .tippy-box[data-theme~="dark"] .tippy-arrow {
    color: #111827;
    stroke: #1e293b;
  }

  .tippy-box[data-theme~="dark"] .tippy-content {
    padding: 0.5rem 0.75rem;
  }

  .tippy-box[data-theme~="dark"][data-placement^="bottom"] > .tippy-arrow::before {
    border-bottom-color: #1e293b;
  }

  .geog-preview {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: 'Inter', system-ui, sans-serif;
    text-align: left;
    border-left: 3px solid var(--accent, #d4a843);
    padding-left: 0.75rem;
  }

  .geog-preview__num {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .geog-preview__title {
    font-family: 'Playfair Display', 'Times New Roman', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #e2e8f0;
    line-height: 1.3;
    margin: 0;
  }
</style>
