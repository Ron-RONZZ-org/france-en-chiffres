---
// MapPageLayout.astro — Shared layout template for interactive map pages
// Provides: wrapper, container, title/subtitle, layer-controls slot, collapse button,
// map slot, related-links slot, collapsible info panel (legend + sources).
//
// All fullscreen CSS lives here, properly scoped to the component's template,
// avoiding the scoping mismatch that occurs when page-level CSS is placed
// inside a child component's <style>.

interface Props {
  wrapperId: string;
  title: string;
  subtitle: string;
  sourceIds: string[];
}

const { wrapperId, title, subtitle, sourceIds } = Astro.props;

import Base from '../layouts/Base.astro';
import { getSource, formatSourceLabel } from '../data/sources';

const sources = (await Promise.all(
  sourceIds.map((id) => getSource(id)),
)).filter(Boolean);
---

<Base
  title={title + ' — France en Chiffres'}
  description={subtitle}
>
  <section id={wrapperId} class="map-page-wrapper">
    <div class="container">
      <h1 class="map-page__title">{title}</h1>
      <p class="map-page__subtitle">{subtitle}</p>
      <div class="french-separator"></div>

      <!-- Layer controls (slot) — the wrapper div IS in the layout template so
           scoped CSS can target it; individual toggle items come from the page
           via slot and need :global() selectors (handled below). -->
      <div class="map-layer-controls" role="group" aria-label="Couches thématiques">
        <slot name="controls" />
      </div>

      <!-- Collapse button (floating sibling, visible in fullscreen) —
           also in the layout template so scoped selectors work. -->
      <button class="map-layer-controls__collapse" type="button" aria-label="Masquer les couches" title="Masquer les couches">
        <span>◀</span>
      </button>

      <!-- Map component (slot) -->
      <slot name="map" />

      <!-- Related links -->
      <div class="map-page__related">
        <h2 class="map-page__related-title">Ça peut vous intéresser aussi&nbsp;:</h2>
        <ul class="map-page__related-links">
          <slot name="related-links" />
        </ul>
      </div>

      <!-- Info panel (legend + sources, collapsed in fullscreen) -->
      <div class="map-info-panel" id="map-info-panel">
        <div class="map-info-panel__header">
          <span class="map-info-panel__title">Informations</span>
          <button class="map-info-panel__toggle" type="button" aria-label="Masquer le panneau d'information" title="Masquer le panneau d'information">
            <span>▼</span>
          </button>
        </div>
        <div class="map-info-panel__body">
          <!-- Legend content moved here by JS in fullscreen -->
          <div class="map-info-panel__legend" id="map-info-legend"></div>

          <footer class="map-info-panel__sources">
            {sources.length > 0 && (
              <>
                <p class="map-info-panel__sources-title">Sources des données</p>
                <ol class="map-info-panel__sources-list">
                  {sources.map((s) => (
                    <li class="map-info-panel__source-item">
                      <a href={`/bibliographie/${s.id}`}>{formatSourceLabel(s)}</a>
                    </li>
                  ))}
                </ol>
              </>
            )}
          </footer>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ═══════════════════════════════════════════════════════════════
     MAP PAGE LAYOUT — shared across geographie/carte-interactive
     and monde/carte-interactive.
     ═══════════════════════════════════════════════════════════════ */

  /* ── Page wrapper ── */
  .map-page-wrapper {
    padding-top: var(--gap-xl);
    padding-bottom: var(--gap-2xl);
  }

  .map-page__title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .map-page__subtitle {
    color: var(--color-text-muted);
    text-align: center;
    max-width: 550px;
    margin: 0 auto var(--gap-lg);
    font-size: 1rem;
  }

  /* ── Layer controls ──
       Note: .map-layer-controls (the wrapper div) IS in the layout template,
       so scoped selectors match.  Individual items inside come from the page
       via <slot>, so selectors targeting them use :global().  The wrapper
       scope ensures these rules only apply inside map-layer-controls blocks
       rendered by this component, not globally. */

  .map-layer-controls {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--gap-sm);
    margin-bottom: var(--gap-lg);
  }

  .map-layer-controls :global(.map-layer-controls__item) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast);
    user-select: none;
  }

  .map-layer-controls :global(.map-layer-controls__item:hover) {
    border-color: var(--color-french-blue);
    background: rgba(59, 130, 246, 0.05);
  }

  .map-layer-controls :global(.map-layer-controls__group) {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.4rem;
  }

  .map-layer-controls :global(.map-layer-controls__group > .map-layer-controls__item) {
    border: none;
    padding: 0.3rem 0.4rem;
  }

  .map-layer-controls :global(.map-layer-controls__group > .map-layer-controls__item:hover) {
    background: rgba(59, 130, 246, 0.08);
    border-radius: var(--radius-sm);
  }

  .map-layer-controls :global(.map-layer-controls__suboption) {
    padding-left: 1.8rem !important;
  }

  .map-layer-controls :global(.map-layer-controls__suboption--hidden) {
    display: none;
  }

  .map-layer-controls :global(.map-layer-controls__swatch) {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .map-layer-controls :global(.map-layer-controls__checkbox) {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid #475569;
    border-radius: 4px;
    background: #1e293b;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 0;
    transition: border-color var(--transition-fast), background var(--transition-fast);
    position: relative;
  }

  .map-layer-controls :global(.map-layer-controls__checkbox:checked) {
    border-color: var(--color-french-blue);
    background: var(--color-french-blue);
  }

  .map-layer-controls :global(.map-layer-controls__checkbox:checked::after) {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }

  .map-layer-controls :global(.map-layer-controls__checkbox:focus-visible) {
    outline: 2px solid var(--color-accent-gold);
    outline-offset: 2px;
  }

  .map-layer-controls :global(.map-layer-controls__label) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: 0.85rem;
  }

  .map-layer-controls :global(.map-layer-controls__label strong) {
    color: var(--color-text-light);
    font-weight: 600;
  }

  .map-layer-controls :global(.map-layer-controls__item[data-loading] .map-layer-controls__label::after) {
    content: '…';
    display: inline-block;
    animation: map-layer-loading-blink 1.2s steps(1, end) infinite;
    margin-left: 0.25rem;
    color: var(--color-accent-gold);
  }

  @keyframes map-layer-loading-blink {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  .map-layer-controls :global(.map-layer-controls__item--disabled) {
    border-color: var(--color-border);
    background: transparent;
  }

  /* ── Collapse button (in layout template — scoped selector works) ── */
  .map-layer-controls__collapse {
    display: none;
    position: fixed;
    top: var(--gap-md);
    left: var(--gap-md);
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(15, 23, 42, 0.9);
    color: var(--color-text-light);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    line-height: 1;
    z-index: 1001;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: left var(--transition-normal);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .map-layer-controls__collapse:hover {
    background: rgba(30, 41, 59, 0.95);
  }

  /* ── Related links ── */
  .map-page__related {
    margin-top: var(--gap-xl);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .map-page__related-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .map-page__related-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .map-page__related-links li {
    margin-bottom: var(--gap-xs);
  }

  .map-page__related-links a {
    color: var(--color-link-on-dark);
    text-decoration: none;
    font-weight: 500;
    transition: text-decoration var(--transition-fast);
  }

  .map-page__related-links a:hover {
    text-decoration: underline;
  }

  /* ── Sources ── */
  .map-info-panel__sources {
    margin-top: var(--gap-lg);
    padding-top: var(--gap-md);
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  .map-info-panel__sources-title {
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .map-info-panel__sources-list {
    padding-left: var(--gap-lg);
    margin: 0;
    list-style: decimal;
  }

  .map-info-panel__source-item {
    margin-bottom: var(--gap-xs);
    line-height: 1.5;
  }

  .map-info-panel__source-item a {
    color: var(--color-link-on-dark);
    text-decoration: none;
  }

  .map-info-panel__source-item a:focus-visible {
    outline: 2px solid var(--color-link-on-dark);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .map-info-panel__source-item a:hover {
    text-decoration: underline;
  }

  /* ── Info panel (hidden in normal mode, shown in fullscreen) ── */
  .map-info-panel {
    display: none;
  }

  .map-info-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem var(--gap-md);
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    flex-shrink: 0;
    min-height: 36px;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .map-info-panel__title {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .map-info-panel__toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-light);
    cursor: pointer;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    transition: transform var(--transition-fast);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .map-info-panel--collapsed .map-info-panel__toggle {
    transform: rotate(180deg);
  }

  .map-info-panel__body {
    overflow-y: auto;
    padding: var(--gap-sm) var(--gap-md);
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-md);
    align-items: flex-start;
  }

  /* Citation superscripts inside layer controls */
  :global(.map-layer-controls sup.citation) {
    font-size: 0.75em;
    vertical-align: super;
    line-height: 1;
  }

  :global(.map-layer-controls sup.citation a) {
    color: var(--color-link-on-dark);
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .map-layer-controls {
      grid-template-columns: 1fr;
    }

    .map-layer-controls__collapse {
      display: flex;
      width: 44px;
      height: 44px;
      font-size: 1.1rem;
    }

    .map-layer-controls:not(.map-layer-controls--fullscreen).map-layer-controls--collapsed {
      display: none !important;
    }

    .map-info-panel__toggle {
      width: 36px;
      height: 36px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     FULLSCREEN LAYOUT — the wrapper is position:fixed over the viewport.
     ═══════════════════════════════════════════════════════════════ */

  .map-page-wrapper.is-fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    background: var(--color-bg-base);
    display: flex;
    flex-direction: row;
    align-items: stretch;
    padding: 0 !important;
  }

  .map-page-wrapper.is-fullscreen .container {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  /* Hide non-map elements */
  .map-page-wrapper.is-fullscreen .map-page__title,
  .map-page-wrapper.is-fullscreen .map-page__subtitle,
  .map-page-wrapper.is-fullscreen .french-separator,
  .map-page-wrapper.is-fullscreen .map-page__related {
    display: none;
  }

  /* ── Layer controls: sidebar in fullscreen ──
       The wrapper div (.map-layer-controls) is in the layout template so
       scoped selectors match.  Items inside come from the page via slot,
       so descendant selectors use :global(). */

  .map-layer-controls--fullscreen {
    position: absolute;
    top: 0;
    left: 0;
    width: 240px;
    height: 100%;
    overflow-y: auto;
    z-index: 1001;
    background: rgba(15, 23, 42, 0.92);
    border-right: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--gap-lg) var(--gap-md);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    transition: transform var(--transition-normal), opacity var(--transition-normal);
  }

  .map-layer-controls--fullscreen.map-layer-controls--collapsed {
    transform: translateX(-100%);
  }

  .map-layer-controls--fullscreen.map-layer-controls--collapsed :global(.map-layer-controls__item),
  .map-layer-controls--fullscreen.map-layer-controls--collapsed :global(.map-layer-controls__group) {
    pointer-events: none;
  }

  .map-layer-controls--fullscreen :global(.map-layer-controls__group) {
    border: none;
    padding: 0;
    margin: 0;
  }

  .map-layer-controls--fullscreen :global(.map-layer-controls__group .map-layer-controls__item) {
    font-size: 0.8rem;
  }

  .map-layer-controls--fullscreen :global(.map-layer-controls__suboption) {
    padding-left: 1.5rem !important;
  }

  /* Collapse button in fullscreen */
  .map-page-wrapper.is-fullscreen .map-layer-controls__collapse {
    display: flex;
  }

  .map-page-wrapper.is-fullscreen .map-layer-controls:not(.map-layer-controls--collapsed) ~ .map-layer-controls__collapse {
    left: 240px;
  }

  /* ── Map section in fullscreen (global targets for component elements) ── */
  .map-page-wrapper.is-fullscreen :global(.data-map-section),
  .map-page-wrapper.is-fullscreen :global(.world-map-section) {
    flex: 1;
    max-width: none;
    padding: 0;
    display: flex;
    align-items: stretch;
  }

  .map-page-wrapper.is-fullscreen :global(.data-map),
  .map-page-wrapper.is-fullscreen :global(.world-map) {
    height: 100vh;
    border-radius: 0;
    border: none;
  }

  /* Push Leaflet zoom controls down to clear the collapse button */
  .map-page-wrapper.is-fullscreen :global(.leaflet-control-zoom) {
    margin-top: 52px;
  }

  /* ── Info panel in fullscreen: collapsible bottom bar ── */
  .map-page-wrapper.is-fullscreen .map-info-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 1001;
    background: rgba(15, 23, 42, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid var(--color-border);
    transition: transform var(--transition-normal);
    max-height: 40vh;
    display: flex;
    flex-direction: column;
  }

  .map-page-wrapper.is-fullscreen .map-info-panel--collapsed {
    transform: translateY(calc(100% - 36px));
  }

  /* Hide original legend container in fullscreen */
  .map-page-wrapper.is-fullscreen :global(.data-map__legend),
  .map-page-wrapper.is-fullscreen :global(.world-map__legend) {
    display: none;
  }

  /* Compact sources/footer inside the info panel */
  .map-page-wrapper.is-fullscreen .map-info-panel__sources {
    padding: 0;
    margin: 0;
    border: none;
    flex: 1 1 auto;
    min-width: 200px;
  }

  .map-page-wrapper.is-fullscreen .map-info-panel__sources-title {
    font-size: 0.8rem;
    margin-bottom: var(--gap-xs);
  }

  .map-page-wrapper.is-fullscreen .map-info-panel__source-item {
    font-size: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .map-layer-controls--fullscreen {
      transition: none !important;
    }
    .map-layer-controls--fullscreen.map-layer-controls--collapsed {
      transform: none;
      opacity: 1;
    }
  }
</style>
