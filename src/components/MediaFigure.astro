---
// MediaFigure.astro — Renders a media asset (image) with attribution.
// Refactored to use Figure.astro base component.

import Figure from './Figure.astro';
import type { ResolvedMedia } from '../data/media';

export interface Props {
  entry: ResolvedMedia;
  /** CSS class added to the <figure> element */
  class?: string;
  /** Display variant: "inline" (default) or "hero" (full-width) */
  variant?: 'inline' | 'hero';
}

const { entry, variant = 'inline' } = Astro.props;
const isSvg = entry.format === 'svg';
const cssClass = Astro.props.class ?? '';
---

<Figure
  variant={variant}
  class={`media-figure ${cssClass}`.trim()}
  caption={entry.caption}
  credit={entry.credit}
  license={entry.license}
  licenseUrl={entry.licenseUrl}
  sourceId={entry.sourceId}
  dataFigureType="media"
  dataFigureId={entry.id}
  sourceCodeMediaId={entry.sourceCode ? entry.id : undefined}
>
  {isSvg ? (
    <img
      src={entry.src}
      alt={entry.alt}
      class="media-figure__img"
      loading="lazy"
      decoding="async"
    />
  ) : (
    <img
      src={entry.src}
      alt={entry.alt}
      class="media-figure__img"
      width={entry.width}
      height={entry.height}
      loading="lazy"
      decoding="async"
    />
  )}
</Figure>

<style>
  .media-figure__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    background: var(--color-bg-dark);
  }
</style>
