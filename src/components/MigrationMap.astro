---
// MigrationMap.astro — Leaflet map showing Homo sapiens and Neanderthal
// migration routes across Europe and the Mediterranean.
// Uses MapShell for HTML skeleton + shared-map.js for base layer init.
import MapShell from './MapShell.astro';
---

<div class="migration-map-wrapper" data-map-wrapper="migration">
  <MapShell
    id="migration"
    label="Carte interactive des migrations des Homo sapiens et Néandertaliens"
    title="Migrations et territoires"
    hint="Survolez les routes ou les sites pour plus d'informations."
    height={500}
  >
    <div slot="legend-bottom" class="migration-legend-layers">
      <span class="migration-legend-line migration-legend-line--sapiens">—</span>
      <span class="migration-legend-label">Homo sapiens</span>
      <span class="migration-legend-line migration-legend-line--neanderthal">—</span>
      <span class="migration-legend-label">Néandertaliens</span>
      <span class="migration-legend-line migration-legend-line--neronian">—</span>
      <span class="migration-legend-label">Incursion néronienne (Mandrin)</span>
    </div>
  </MapShell>
</div>

<script>
  import L from 'leaflet';
  import { initMap, onViewTransition } from '../scripts/maps/shared-map';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const map = initMap('migration-map', { center: [38, 18], zoom: 4, minZoom: 3, maxZoom: 8 });
    if (!map) return;

    // ── Site data ──
    const sites = [
      {
        id: 'mandrin',
        name: 'Grotte Mandrin',
        lieu: 'Malataverne (Drôme), France',
        age: '~54 000 ans',
        type: 'sapiens',
        desc: 'Plus ancienne trace d\'Homo sapiens en France. Dent de lait et outils néroniens dans la couche E, intercalée entre occupations néandertaliennes.',
        coords: [44.46944, 4.77139],
      },
      {
        id: 'ksar-akil',
        name: 'Ksar Akil',
        lieu: 'Liban',
        age: '~45 000–40 000 ans',
        type: 'sapiens',
        desc: 'Site levantin aux industries lithiques similaires au Néronien de la grotte Mandrin, suggérant une origine proche-orientale pour cette première incursion.',
        coords: [33.9333, 35.6167],
      },
      {
        id: 'bacho-kiro',
        name: 'Bacho Kiro',
        lieu: 'Bulgarie',
        age: '~45 000 ans',
        type: 'sapiens',
        desc: 'L\'un des plus anciens sites sapiens d\'Europe. Outils en pierre et os, traces d\'industrie aurignacienne précoce.',
        coords: [42.9461, 25.4286],
      },
      {
        id: 'geissenklosterle',
        name: 'Geissenklösterle',
        lieu: 'Allemagne (Jura souabe)',
        age: '~43 000–40 000 ans',
        type: 'sapiens',
        desc: 'Site aurignacien majeur. Petites sculptures en ivoire de mammouth, flûtes en os parmi les plus anciens instruments de musique connus.',
        coords: [48.3981, 9.7794],
      },
      {
        id: 'chauvet',
        name: 'Grotte Chauvet',
        lieu: 'Vallon-Pont-d\'Arc (Ardèche), France',
        age: '~32 000 ans',
        type: 'sapiens',
        desc: 'Chef-d\'œuvre de l\'art pariétal aurignacien. Peintures de lions, rhinocéros et chevaux d\'une maîtrise technique remarquable.',
        coords: [44.38750, 4.41417],
      },
      {
        id: 'abri-pataud',
        name: 'Abri Pataud',
        lieu: 'Dordogne, France',
        age: '~35 000–22 000 ans',
        type: 'sapiens',
        desc: 'Site aurignacien et gravettien en Périgord, témoignant d\'une occupation continue d\'Homo sapiens durant le Paléolithique supérieur.',
        coords: [44.9386, 1.0078],
      },
      {
        id: 'omo-kibish',
        name: 'Omo Kibish',
        lieu: 'Éthiopie',
        age: '~200 000 ans',
        type: 'sapiens',
        desc: 'Les plus anciens fossiles connus d\'Homo sapiens anatomiquement moderne (Omo I et Omo II).',
        coords: [5.5833, 35.9500],
      },
      {
        id: 'skhul-qafzeh',
        name: 'Skhoul / Qafzeh',
        lieu: 'Israël',
        age: '~120 000–90 000 ans',
        type: 'sapiens',
        desc: 'Premières incursions d\'Homo sapiens hors d\'Afrique. Sépultures intentionnelles parmi les plus anciennes connues.',
        coords: [32.6833, 35.0167],
      },
      {
        id: 'chapelle-saints',
        name: 'La Chapelle-aux-Saints',
        lieu: 'Corrèze, France',
        age: '~50 000 ans',
        type: 'neanderthal',
        desc: 'Célèbre sépulture néandertalienne ayant servi à reconstituer le premier squelette complet de Néandertalien (1908).',
        coords: [44.9925, 1.7258],
      },
      {
        id: 'krapina',
        name: 'Krapina',
        lieu: 'Croatie',
        age: '~130 000–120 000 ans',
        type: 'neanderthal',
        desc: 'Important site néandertalien où furent découverts près de 900 ossements appartenant à plusieurs dizaines d\'individus.',
        coords: [46.1583, 15.8750],
      },
      {
        id: 'gibraltar',
        name: 'Gibraltar (Gorham\'s Cave)',
        lieu: 'Gibraltar',
        age: '~32 000–28 000 ans',
        type: 'neanderthal',
        desc: 'L\'un des derniers refuges néandertaliens. Les plus récentes traces de vie néandertalienne jamais découvertes.',
        coords: [36.1167, -5.3500],
      },
      {
        id: 'vindija',
        name: 'Vindija',
        lieu: 'Croatie',
        age: '~44 000–32 000 ans',
        type: 'neanderthal',
        desc: 'Site ayant livré de l\'ADN néandertalien, utilisé pour le séquençage du génome de Néandertal. Possibles contacts avec sapiens.',
        coords: [46.3000, 16.0833],
      },
    ];

    // ── Migration route data ──
    const routes = [
      {
        id: 'sapiens-main',
        type: 'sapiens',
        label: 'Route principale des Homo sapiens',
        coords: [
          [5.5833, 35.9500],  // Omo Kibish
          [12.0000, 37.0000],  // Lake Tana
          [15.5000, 33.0000],  // Eastern Sudan/Red Sea
          [20.0000, 35.0000],  // Along Red Sea
          [24.0000, 36.0000],  // NW Arabia
          [29.5000, 34.5000],  // Sinai
          [32.6833, 35.0167],  // Skhul/Qafzeh (Levant)
          [34.5000, 33.5000],  // Cyprus direction?
          [36.0000, 34.0000],  // Amuq Valley
          [37.0000, 33.0000],  // Anatolia coast
          [38.5000, 31.0000],  // Central Anatolia
          [40.0000, 28.0000],  // Bosphorus/Marmara
          [42.0000, 26.0000],  // Balkans
          [42.9461, 25.4286],  // Bacho Kiro
          [44.0000, 22.0000],  // Danube corridor
          [45.5000, 18.0000],  // Pannonian basin
          [46.0000, 14.0000],  // Alps direction
          [48.3981, 9.7794],   // Geissenklösterle
          [46.5000, 6.0000],   // Jura
          [44.9386, 1.0078],   // Abri Pataud
          [44.46944, 4.77139], // Mandrin
          [44.38750, 4.41417], // Chauvet
        ],
      },
      {
        id: 'neronian-incursion',
        type: 'neronian',
        label: 'Incursion néronienne (54 000 BP)',
        coords: [
          [33.9333, 35.6167],  // Ksar Akil
          [34.5000, 34.0000],  // Amuq
          [36.0000, 33.0000],  // Mediterranean coast
          [37.5000, 28.5000],  // Aegean coast
          [38.5000, 23.0000],  // Greece
          [40.0000, 18.0000],  // Italy heel
          [42.0000, 14.0000],  // Italy coast
          [43.0000, 10.0000],  // Tyrrhenian
          [43.5000, 6.5000],   // Provence coast
          [44.46944, 4.77139], // Mandrin Cave
        ],
      },
    ];

    // ── Route styles ──
    const routeStyles = {
      sapiens: { color: '#d4a843', weight: 3, opacity: 0.8, dashArray: '10, 6' },
      neronian: { color: '#e07b39', weight: 3, opacity: 0.8, dashArray: '6, 4' },
    };

    // ── Marker icons ──
    function createSiteIcon(type) {
      const colors = { sapiens: '#d4a843', neanderthal: '#4a90d9' };
      const color = colors[type] || '#94a3b8';
      return L.divIcon({
        className: 'migration-marker',
        html: `<span class="migration-marker__icon" style="color:${color}">&#9679;</span>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
      });
    }

    // ── Legend updater ──
    const legendContent = document.getElementById('migration-legend-content');

    function updateLegend(html) {
      if (!legendContent) return;
      legendContent.innerHTML = html;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="map-shell__legend-placeholder">Survolez un élément sur la carte.</p>';
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ── Add polylines (migration routes) ──
    routes.forEach((route) => {
      const style = routeStyles[route.type] || routeStyles.sapiens;
      const polyline = L.polyline(route.coords, style).addTo(map);

      polyline.on('mouseover', () => {
        updateLegend(`
          <p class="map-shell__legend-site"><strong>${escapeHtml(route.label)}</strong></p>
        `);
      });

      polyline.on('mouseout', () => {
        clearLegend();
      });
    });

    // ── Add site markers ──
    sites.forEach((site) => {
      const icon = createSiteIcon(site.type);
      const marker = L.marker(site.coords, { icon }).addTo(map);

      // Build Tippy tooltip content
      const typeLabel = site.type === 'sapiens' ? 'Homo sapiens' : 'Néandertalien';
      const tipHtml = `
        <div class="migration-tooltip">
          <strong>${escapeHtml(site.name)}</strong>
          <br><em class="migration-tooltip__lieu">${escapeHtml(site.lieu)}</em>
          <br>Âge : <strong>${escapeHtml(site.age)}</strong>
          <br>Type : ${typeLabel}
          <br><span class="migration-tooltip__desc">${escapeHtml(site.desc)}</span>
        </div>
      `;

      marker.on('add', () => {
        const el = marker.getElement();
        if (el) {
          tippy(el, {
            content: tipHtml,
            allowHTML: true,
            placement: 'top',
            animation: 'shift-away',
            theme: 'dark',
            maxWidth: 320,
            delay: [150, 0],
            interactive: false,
          });
        }
      });

      marker.bindPopup(`
        <div class="migration-popup">
          <strong>${escapeHtml(site.name)}</strong><br>
          <em>${escapeHtml(site.lieu)}</em><br>
          Âge : ${escapeHtml(site.age)}<br>
          ${escapeHtml(site.desc)}
        </div>
      `);

      marker.on('mouseover', () => {
        const typeLabel = site.type === 'sapiens' ? 'Homo sapiens' : 'Néandertalien';
        updateLegend(`
          <p class="map-shell__legend-site"><strong>${escapeHtml(site.name)}</strong> <span class="migration-legend-type">${typeLabel}</span></p>
          <p class="map-shell__legend-lieu">${escapeHtml(site.lieu)}</p>
          <p class="map-shell__legend-age">Âge : ${escapeHtml(site.age)}</p>
          <p class="map-shell__legend-desc">${escapeHtml(site.desc)}</p>
        `);
      });

      marker.on('mouseout', () => {
        clearLegend();
      });
    });

    // ── Fit bounds to show all sites and routes ──
    const allCoords = [
      ...sites.map((s) => s.coords),
      ...routes.flatMap((r) => r.coords),
    ];
    const bounds = L.latLngBounds(allCoords);
    map.fitBounds(bounds, { padding: [50, 50], maxZoom: 5 });

    // ── Relocate the map to its slot in the article body ──
    const slot = document.querySelector('[data-map-slot="migration"]');
    const wrapper = document.querySelector('[data-map-wrapper="migration"]');
    if (slot && wrapper) {
      wrapper.remove();
      slot.replaceWith(wrapper);
    }

    onViewTransition(map);
  })();
</script>

<style>
  /* ── Wrapper for relocation ── */
  .migration-map-wrapper {
    width: 100%;
  }

  /* ── Custom marker ── */
  .migration-marker {
    background: none !important;
    border: none !important;
  }

  .migration-marker__icon {
    display: block;
    width: 20px;
    height: 20px;
    font-size: 24px;
    line-height: 20px;
    text-align: center;
    cursor: pointer;
    transition: transform 0.2s ease;
    text-shadow:
      0 0 4px rgba(0,0,0,0.6),
      0 0 8px rgba(0,0,0,0.4);
  }

  .migration-marker__icon:hover {
    transform: scale(1.4);
  }

  /* ── Legend layers (legend-bottom slot) ── */
  .migration-legend-layers {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.75rem;
    margin-top: var(--gap-sm);
    padding-top: var(--gap-sm);
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .migration-legend-line {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .migration-legend-line--sapiens {
    color: #d4a843;
  }

  .migration-legend-line--neanderthal {
    color: #4a90d9;
  }

  .migration-legend-line--neronian {
    color: #e07b39;
  }

  .migration-legend-label {
    margin-right: 0.25rem;
  }

  .migration-legend-type {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-weight: 400;
  }

  /* ── Tippy overrides ── */
  :global(.tippy-box[data-theme~="dark"]) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-arrow) {
    color: #111827;
    stroke: #1e293b;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-content) {
    padding: 0.5rem 0.65rem;
  }

  .migration-tooltip__lieu {
    color: #94a3b8;
    font-size: 0.85em;
  }

  .migration-tooltip__desc {
    font-size: 0.85em;
    color: #94a3b8;
  }

  /* ── Leaflet popup ── */
  :global(.leaflet-popup-content-wrapper) {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  :global(.leaflet-popup-tip) {
    background: #1e293b;
    border: 1px solid #334155;
  }
</style>
