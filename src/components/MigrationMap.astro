---
// MigrationMap.astro — Leaflet map showing Homo sapiens and Neanderthal
// migration routes across Europe and the Mediterranean.
// Embedded in event pages for arrivee-sapiens.
// Uses Leaflet for basemap + polylines + markers, Tippy.js for hover tooltips.
---

<section class="migration-map-section">
  <div id="migration-map" class="migration-map" role="application" aria-label="Carte interactive des migrations des Homo sapiens et Néandertaliens">
    <noscript>
      <div class="migration-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>
  <div id="migration-legend" class="migration-map__legend">
    <p class="migration-map__legend-title">Migrations et territoires</p>
    <p class="migration-map__legend-hint">Survolez les routes ou les sites pour plus d'informations.</p>
    <div class="migration-map__legend-content" id="migration-legend-content">
      <p class="migration-map__legend-placeholder">Survolez un élément sur la carte.</p>
    </div>
    <div class="migration-map__legend-layers">
      <span class="migration-map__legend-line migration-map__legend-line--sapiens">—</span>
      <span class="migration-map__legend-label">Homo sapiens</span>
      <span class="migration-map__legend-line migration-map__legend-line--neanderthal">—</span>
      <span class="migration-map__legend-label">Néandertaliens</span>
      <span class="migration-map__legend-line migration-map__legend-line--neronian">—</span>
      <span class="migration-map__legend-label">Incursion néronienne (Mandrin)</span>
    </div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const mapEl = document.getElementById('migration-map');
    if (!mapEl) return;

    // ── Site data ──
    const sites = [
      {
        id: 'mandrin',
        name: 'Grotte Mandrin',
        lieu: 'Malataverne (Drôme), France',
        age: '~54 000 ans',
        type: 'sapiens',
        desc: 'Plus ancienne trace d\'Homo sapiens en France. Dent de lait et outils néroniens dans la couche E, intercalée entre occupations néandertaliennes.',
        coords: [44.46944, 4.77139],
      },
      {
        id: 'ksar-akil',
        name: 'Ksar Akil',
        lieu: 'Liban',
        age: '~45 000–40 000 ans',
        type: 'sapiens',
        desc: 'Site levantin aux industries lithiques similaires au Néronien de la grotte Mandrin, suggérant une origine proche-orientale pour cette première incursion.',
        coords: [33.9333, 35.6167],
      },
      {
        id: 'bacho-kiro',
        name: 'Bacho Kiro',
        lieu: 'Bulgarie',
        age: '~45 000 ans',
        type: 'sapiens',
        desc: 'L\'un des plus anciens sites sapiens d\'Europe. Outils en pierre et os, traces d\'industrie aurignacienne précoce.',
        coords: [42.9461, 25.4286],
      },
      {
        id: 'geissenklosterle',
        name: 'Geissenklösterle',
        lieu: 'Allemagne (Jura souabe)',
        age: '~43 000–40 000 ans',
        type: 'sapiens',
        desc: 'Site aurignacien majeur. Petites sculptures en ivoire de mammouth, flûtes en os parmi les plus anciens instruments de musique connus.',
        coords: [48.3981, 9.7794],
      },
      {
        id: 'chauvet',
        name: 'Grotte Chauvet',
        lieu: 'Vallon-Pont-d\'Arc (Ardèche), France',
        age: '~32 000 ans',
        type: 'sapiens',
        desc: 'Chef-d\'œuvre de l\'art pariétal aurignacien. Peintures de lions, rhinocéros et chevaux d\'une maîtrise technique remarquable.',
        coords: [44.38750, 4.41417],
      },
      {
        id: 'abri-pataud',
        name: 'Abri Pataud',
        lieu: 'Dordogne, France',
        age: '~35 000–22 000 ans',
        type: 'sapiens',
        desc: 'Site aurignacien et gravettien en Périgord, témoignant d\'une occupation continue d\'Homo sapiens durant le Paléolithique supérieur.',
        coords: [44.9386, 1.0078],
      },
      {
        id: 'omo-kibish',
        name: 'Omo Kibish',
        lieu: 'Éthiopie',
        age: '~200 000 ans',
        type: 'sapiens',
        desc: 'Les plus anciens fossiles connus d\'Homo sapiens anatomiquement moderne (Omo I et Omo II).',
        coords: [5.5833, 35.9500],
      },
      {
        id: 'skhul-qafzeh',
        name: 'Skhoul / Qafzeh',
        lieu: 'Israël',
        age: '~120 000–90 000 ans',
        type: 'sapiens',
        desc: 'Premières incursions d\'Homo sapiens hors d\'Afrique. Sépultures intentionnelles parmi les plus anciennes connues.',
        coords: [32.6833, 35.0167],
      },
      {
        id: 'chapelle-saints',
        name: 'La Chapelle-aux-Saints',
        lieu: 'Corrèze, France',
        age: '~50 000 ans',
        type: 'neanderthal',
        desc: 'Célèbre sépulture néandertalienne ayant servi à reconstituer le premier squelette complet de Néandertalien (1908).',
        coords: [44.9925, 1.7258],
      },
      {
        id: 'krapina',
        name: 'Krapina',
        lieu: 'Croatie',
        age: '~130 000–120 000 ans',
        type: 'neanderthal',
        desc: 'Important site néandertalien où furent découverts près de 900 ossements appartenant à plusieurs dizaines d\'individus.',
        coords: [46.1583, 15.8750],
      },
      {
        id: 'gibraltar',
        name: 'Gibraltar (Gorham\'s Cave)',
        lieu: 'Gibraltar',
        age: '~32 000–28 000 ans',
        type: 'neanderthal',
        desc: 'L\'un des derniers refuges néandertaliens. Les plus récentes traces de vie néandertalienne jamais découvertes.',
        coords: [36.1167, -5.3500],
      },
      {
        id: 'vindija',
        name: 'Vindija',
        lieu: 'Croatie',
        age: '~44 000–32 000 ans',
        type: 'neanderthal',
        desc: 'Site ayant livré de l\'ADN néandertalien, utilisé pour le séquençage du génome de Néandertal. Possibles contacts avec sapiens.',
        coords: [46.3000, 16.0833],
      },
    ];

    // ── Migration route data ──
    const routes = [
      {
        id: 'sapiens-main',
        type: 'sapiens',
        label: 'Route principale des Homo sapiens',
        coords: [
          [5.5833, 35.9500],  // Omo Kibish
          [12.0000, 37.0000],  // Lake Tana
          [15.5000, 33.0000],  // Eastern Sudan/Red Sea
          [20.0000, 35.0000],  // Along Red Sea
          [24.0000, 36.0000],  // NW Arabia
          [29.5000, 34.5000],  // Sinai
          [32.6833, 35.0167],  // Skhul/Qafzeh (Levant)
          [34.5000, 33.5000],  // Cyprus direction?
          [36.0000, 34.0000],  // Amuq Valley
          [37.0000, 33.0000],  // Anatolia coast
          [38.5000, 31.0000],  // Central Anatolia
          [40.0000, 28.0000],  // Bosphorus/Marmara
          [42.0000, 26.0000],  // Balkans
          [42.9461, 25.4286],  // Bacho Kiro
          [44.0000, 22.0000],  // Danube corridor
          [45.5000, 18.0000],  // Pannonian basin
          [46.0000, 14.0000],  // Alps direction
          [48.3981, 9.7794],   // Geissenklösterle
          [46.5000, 6.0000],   // Jura
          [44.9386, 1.0078],   // Abri Pataud
          [44.46944, 4.77139], // Mandrin
          [44.38750, 4.41417], // Chauvet
        ],
      },
      {
        id: 'neronian-incursion',
        type: 'neronian',
        label: 'Incursion néronienne (54 000 BP)',
        coords: [
          [33.9333, 35.6167],  // Ksar Akil
          [34.5000, 34.0000],  // Amuq
          [36.0000, 33.0000],  // Mediterranean coast
          [37.5000, 28.5000],  // Aegean coast
          [38.5000, 23.0000],  // Greece
          [40.0000, 18.0000],  // Italy heel
          [42.0000, 14.0000],  // Italy coast
          [43.0000, 10.0000],  // Tyrrhenian
          [43.5000, 6.5000],   // Provence coast
          [44.46944, 4.77139], // Mandrin Cave
        ],
      },
    ];

    // ── Map init ──
    const map = L.map(mapEl, {
      center: [38.0, 18.0],
      zoom: 4,
      minZoom: 3,
      maxZoom: 8,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── Route styles ──
    const routeStyles = {
      sapiens: {
        color: '#d4a843',
        weight: 3,
        opacity: 0.8,
        dashArray: '10, 6',
      },
      neronian: {
        color: '#e07b39',
        weight: 3,
        opacity: 0.8,
        dashArray: '6, 4',
      },
    };

    // ── Marker icons ──
    function createSiteIcon(type) {
      const colors = { sapiens: '#d4a843', neanderthal: '#4a90d9' };
      const color = colors[type] || '#94a3b8';
      return L.divIcon({
        className: 'migration-marker',
        html: `<span class="migration-marker__icon" style="color:${color}">&#9679;</span>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
      });
    }

    // ── Legend updater ──
    const legendContent = document.getElementById('migration-legend-content');

    function updateLegend(html) {
      if (!legendContent) return;
      legendContent.innerHTML = html;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="migration-map__legend-placeholder">Survolez un élément sur la carte.</p>';
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ── Add polylines (migration routes) ──
    const polylines = [];
    routes.forEach((route) => {
      const style = routeStyles[route.type] || routeStyles.sapiens;
      const polyline = L.polyline(route.coords, style).addTo(map);
      polylines.push(polyline);

      // Tippy tooltip on hover for polyline
      const tipContent = `
        <div class="migration-tooltip">
          <strong>${escapeHtml(route.label)}</strong>
        </div>
      `;

      polyline.on('mouseover', (e) => {
        const el = e.target.getElement ? e.target.getElement() : null;
        if (el) {
          el.style.cursor = 'pointer';
        }
        updateLegend(`
          <p class="migration-map__legend-route"><strong>${escapeHtml(route.label)}</strong></p>
        `);
      });

      polyline.on('mouseout', () => {
        clearLegend();
      });
    });

    // ── Add site markers ──
    const markers = [];
    sites.forEach((site) => {
      const icon = createSiteIcon(site.type);
      const marker = L.marker(site.coords, { icon }).addTo(map);
      markers.push(marker);

      // Build Tippy tooltip content
      const typeLabel = site.type === 'sapiens' ? 'Homo sapiens' : 'Néandertalien';
      const tipHtml = `
        <div class="migration-tooltip">
          <strong>${escapeHtml(site.name)}</strong>
          <br><em class="migration-tooltip__lieu">${escapeHtml(site.lieu)}</em>
          <br>Âge : <strong>${escapeHtml(site.age)}</strong>
          <br>Type : ${typeLabel}
          <br><span class="migration-tooltip__desc">${escapeHtml(site.desc)}</span>
        </div>
      `;

      // Use Tippy for hover tooltip (on the marker element)
      marker.on('add', () => {
        const el = marker.getElement();
        if (el) {
          tippy(el, {
            content: tipHtml,
            allowHTML: true,
            placement: 'top',
            animation: 'shift-away',
            theme: 'dark',
            maxWidth: 320,
            delay: [150, 0],
            interactive: false,
          });
        }
      });

      // Click → highlight in legend
      marker.on('click', () => {
        marker.openPopup();
      });

      // Popup on click (brief info)
      marker.bindPopup(`
        <div class="migration-popup">
          <strong>${escapeHtml(site.name)}</strong><br>
          <em>${escapeHtml(site.lieu)}</em><br>
          Âge : ${escapeHtml(site.age)}<br>
          ${escapeHtml(site.desc)}
        </div>
      `);

      // Hover → update legend
      marker.on('mouseover', () => {
        const typeLabel = site.type === 'sapiens' ? 'Homo sapiens' : 'Néandertalien';
        updateLegend(`
          <p class="migration-map__legend-site"><strong>${escapeHtml(site.name)}</strong> <span class="migration-map__legend-type">${typeLabel}</span></p>
          <p class="migration-map__legend-lieu">${escapeHtml(site.lieu)}</p>
          <p class="migration-map__legend-age">Âge : ${escapeHtml(site.age)}</p>
          <p class="migration-map__legend-desc">${escapeHtml(site.desc)}</p>
        `);
      });

      marker.on('mouseout', () => {
        clearLegend();
      });
    });

    // ── Fit bounds to show all sites and routes ──
    const allCoords = [
      ...sites.map((s) => s.coords),
      ...routes.flatMap((r) => r.coords),
    ];
    const bounds = L.latLngBounds(allCoords);
    map.fitBounds(bounds, { padding: [50, 50], maxZoom: 5 });

    // ── Handle Astro View Transitions ──
    document.addEventListener('astro:after-swap', () => {
      setTimeout(() => map.invalidateSize(), 200);
    });
  })();
</script>

<style>
  .migration-map-section {
    width: 100%;
    max-width: 720px;
    margin: var(--gap-lg) auto;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .migration-map {
    width: 100%;
    height: 500px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: #1e293b;
  }

  .migration-map__noscript {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: var(--gap-lg);
    text-align: center;
  }

  /* ── Legend panel ── */
  .migration-map__legend {
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .migration-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .migration-map__legend-hint {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-style: italic;
    margin-bottom: var(--gap-sm);
  }

  .migration-map__legend-content {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    min-height: 3em;
  }

  .migration-map__legend-placeholder {
    font-style: italic;
  }

  .migration-map__legend-site {
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .migration-map__legend-type {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-weight: 400;
  }

  .migration-map__legend-lieu {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--gap-xs);
  }

  .migration-map__legend-age {
    font-weight: 600;
    color: var(--color-accent-gold, #d4a843);
    margin-bottom: var(--gap-xs);
  }

  .migration-map__legend-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .migration-map__legend-route {
    font-weight: 600;
    color: var(--color-text-light);
  }

  .migration-map__legend-layers {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.75rem;
    margin-top: var(--gap-sm);
    padding-top: var(--gap-sm);
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .migration-map__legend-line {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .migration-map__legend-line--sapiens {
    color: #d4a843;
  }

  .migration-map__legend-line--neanderthal {
    color: #4a90d9;
  }

  .migration-map__legend-line--neronian {
    color: #e07b39;
  }

  .migration-map__legend-label {
    margin-right: 0.25rem;
  }

  /* ── Custom marker ── */
  .migration-marker {
    background: none !important;
    border: none !important;
  }

  .migration-marker__icon {
    display: block;
    width: 20px;
    height: 20px;
    font-size: 24px;
    line-height: 20px;
    text-align: center;
    cursor: pointer;
    transition: transform 0.2s ease;
    text-shadow:
      0 0 4px rgba(0,0,0,0.6),
      0 0 8px rgba(0,0,0,0.4);
  }

  .migration-marker__icon:hover {
    transform: scale(1.4);
  }

  /* ── Leaflet overrides ── */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #1e293b;
  }

  :global(.leaflet-control-zoom a) {
    background: #1e293b !important;
    color: #e2e8f0 !important;
    border-color: #334155 !important;
  }

  :global(.leaflet-control-zoom a:hover) {
    background: #334155 !important;
  }

  :global(.leaflet-control-attribution) {
    background: rgba(11, 17, 32, 0.85) !important;
    color: #94a3b8 !important;
    font-size: 10px !important;
  }

  :global(.leaflet-control-attribution a) {
    color: #94a3b8 !important;
  }

  /* ── Popup ── */
  :global(.leaflet-popup-content-wrapper) {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  :global(.leaflet-popup-tip) {
    background: #1e293b;
    border: 1px solid #334155;
  }

  /* ── Tippy overrides ── */
  :global(.tippy-box[data-theme~="dark"]) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-arrow) {
    color: #111827;
    stroke: #1e293b;
  }

  :global(.tippy-box[data-theme~="dark"] .tippy-content) {
    padding: 0.5rem 0.65rem;
  }

  .migration-tooltip__lieu {
    color: #94a3b8;
    font-size: 0.85em;
  }

  .migration-tooltip__desc {
    font-size: 0.85em;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .migration-map {
      height: 350px;
    }
  }

  @media (max-width: 400px) {
    .migration-map {
      height: 280px;
    }
  }
</style>
