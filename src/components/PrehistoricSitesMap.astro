---
import MapShell from './MapShell.astro';
// PrehistoricSitesMap.astro — Leaflet map of the 5 oldest prehistoric sites in France (>1 Ma)
// Uses MapShell for HTML skeleton + CSS, and shared-map.js for base layer init.
---

<MapShell
  id="prehistoric"
  label="Carte des cinq plus anciens sites préhistoriques de France"
  title="Sites préhistoriques &gt; 1 Ma"
  hint="Cliquez sur un marqueur pour plus d'informations."
/>

<script>
  import { initMap, onViewTransition } from '../scripts/maps/shared-map';

  (() => {
    const map = initMap('prehistoric-map', { center: [46, 2.5], zoom: 6 });
    if (!map) return;

    const sites = [
      { id: 'bois-de-riquet',     name: 'Le Bois-de-Riquet',       lieu: 'Lézignan-la-Cèbe (Hérault)',              age: '1,2 Ma', desc: 'Plus ancien site de France. Découvert en 2008. On y a trouvé de simples galets taillés, parmi les plus vieux outils connus en Europe.',                                      coords: [43.4937, 3.4264] },
      { id: 'vallonnet',          name: 'Grotte du Vallonnet',      lieu: 'Roquebrune-Cap-Martin (Alpes-Maritimes)', age: '1,15 Ma',desc: 'Découverte en 1958. Outils de pierre taillée et ossements de grands carnivores (tigre à dents de sabre, hyène). À l\'époque, la grotte surplombait une mer tropicale.',                      coords: [43.7643, 7.4698] },
      { id: 'terre-des-sablons',  name: 'Terre-des-Sablons',       lieu: 'Lunery-Rosières (Cher)',                  age: '1,15 Ma',desc: 'Site de plein air dans le Berry. Pierre taillée et ossements d\'animaux disparus (mammouth, rhinocéros).',                                                       coords: [46.93, 2.27] },
      { id: 'pont-de-lavaud',     name: 'Pont-de-Lavaud',          lieu: 'Éguzon-Chantôme (Indre)',                 age: '1,05 Ma',desc: 'Site dans la vallée de la Creuse. Galets aménagés et ossements animaux témoignant d\'une présence humaine très ancienne dans le centre de la France.',                                                                          coords: [46.44, 1.58] },
      { id: 'pont-de-la-hulauderie', name: 'Pont-de-la-Hulauderie',lieu: 'Saint-Hilaire-la-Gravelle (Loir-et-Cher)', age: '1 Ma',   desc: 'Le plus septentrional des sites français d\'un million d\'années. Outils de pierre taillée, dans la vallée du Loir.',                                                                      coords: [47.92, 1.21] },
    ];

    // Gold marker
    const siteIcon = L.divIcon({
      className: 'map-shell-marker',
      html: '<span class="map-shell-marker__icon">●</span>',
      iconSize: [24, 24],
      iconAnchor: [12, 12],
      popupAnchor: [0, -16],
    });

    const legendContent = document.getElementById('prehistoric-legend-content');

    function escapeHtml(str) {
      const d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    function updateLegend(site) {
      if (!legendContent) return;
      legendContent.innerHTML = `
        <p class="map-shell__legend-site"><strong>${escapeHtml(site.name)}</strong></p>
        <p class="map-shell__legend-lieu">${escapeHtml(site.lieu)}</p>
        <p class="map-shell__legend-age">Âge : ${escapeHtml(site.age)}</p>
        <p class="map-shell__legend-desc">${escapeHtml(site.desc)}</p>
      `;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="map-shell__legend-placeholder">Survolez un site sur la carte.</p>';
    }

    // Add markers
    sites.forEach((site) => {
      const marker = L.marker(site.coords, { icon: siteIcon }).addTo(map);

      marker.bindPopup(`
        <div><strong>${escapeHtml(site.name)}</strong><br>
        <em>${escapeHtml(site.lieu)}</em><br>
        Âge : ${escapeHtml(site.age)}<br>
        ${escapeHtml(site.desc)}</div>
      `);

      marker.on('mouseover', () => updateLegend(site));
      marker.on('mouseout', () => clearLegend());
    });

    // Fit all sites
    const bounds = L.latLngBounds(sites.map((s) => s.coords));
    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 7 });

    onViewTransition(map);
  })();
</script>
