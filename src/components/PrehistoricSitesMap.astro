---
// PrehistoricSitesMap.astro — Leaflet map of the 5 oldest prehistoric sites in France (>1 Ma)
// Embedded in event pages for premiers-humains-en-France.
// Uses Leaflet for basemap + custom markers, Tippy.js for hover tooltips.
---

<section class="prehistoric-map-section">
  <div id="prehistoric-map" class="prehistoric-map" role="application" aria-label="Carte des cinq plus anciens sites préhistoriques de France">
    <noscript>
      <div class="prehistoric-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>
  <div id="prehistoric-legend" class="prehistoric-map__legend">
    <p class="prehistoric-map__legend-title">Sites préhistoriques &gt; 1 Ma</p>
    <p class="prehistoric-map__legend-hint">Survolez un marqueur pour plus d'informations.</p>
    <div id="prehistoric-legend-content" class="prehistoric-map__legend-content">
      <p class="prehistoric-map__legend-placeholder">Survolez un site sur la carte.</p>
    </div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  (() => {
    const mapEl = document.getElementById('prehistoric-map');
    if (!mapEl) return;

    // ── Site data ──
    const sites = [
      {
        id: 'bois-de-riquet',
        name: 'Le Bois-de-Riquet',
        lieu: 'Lézignan-la-Cèbe (Hérault)',
        age: '1,2 Ma',
        desc: 'Plus ancien site préhistorique de France. Découvert en 2008. Industrie oldowayenne (Mode 1).',
        coords: [43.4937, 3.4264],
      },
      {
        id: 'vallonnet',
        name: 'Grotte du Vallonnet',
        lieu: 'Roquebrune-Cap-Martin (Alpes-Maritimes)',
        age: '1,15 Ma',
        desc: 'Découverte en 1958. Outils oldowayens et ossements de grands carnivores. Mer tropicale à son pied.',
        coords: [43.7643, 7.4698],
      },
      {
        id: 'terre-des-sablons',
        name: 'Terre-des-Sablons',
        lieu: 'Lunery-Rosières (Cher)',
        age: '1,15 Ma',
        desc: 'Site de plein air oldowayen en région Centre-Val de Loire.',
        coords: [46.93, 2.27],
      },
      {
        id: 'pont-de-lavaud',
        name: 'Pont-de-Lavaud',
        lieu: 'Éguzon-Chantôme (Indre)',
        age: '1,05 Ma',
        desc: 'Site oldowayen dans la vallée de la Creuse, attestant d\'une présence humaine précoce dans le centre de la France.',
        coords: [46.44, 1.58],
      },
      {
        id: 'pont-de-la-hulauderie',
        name: 'Pont-de-la-Hulauderie',
        lieu: 'Saint-Hilaire-la-Gravelle (Loir-et-Cher)',
        age: '1 Ma',
        desc: 'Site oldowayen le plus septentrional de France à ce jour.',
        coords: [47.92, 1.21],
      },
    ];

    // ── Map init ──
    const map = L.map(mapEl, {
      center: [46.0, 2.5],
      zoom: 6,
      minZoom: 5,
      maxZoom: 10,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── Custom icon: gold marker ──
    const siteIcon = L.divIcon({
      className: 'prehistoric-marker',
      html: '<span class="prehistoric-marker__icon">&#9679;</span>',
      iconSize: [24, 24],
      iconAnchor: [12, 12],
      popupAnchor: [0, -16],
    });

    // ── Legend updater ──
    const legendContent = document.getElementById('prehistoric-legend-content');

    function updateLegend(site) {
      if (!legendContent) return;
      legendContent.innerHTML = `
        <p class="prehistoric-map__legend-site"><strong>${escapeHtml(site.name)}</strong></p>
        <p class="prehistoric-map__legend-lieu">${escapeHtml(site.lieu)}</p>
        <p class="prehistoric-map__legend-age">Âge : ${escapeHtml(site.age)}</p>
        <p class="prehistoric-map__legend-desc">${escapeHtml(site.desc)}</p>
      `;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="prehistoric-map__legend-placeholder">Survolez un site sur la carte.</p>';
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ── Add markers ──
    sites.forEach((site) => {
      const marker = L.marker(site.coords, { icon: siteIcon }).addTo(map);

      // Popup on click
      marker.bindPopup(`
        <div class="prehistoric-popup">
          <strong>${escapeHtml(site.name)}</strong><br>
          <em>${escapeHtml(site.lieu)}</em><br>
          Âge : ${escapeHtml(site.age)}<br>
          ${escapeHtml(site.desc)}
        </div>
      `);

      // Hover → legend
      marker.on('mouseover', () => updateLegend(site));
      marker.on('mouseout', () => clearLegend());
    });

    // ── Fit bounds to show all sites ──
    const bounds = L.latLngBounds(sites.map((s) => s.coords));
    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 7 });

    // ── Handle Astro View Transitions ──
    document.addEventListener('astro:after-swap', () => {
      setTimeout(() => map.invalidateSize(), 200);
    });
  })();
</script>

<style>
  .prehistoric-map-section {
    width: 100%;
    max-width: 720px;
    margin: var(--gap-lg) auto;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .prehistoric-map {
    width: 100%;
    height: 420px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: #1e293b;
  }

  .prehistoric-map__noscript {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: var(--gap-lg);
    text-align: center;
  }

  /* ── Legend panel ── */
  .prehistoric-map__legend {
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .prehistoric-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .prehistoric-map__legend-hint {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-style: italic;
    margin-bottom: var(--gap-sm);
  }

  .prehistoric-map__legend-content {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    min-height: 3em;
  }

  .prehistoric-map__legend-placeholder {
    font-style: italic;
  }

  .prehistoric-map__legend-site {
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .prehistoric-map__legend-lieu {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--gap-xs);
  }

  .prehistoric-map__legend-age {
    font-weight: 600;
    color: var(--color-accent-gold, #d4a843);
    margin-bottom: var(--gap-xs);
  }

  .prehistoric-map__legend-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Custom marker ── */
  .prehistoric-marker {
    background: none !important;
    border: none !important;
  }

  .prehistoric-marker__icon {
    display: block;
    width: 24px;
    height: 24px;
    font-size: 28px;
    line-height: 24px;
    text-align: center;
    color: #d4a843;
    text-shadow:
      0 0 4px rgba(0,0,0,0.6),
      0 0 8px rgba(0,0,0,0.4);
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .prehistoric-marker__icon:hover {
    transform: scale(1.3);
  }

  /* ── Leaflet overrides ── */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #1e293b;
  }

  :global(.leaflet-control-zoom a) {
    background: #1e293b !important;
    color: #e2e8f0 !important;
    border-color: #334155 !important;
  }

  :global(.leaflet-control-zoom a:hover) {
    background: #334155 !important;
  }

  :global(.leaflet-control-attribution) {
    background: rgba(11, 17, 32, 0.85) !important;
    color: #94a3b8 !important;
    font-size: 10px !important;
  }

  :global(.leaflet-control-attribution a) {
    color: #94a3b8 !important;
  }

  /* ── Popup ── */
  :global(.leaflet-popup-content-wrapper) {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  :global(.leaflet-popup-tip) {
    background: #1e293b;
    border: 1px solid #334155;
  }
</style>
