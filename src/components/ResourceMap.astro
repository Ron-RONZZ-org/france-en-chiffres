---
// ResourceMap.astro — Leaflet map of copper & tin sources in Iron Age Europe
// Embedded in event pages for age-de-fer.
// Uses Leaflet for basemap + custom markers, Tippy.js for hover tooltips.
---

<section class="resource-map-section">
  <div id="resource-map" class="resource-map" role="application" aria-label="Carte des sources de cuivre et d'étain en Europe">
    <noscript>
      <div class="resource-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>
  <div id="resource-legend" class="resource-map__legend">
    <p class="resource-map__legend-title">Sources de métaux &agrave; l'&Acirc;ge du bronze</p>
    <div class="resource-map__legend-items">
      <div class="resource-map__legend-item">
        <span class="resource-map__legend-marker resource-map__legend-marker--copper"></span>
        <span>Cuivre</span>
      </div>
      <div class="resource-map__legend-item">
        <span class="resource-map__legend-marker resource-map__legend-marker--tin"></span>
        <span>&Eacute;tain</span>
      </div>
    </div>
    <p class="resource-map__legend-hint">Survolez un marqueur pour plus d'informations.</p>
    <div id="resource-legend-content" class="resource-map__legend-content">
      <p class="resource-map__legend-placeholder">Survolez un site sur la carte.</p>
    </div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const mapEl = document.getElementById('resource-map');
    if (!mapEl) return;

    // ── Resource data: copper and tin sources in Iron Age Europe ──
    const resources = [
      // ── Copper sources ──
      {
        id: 'carpathes',
        name: 'Carpates',
        region: 'Roumanie, Serbie',
        type: 'copper',
        desc: 'L\'une des principales sources de cuivre de l\'Europe ancienne. Les mines de la zone carpatique alimentaient les réseaux d\'échanges dès l\'âge du Bronze.',
        coords: [46.5, 24.5],
      },
      {
        id: 'alpes-cuivre',
        name: 'Alpes orientales',
        region: 'Autriche, Suisse',
        type: 'copper',
        desc: 'Mines de cuivre du Mitterberg (Salzbourg) — l\'un des plus grands districts miniers préhistoriques d\'Europe, exploité dès le II<sup>e</sup> millénaire AEC.',
        coords: [47.2, 13.0],
      },
      {
        id: 'rio-tinto',
        name: 'Rio Tinto',
        region: 'Andalousie, Espagne',
        type: 'copper',
        desc: 'District minier antique parmi les plus riches d\'Europe. Exploité dès l\'âge du Bronze pour le cuivre, puis pour l\'argent à l\'époque romaine.',
        coords: [37.7, -6.6],
      },
      {
        id: 'cyprus',
        name: 'Chypre',
        region: 'Méditerranée orientale',
        type: 'copper',
        desc: 'L\'île qui a donné son nom au cuivre (aes Cyprium). Source majeure de cuivre dans l\'Antiquité méditerranéenne, exportée dans tout le bassin.',
        coords: [35.0, 33.0],
      },
      {
        id: 'bohême',
        name: 'Bohême',
        region: 'République tchèque',
        type: 'copper',
        desc: 'Mines de cuivre des Monts Métallifères (Erzgebirge) et de la région de Bohême centrale, exploitées dès l\'âge du Bronze ancien.',
        coords: [49.8, 13.5],
      },
      // ── Tin sources ──
      {
        id: 'cornouailles',
        name: 'Cornouailles',
        region: 'Sud-ouest de l\'Angleterre',
        type: 'tin',
        desc: 'La plus importante source d\'étain de l\'Europe ancienne. Le commerce de l\'étain cornique avec la Méditerranée est attesté dès l\'âge du Bronze par les écrits grecs (Strabon, Pline).',
        coords: [50.3, -5.1],
      },
      {
        id: 'bretagne',
        name: 'Bretagne',
        region: 'Nord-ouest de la France',
        type: 'tin',
        desc: 'Gisements d\'étain alluvionnaire dans le Massif armoricain, notamment dans les Côtes-d\'Armor et le Morbihan. Source régionale pour la métallurgie du bronze en Gaule.',
        coords: [48.1, -3.0],
      },
      {
        id: 'galice',
        name: 'Galice',
        region: 'Nord-ouest de l\'Espagne',
        type: 'tin',
        desc: 'Province stannifère du nord-ouest ibérique. Avec la Cornouailles et la Bretagne, l\'une des trois grandes sources d\'étain atlantiques de l\'Europe ancienne.',
        coords: [42.5, -7.5],
      },
      {
        id: 'erzgebirge',
        name: 'Monts Métallifères (Erzgebirge)',
        region: 'Saxe / Bohême',
        type: 'tin',
        desc: 'Chaîne de montagnes à la frontière germano-tchèque, riche en étain et autres métaux. Exploitée dès l\'âge du Bronze, elle devint une source majeure à l\'époque moderne.',
        coords: [50.4, 12.8],
      },
      {
        id: 'sardaigne',
        name: 'Sardaigne',
        region: 'Italie',
        type: 'tin',
        desc: 'L\'île possède des gisements d\'étain et de cuivre. La civilisation nuragique exploitait ces ressources pour la métallurgie du bronze.',
        coords: [40.0, 9.0],
      },
      // ── Iron ore regions (context) ──
      {
        id: 'lorraine-fer',
        name: 'Bassin ferrifère lorrain',
        region: 'Lorraine, France',
        type: 'iron',
        desc: 'Immense gisement de minerai de fer (minette) qui affleure dans l\'est de la France. Exploité dès l\'Antiquité, il devint au XIX<sup>e</sup> siècle l\'un des plus grands bassins miniers d\'Europe.',
        coords: [49.3, 6.0],
      },
      {
        id: 'bourgogne-fer',
        name: 'Massif central et Bourgogne',
        region: 'France',
        type: 'iron',
        desc: 'Nombreux gisements de minerai de fer superficiels dans le Massif central, la Bourgogne et le Berry. Le minerai de fer — abondant et proche de la surface — était accessible à chaque communauté gauloise.',
        coords: [46.5, 3.0],
      },
    ];

    // Marker icon factory — resource-type-aware divIcon
    function makeIcon(type) {
      const colors = {
        copper: '#cd7f32',
        tin: '#94a3b8',
        iron: '#8b4513',
      };
      const color = colors[type] || '#d4a843';
      return L.divIcon({
        className: 'resource-marker',
        html: `<span class="resource-marker__icon" style="color:${color}">&#9679;</span>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
        popupAnchor: [0, -14],
      });
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ── Map init ──
    const map = L.map(mapEl, {
      center: [46.0, 6.0],
      zoom: 5,
      minZoom: 3,
      maxZoom: 8,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── Legend panel ──
    const legendContent = document.getElementById('resource-legend-content');

    function updateLegend(resource) {
      if (!legendContent) return;
      legendContent.innerHTML = `
        <p class="resource-map__legend-site"><strong>${escapeHtml(resource.name)}</strong></p>
        <p class="resource-map__legend-region">${escapeHtml(resource.region)}</p>
        <p class="resource-map__legend-type">Ressource : ${escapeHtml(resource.type)}</p>
        <p class="resource-map__legend-desc">${resource.desc}</p>
      `;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="resource-map__legend-placeholder">Survolez un site sur la carte.</p>';
    }

    // ── Add markers with Tippy tooltips ──
    resources.forEach((r) => {
      const marker = L.marker(r.coords, { icon: makeIcon(r.type) }).addTo(map);

      // Tippy tooltip on hover
      const markerEl = marker.getElement();
      if (markerEl) {
        markerEl.setAttribute('data-resource-id', r.id);
        tippy(markerEl, {
          content: `<strong>${escapeHtml(r.name)}</strong><br><em>${escapeHtml(r.region)}</em><br>Type : ${escapeHtml(r.type)}<br>${r.desc}`,
          allowHTML: true,
          placement: 'top',
          animation: 'shift-away',
          theme: 'dark',
          maxWidth: 300,
          delay: [100, 0],
        });
      }

      // Click → center map on marker
      marker.on('click', () => {
        map.setView(r.coords, 6, { animate: true });
      });

      // Hover → legend
      marker.on('mouseover', () => updateLegend(r));
      marker.on('mouseout', () => clearLegend());
    });

    // ── Fit bounds to show all markers ──
    const bounds = L.latLngBounds(resources.map((r) => r.coords));
    map.fitBounds(bounds, { padding: [50, 50], maxZoom: 5 });

    // ── Handle Astro View Transitions ──
    document.addEventListener('astro:after-swap', () => {
      setTimeout(() => map.invalidateSize(), 200);
    });
  })();
</script>

<style>
  .resource-map-section {
    width: 100%;
    max-width: 720px;
    margin: var(--gap-lg) auto;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .resource-map {
    width: 100%;
    height: 480px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: #1e293b;
  }

  .resource-map__noscript {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: var(--gap-lg);
    text-align: center;
  }

  /* ── Legend panel ── */
  .resource-map__legend {
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .resource-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .resource-map__legend-items {
    display: flex;
    gap: var(--gap-md);
    margin-bottom: var(--gap-xs);
  }

  .resource-map__legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .resource-map__legend-marker {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .resource-map__legend-marker--copper {
    background: #cd7f32;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .resource-map__legend-marker--tin {
    background: #94a3b8;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .resource-map__legend-hint {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-style: italic;
    margin-bottom: var(--gap-sm);
  }

  .resource-map__legend-content {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    min-height: 3em;
  }

  .resource-map__legend-placeholder {
    font-style: italic;
  }

  .resource-map__legend-site {
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .resource-map__legend-region {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--gap-xs);
  }

  .resource-map__legend-type {
    font-weight: 600;
    color: #d4a843;
    margin-bottom: var(--gap-xs);
    text-transform: capitalize;
  }

  .resource-map__legend-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Custom marker ── */
  .resource-marker {
    background: none !important;
    border: none !important;
  }

  .resource-marker__icon {
    display: block;
    width: 20px;
    height: 20px;
    font-size: 26px;
    line-height: 20px;
    text-align: center;
    text-shadow:
      0 0 4px rgba(0,0,0,0.6),
      0 0 8px rgba(0,0,0,0.4);
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .resource-marker__icon:hover {
    transform: scale(1.4);
  }

  /* ── Leaflet overrides ── */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #1e293b;
  }

  :global(.leaflet-control-zoom a) {
    background: #1e293b !important;
    color: #e2e8f0 !important;
    border-color: #334155 !important;
  }

  :global(.leaflet-control-zoom a:hover) {
    background: #334155 !important;
  }

  :global(.leaflet-control-attribution) {
    background: rgba(11, 17, 32, 0.85) !important;
    color: #94a3b8 !important;
    font-size: 10px !important;
  }

  :global(.leaflet-control-attribution a) {
    color: #94a3b8 !important;
  }

  /* ── Tippy overrides ── */
  :global(.tippy-box[data-theme~='dark']) {
    background: #1e293b;
    border: 1px solid #334155;
    color: #e2e8f0;
    font-size: 0.8rem;
    line-height: 1.4;
    border-radius: 8px;
  }

  :global(.tippy-box[data-theme~='dark'] .tippy-arrow) {
    color: #1e293b;
  }

  /* ── Leaflet popup ── */
  :global(.leaflet-popup-content-wrapper) {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  :global(.leaflet-popup-tip) {
    background: #1e293b;
    border: 1px solid #334155;
  }
</style>
