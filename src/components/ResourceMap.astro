---
// ResourceMap.astro — Leaflet map of copper & tin sources in Iron Age Europe
// Uses MapShell for HTML skeleton + shared-map.js for base layer init.
import MapShell from './MapShell.astro';
---

<MapShell
  id="resource"
  label="Carte des sources de cuivre et d'étain en Europe"
  title="Sources de métaux à l'Âge du bronze"
  hint="Survolez un marqueur pour plus d'informations."
  height={480}
>
  <div slot="legend-bottom" class="resource-legend-items">
    <div class="resource-legend-item">
      <span class="resource-legend-marker resource-legend-marker--copper"></span>
      <span>Cuivre</span>
    </div>
    <div class="resource-legend-item">
      <span class="resource-legend-marker resource-legend-marker--tin"></span>
      <span>Étain</span>
    </div>
  </div>
</MapShell>

<script>
  import L from 'leaflet';
  import { initMap, onViewTransition } from '../scripts/maps/shared-map';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const map = initMap('resource-map', { center: [46, 6], zoom: 5, minZoom: 3, maxZoom: 8 });
    if (!map) return;

    // ── Resource data: copper and tin sources in Iron Age Europe ──
    const resources = [
      // ── Copper sources ──
      {
        id: 'carpathes',
        name: 'Carpates',
        region: 'Roumanie, Serbie',
        type: 'copper',
        desc: 'L\'une des principales sources de cuivre de l\'Europe ancienne. Les mines de la zone carpatique alimentaient les réseaux d\'échanges dès l\'âge du Bronze.',
        coords: [46.5, 24.5],
      },
      {
        id: 'alpes-cuivre',
        name: 'Alpes orientales',
        region: 'Autriche, Suisse',
        type: 'copper',
        desc: 'Mines de cuivre du Mitterberg (Salzbourg) — l\'un des plus grands districts miniers préhistoriques d\'Europe, exploité dès le II<sup>e</sup> millénaire AEC.',
        coords: [47.2, 13.0],
      },
      {
        id: 'rio-tinto',
        name: 'Rio Tinto',
        region: 'Andalousie, Espagne',
        type: 'copper',
        desc: 'District minier antique parmi les plus riches d\'Europe. Exploité dès l\'âge du Bronze pour le cuivre, puis pour l\'argent à l\'époque romaine.',
        coords: [37.7, -6.6],
      },
      {
        id: 'cyprus',
        name: 'Chypre',
        region: 'Méditerranée orientale',
        type: 'copper',
        desc: 'L\'île qui a donné son nom au cuivre (aes Cyprium). Source majeure de cuivre dans l\'Antiquité méditerranéenne, exportée dans tout le bassin.',
        coords: [35.0, 33.0],
      },
      {
        id: 'bohême',
        name: 'Bohême',
        region: 'République tchèque',
        type: 'copper',
        desc: 'Mines de cuivre des Monts Métallifères (Erzgebirge) et de la région de Bohême centrale, exploitées dès l\'âge du Bronze ancien.',
        coords: [49.8, 13.5],
      },
      // ── Tin sources ──
      {
        id: 'cornouailles',
        name: 'Cornouailles',
        region: 'Sud-ouest de l\'Angleterre',
        type: 'tin',
        desc: 'La plus importante source d\'étain de l\'Europe ancienne. Le commerce de l\'étain cornique avec la Méditerranée est attesté dès l\'âge du Bronze par les écrits grecs (Strabon, Pline).',
        coords: [50.3, -5.1],
      },
      {
        id: 'bretagne',
        name: 'Bretagne',
        region: 'Nord-ouest de la France',
        type: 'tin',
        desc: 'Gisements d\'étain alluvionnaire dans le Massif armoricain, notamment dans les Côtes-d\'Armor et le Morbihan. Source régionale pour la métallurgie du bronze en Gaule.',
        coords: [48.1, -3.0],
      },
      {
        id: 'galice',
        name: 'Galice',
        region: 'Nord-ouest de l\'Espagne',
        type: 'tin',
        desc: 'Province stannifère du nord-ouest ibérique. Avec la Cornouailles et la Bretagne, l\'une des trois grandes sources d\'étain atlantiques de l\'Europe ancienne.',
        coords: [42.5, -7.5],
      },
      {
        id: 'erzgebirge',
        name: 'Monts Métallifères (Erzgebirge)',
        region: 'Saxe / Bohême',
        type: 'tin',
        desc: 'Chaîne de montagnes à la frontière germano-tchèque, riche en étain et autres métaux. Exploitée dès l\'âge du Bronze, elle devint une source majeure à l\'époque moderne.',
        coords: [50.4, 12.8],
      },
      {
        id: 'sardaigne',
        name: 'Sardaigne',
        region: 'Italie',
        type: 'tin',
        desc: 'L\'île possède des gisements d\'étain et de cuivre. La civilisation nuragique exploitait ces ressources pour la métallurgie du bronze.',
        coords: [40.0, 9.0],
      },
      // ── Iron ore regions (context) ──
      {
        id: 'lorraine-fer',
        name: 'Bassin ferrifère lorrain',
        region: 'Lorraine, France',
        type: 'iron',
        desc: 'Immense gisement de minerai de fer (minette) qui affleure dans l\'est de la France. Exploité dès l\'Antiquité, il devint au XIX<sup>e</sup> siècle l\'un des plus grands bassins miniers d\'Europe.',
        coords: [49.3, 6.0],
      },
      {
        id: 'bourgogne-fer',
        name: 'Massif central et Bourgogne',
        region: 'France',
        type: 'iron',
        desc: 'Nombreux gisements de minerai de fer superficiels dans le Massif central, la Bourgogne et le Berry. Le minerai de fer — abondant et proche de la surface — était accessible à chaque communauté gauloise.',
        coords: [46.5, 3.0],
      },
    ];

    // Marker icon factory
    function makeIcon(type) {
      const colors = {
        copper: '#cd7f32',
        tin: '#94a3b8',
        iron: '#8b4513',
      };
      const color = colors[type] || '#d4a843';
      return L.divIcon({
        className: 'resource-marker',
        html: `<span class="resource-marker__icon" style="color:${color}">&#9679;</span>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
        popupAnchor: [0, -14],
      });
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ── Legend panel ──
    const legendContent = document.getElementById('resource-legend-content');

    function updateLegend(resource) {
      if (!legendContent) return;
      legendContent.innerHTML = `
        <p class="map-shell__legend-site"><strong>${escapeHtml(resource.name)}</strong></p>
        <p class="map-shell__legend-lieu">${escapeHtml(resource.region)}</p>
        <p class="resource-legend-type">Ressource : ${escapeHtml(resource.type)}</p>
        <p class="map-shell__legend-desc">${resource.desc}</p>
      `;
    }

    function clearLegend() {
      if (!legendContent) return;
      legendContent.innerHTML = '<p class="map-shell__legend-placeholder">Survolez un site sur la carte.</p>';
    }

    // ── Add markers with Tippy tooltips ──
    resources.forEach((r) => {
      const marker = L.marker(r.coords, { icon: makeIcon(r.type) }).addTo(map);

      const markerEl = marker.getElement();
      if (markerEl) {
        markerEl.setAttribute('data-resource-id', r.id);
        tippy(markerEl, {
          content: `<strong>${escapeHtml(r.name)}</strong><br><em>${escapeHtml(r.region)}</em><br>Type : ${escapeHtml(r.type)}<br>${r.desc}`,
          allowHTML: true,
          placement: 'top',
          animation: 'shift-away',
          theme: 'dark',
          maxWidth: 300,
          delay: [100, 0],
        });
      }

      marker.on('click', () => {
        map.setView(r.coords, 6, { animate: true });
      });

      marker.on('mouseover', () => updateLegend(r));
      marker.on('mouseout', () => clearLegend());
    });

    // ── Fit bounds to show all markers ──
    const bounds = L.latLngBounds(resources.map((r) => r.coords));
    map.fitBounds(bounds, { padding: [50, 50], maxZoom: 5 });

    onViewTransition(map);
  })();
</script>

<style>
  /* ── Custom marker ── */
  .resource-marker {
    background: none !important;
    border: none !important;
  }

  .resource-marker__icon {
    display: block;
    width: 20px;
    height: 20px;
    font-size: 26px;
    line-height: 20px;
    text-align: center;
    text-shadow:
      0 0 4px rgba(0,0,0,0.6),
      0 0 8px rgba(0,0,0,0.4);
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .resource-marker__icon:hover {
    transform: scale(1.4);
  }

  /* ── Legend items (legend-bottom slot) ── */
  .resource-legend-items {
    display: flex;
    gap: var(--gap-md);
    margin-top: var(--gap-xs);
  }

  .resource-legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .resource-legend-marker {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .resource-legend-marker--copper {
    background: #cd7f32;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .resource-legend-marker--tin {
    background: #94a3b8;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .resource-legend-type {
    font-weight: 600;
    color: #d4a843;
    margin-bottom: var(--gap-xs);
    text-transform: capitalize;
    font-size: 0.85rem;
  }

  /* ── Tippy overrides ── */
  :global(.tippy-box[data-theme~='dark']) {
    background: #1e293b;
    border: 1px solid #334155;
    color: #e2e8f0;
    font-size: 0.8rem;
    line-height: 1.4;
    border-radius: 8px;
  }

  :global(.tippy-box[data-theme~='dark'] .tippy-arrow) {
    color: #1e293b;
  }

  /* ── Leaflet popup ── */
  :global(.leaflet-popup-content-wrapper) {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 8px;
  }

  :global(.leaflet-popup-tip) {
    background: #1e293b;
    border: 1px solid #334155;
  }
</style>
