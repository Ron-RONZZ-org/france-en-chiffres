---
// RomanCitiesMap.astro — Leaflet map of Roman cities in Gaul with modern equivalents
// The HTML container is injected by the remark-figure-embed plugin via [map:roman-cities]
---

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    const mapEl = document.getElementById('roman-cities-map');
    if (!mapEl) return;

    // ── City data ──
    const cities = [
      { name: 'Lugdunum', modern: 'Lyon', coords: [45.764, 4.835] },
      { name: 'Lutetia', modern: 'Paris', coords: [48.856, 2.352] },
      { name: 'Arelate', modern: 'Arles', coords: [43.677, 4.630] },
      { name: 'Nemausus', modern: 'Nîmes', coords: [43.837, 4.360] },
      { name: 'Arausio', modern: 'Orange', coords: [44.136, 4.808] },
      { name: 'Vienna', modern: 'Vienne', coords: [45.525, 4.874] },
      { name: 'Burdigala', modern: 'Bordeaux', coords: [44.837, -0.579] },
      { name: 'Tolosa', modern: 'Toulouse', coords: [43.604, 1.444] },
      { name: 'Divodurum', modern: 'Metz', coords: [49.119, 6.175] },
      { name: 'Durocortorum', modern: 'Reims', coords: [49.258, 4.032] },
      { name: 'Augustodunum', modern: 'Autun', coords: [46.951, 4.299] },
      { name: 'Narbo Martius', modern: 'Narbonne', coords: [43.183, 3.000] },
      { name: 'Massalia', modern: 'Marseille', coords: [43.296, 5.370] },
    ];

    const getColor = (name) => {
      const colors = [
        '#d4a843', '#22c55e', '#3b82f6', '#a855f7', '#ec4899',
        '#f97316', '#14b8a6', '#ef4444', '#8b5cf6', '#06b6d4',
        '#84cc16', '#e11d48', '#0ea5e9',
      ];
      const idx = cities.findIndex((c) => c.name === name);
      return colors[idx % colors.length];
    };

    // ── Map init ──
    const map = L.map(mapEl, {
      center: [46.0, 2.5],
      zoom: 6,
      minZoom: 5,
      maxZoom: 10,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── City markers ──
    for (const city of cities) {
      const marker = L.circleMarker(city.coords, {
        radius: 7,
        color: '#fff',
        weight: 2,
        fillColor: getColor(city.name),
        fillOpacity: 0.9,
      }).addTo(map);

      marker.bindTooltip(
        `<strong>${city.name}</strong> → ${city.modern}`,
        { sticky: true, className: 'roman-map-tooltip' },
      );

      // Add label near each marker
      const label = L.tooltip({
        permanent: true,
        direction: 'top',
        offset: L.point(0, -10),
        className: 'roman-city-label',
      });
      label.setContent(`<span class="roman-city-label__roman">${city.name}</span>`);
      label.setLatLng(city.coords);
      map.addLayer(label);
    }

    // ── Legend ──
    const legendEl = document.getElementById('roman-cities-legend-content');
    if (legendEl) {
      let html = '';
      for (const city of cities) {
        html += `<div class="roman-cities-legend__item">
          <span class="roman-cities-legend__dot" style="background:${getColor(city.name)}"></span>
          <span class="roman-cities-legend__roman">${city.name}</span>
          <span class="roman-cities-legend__arrow">→</span>
          <span class="roman-cities-legend__modern">${city.modern}</span>
        </div>`;
      }
      legendEl.innerHTML = html;
    }

    // ── Tippy: hover info on legend items ──
    tippy('.roman-cities-legend__item', {
      content: (ref) => {
        const name = ref.querySelector('.roman-cities-legend__roman')?.textContent || '';
        const modern = ref.querySelector('.roman-cities-legend__modern')?.textContent || '';
        return `<strong>${name}</strong> = ${modern} aujourd'hui<br>Ville fondée à l'époque romaine, encore habitée.`;
      },
      allowHTML: true,
      placement: 'top',
      animation: 'shift-away',
      theme: 'dark',
      maxWidth: 280,
      delay: [200, 0],
    });

    setTimeout(() => map.invalidateSize(), 200);
  })();
</script>

<style>
  :global(.roman-map-tooltip) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
    padding: 0.35rem 0.6rem;
    white-space: nowrap;
  }

  :global(.roman-map-tooltip::before) {
    border-top-color: #1e293b;
  }

  :global(.roman-city-label) {
    background: transparent;
    border: none;
    box-shadow: none;
    color: #e2e8f0;
    font-size: 0.65rem;
    font-weight: 400;
    padding: 0;
    white-space: nowrap;
    text-shadow: 0 1px 3px rgba(0,0,0,0.8);
  }

  :global(.roman-city-label::before) {
    display: none;
  }

  :global(.roman-city-label .roman-city-label__roman) {
    background: rgba(17, 24, 39, 0.7);
    padding: 1px 4px;
    border-radius: 2px;
  }

  .roman-cities-legend__item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.15rem 0;
    font-size: 0.82rem;
    color: var(--color-text-muted, #94a3b8);
    cursor: pointer;
  }

  .roman-cities-legend__item:hover {
    color: var(--color-text-light, #e2e8f0);
  }

  .roman-cities-legend__dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .roman-cities-legend__roman {
    font-weight: 600;
    color: var(--color-text-light, #e2e8f0);
  }

  .roman-cities-legend__arrow {
    color: var(--color-accent-gold, #d4a843);
    font-size: 0.7rem;
  }

  .roman-cities-legend__modern {
    color: var(--color-text-muted, #94a3b8);
  }

  :global(.tippy-box[data-theme~="dark"]) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    color: #e2e8f0;
    font-size: 0.8rem;
  }
</style>
