---
import type { TimelineEvent as EventData } from '../data/history.types';
import { getSource, formatSourceLabel, sourceUrl } from '../data/sources';
import { getMedia } from '../data/media';

export interface Props {
  event: EventData;
  index: number;
  total: number;
}

const { event, index, total } = Astro.props;
const side = index % 2 === 0 ? 'left' : 'right';

// Category colors
const categoryColors: Record<string, string> = {
  political: '#3b82f6',
  military: '#ef4444',
  cultural: '#ec4899',
  economic: '#22c55e',
  scientific: '#f97316',
};

const catColor = categoryColors[event.category] || '#94a3b8';

// Resolve source for hyperlinked citation (build-time)
const refSource = event.sourceId ? getSource(event.sourceId) : undefined;
const sourceLabel = refSource
  ? formatSourceLabel(refSource)
  : (event.source ?? '');
const sourceHref = event.sourceId ? sourceUrl(event.sourceId) : null;

// Resolve media thumbnail (build-time)
const refMedia = event.mediaId ? getMedia(event.mediaId) : undefined;
---

<div
  class="timeline-event group"
  data-event-id={event.id}
  data-side={side}
  data-year={event.year}
  id={"event-" + event.id}
  data-preview-year={event.yearDisplay}
  data-preview-title={event.title}
  data-preview-description={event.description}
  data-preview-summary={event.preview.summary}
  data-preview-stat-label={event.preview.statLabel}
  data-preview-stat-value={event.preview.statValue}
  data-preview-source-label={sourceLabel}
  data-preview-source-href={sourceHref ?? ''}
  data-preview-link={event.link || ''}
  data-preview-color={catColor}
  data-preview-media-src={refMedia?.src ?? ''}
  data-preview-media-alt={refMedia?.alt ?? ''}
>
  <!-- Timeline dot on the central line -->
  <div class="timeline-event__dot" style={{ '--dot-color': catColor }}>
    <span class="timeline-event__dot-inner"></span>
  </div>

  <!-- Event card -->
  <article class="timeline-event__card">
    <div class="timeline-event__card-inner">
      <!-- Year -->
      <time class="timeline-event__year" datetime={String(event.year)}>
        {event.yearDisplay}
      </time>

      <!-- Title -->
      <h3 class="timeline-event__title">{event.title}</h3>
    </div>
  </article>
</div>

<style>
  .timeline-event {
    display: flex;
    align-items: flex-start;
    position: relative;
    gap: var(--gap-md);
  }

  /* ===== DOT ===== */
  .timeline-event__dot {
    position: absolute;
    left: 50%;
    top: 24px;
    transform: translateX(-50%);
    z-index: 2;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .timeline-event__dot-inner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--dot-color);
    box-shadow: 0 0 12px var(--dot-color);
    transition: transform var(--transition-fast);
  }

  .group:hover .timeline-event__dot-inner {
    transform: scale(1.4);
  }

  /* ===== CARD ===== */
  .timeline-event__card {
    width: calc(50% - 40px);
    position: relative;
  }

  /* Side alternation */
  [data-side="right"] .timeline-event__card {
    margin-left: calc(50% + 40px);
  }

  [data-side="left"] .timeline-event__card {
    margin-left: 0;
    text-align: right;
  }

  [data-side="left"] .timeline-event__card-inner {
    align-items: flex-end;
  }

  .timeline-event__card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    position: relative;
  }

  .group:hover .timeline-event__card-inner {
    border-color: var(--dot-color);
    background: rgba(17, 24, 39, 0.9);
  }

  .timeline-event__year {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-event__title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-light);
    line-height: 1.3;
  }

  /* ===== MOBILE: single column ===== */
  @media (max-width: 767px) {
    .timeline-event__card {
      width: calc(100% - 60px);
      margin-left: 60px !important;
      text-align: left !important;
    }

    .timeline-event__card-inner {
      align-items: flex-start !important;
    }

    .timeline-event__dot {
      left: 24px;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';

  (() => {
    const events = document.querySelectorAll('.timeline-event');
    if (!events.length) return;

    const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    // Build preview HTML from data attributes
    const buildPreviewHTML = (el) => {
      const color = el.dataset.previewColor || '#3b82f6';
      const link = el.dataset.previewLink || '';
      const year = el.dataset.previewYear || '';
      const title = el.dataset.previewTitle || '';
      const description = el.dataset.previewDescription || '';
      const summary = el.dataset.previewSummary || '';
      const statLabel = el.dataset.previewStatLabel || '';
      const statValue = el.dataset.previewStatValue || '';
      const sourceLabel = el.dataset.previewSourceLabel || '';
      const sourceHref = el.dataset.previewSourceHref || '';
      const mediaSrc = el.dataset.previewMediaSrc || '';
      const mediaAlt = el.dataset.previewMediaAlt || '';

      return `
        <div class="tippy-preview" style="--accent:${color}">
          ${mediaSrc
            ? `<img src="${escapeHTML(mediaSrc)}" alt="${escapeHTML(mediaAlt)}" class="tippy-preview__media" loading="lazy">`
            : ''
          }
          <span class="tippy-preview__year">${escapeHTML(year)}</span>
          <h4 class="tippy-preview__title">${escapeHTML(title)}</h4>
          <div class="tippy-preview__divider" style="background:${color}"></div>
          <p class="tippy-preview__description">${escapeHTML(description)}</p>
          <div class="tippy-preview__divider" style="background:${color}"></div>
          <p class="tippy-preview__summary">${escapeHTML(summary)}</p>
          <div class="tippy-preview__stat">
            <span class="tippy-preview__stat-label">${escapeHTML(statLabel)}</span>
            <span class="tippy-preview__stat-value">${escapeHTML(statValue)}</span>
          </div>
          ${sourceHref
            ? `<a href="${escapeHTML(sourceHref)}" class="tippy-preview__source tippy-preview__source--link" target="_blank" rel="noopener noreferrer">${escapeHTML(sourceLabel)}</a>`
            : `<span class="tippy-preview__source">${escapeHTML(sourceLabel)}</span>`
          }
          ${link ? `<a href="${escapeHTML(link)}" class="tippy-preview__link" target="_blank" rel="noopener noreferrer">Lire plus sur Wikipédia →</a>` : ''}
        </div>
      `;
    };

    const escapeHTML = (str) => {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    };

    events.forEach((el) => {
      tippy(el, {
        content: buildPreviewHTML(el),
        allowHTML: true,
        trigger: isTouch ? 'click' : 'mouseenter',
        interactive: true,
        placement: 'bottom',
        maxWidth: 420,
        theme: 'dark',
        animation: 'shift-away',
        duration: [300, 200],
        hideOnClick: isTouch,
        appendTo: document.body,
        onShow(instance) {
          // Hide all other tippies
          events.forEach((other) => {
            if (other !== el && other._tippy) {
              other._tippy.hide();
            }
          });
        },
      });
    });
  })();
</script>
