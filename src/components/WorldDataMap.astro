---
// WorldDataMap.astro — Leaflet-based world interactive map with thematic layers
// Layers: HDI / HDIAI choropleth, population density
// Tooltips via Tippy.js, click opens country profile
// Uses the same fullscreen/layer-toggle/legend pattern as InteractiveDataMap.astro
---

<section class="world-map-section">
  <div id="world-interactive-map" class="world-map" role="application" aria-label="Carte interactive du monde">
    <noscript>
      <div class="world-map__noscript">
        <p>La carte interactive nécessite JavaScript. Veuillez activer JavaScript pour voir la carte.</p>
      </div>
    </noscript>
  </div>

  <div id="world-map-legend" class="world-map__legend" aria-hidden="true">
    <p class="world-map__legend-title">Légende</p>
    <div id="map-legend-content" class="world-map__legend-content">
      <p class="world-map__legend-placeholder">Sélectionnez une couche pour voir la légende.</p>
    </div>
  </div>

  <div id="map-loading" class="world-map__loading" aria-hidden="true">
    <div class="world-map__loading-spinner"></div>
    <span class="world-map__loading-text">Chargement des données…</span>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';
  import 'tippy.js/animations/shift-away.css';

  (() => {
    // ── Constants ──
    const WORLD_CENTER = [20, 0];
    const DEFAULT_ZOOM = 2;
    const MIN_ZOOM = 2;
    const MAX_ZOOM = 6;

    const COUNTRY_STYLE = {
      color: '#475569',
      weight: 1.0,
      fill: true,
      fillColor: '#1e293b',
      fillOpacity: 0.01,
    };

    const COUNTRY_HIGHLIGHT = {
      color: '#d4a843',
      weight: 2.0,
      fill: true,
      fillColor: '#d4a843',
      fillOpacity: 0.15,
    };

    // ── Initialize map ──
    const mapEl = document.getElementById('world-interactive-map');
    if (!mapEl) return;

    const map = L.map(mapEl, {
      center: WORLD_CENTER,
      zoom: DEFAULT_ZOOM,
      minZoom: MIN_ZOOM,
      maxZoom: MAX_ZOOM,
      zoomControl: true,
      attributionControl: true,
      // worldCopyJump intentionally omitted: when enabled, Leaflet's coordinate
      // system wraps around the antimeridian, causing GeoJSON vector layers
      // (which don't wrap) to render as duplicates at low zoom.  Instead,
      // we constrain the viewport to the world extent so the user can never
      // pan far enough to trigger the wrapping.
      maxBounds: [[-90, -180], [90, 180]],
      maxBoundsViscosity: 1.0,
    });

    // ── Base tile layer (OSM) ──
    const osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    // ── State ──
    let countryLayer = null;
    let worldData = null;
    let hdiLayer = null;
    let densityLayer = null;
    let currentHighlight = null;
    let dataFetched = false;

    // ── Color scales ──
    // HDI quintiles (UNDP: low < 0.550, medium < 0.700, high < 0.800, very high >= 0.800)
    function getHDIColor(value) {
      if (value === null || value === undefined) return '#1e293b';
      if (value >= 0.900) return '#006837';
      if (value >= 0.800) return '#31a354';
      if (value >= 0.700) return '#78c679';
      if (value >= 0.550) return '#addd8e';
      if (value >= 0.400) return '#f7f7c0';
      return '#f03b20';
    }

    // IHDI colors (more inequality = lower score, similar gradient but shifted)
    function getIHDIColor(value) {
      if (value === null || value === undefined) return '#1e293b';
      if (value >= 0.800) return '#006837';
      if (value >= 0.700) return '#31a354';
      if (value >= 0.600) return '#78c679';
      if (value >= 0.450) return '#addd8e';
      if (value >= 0.300) return '#f7f7c0';
      return '#f03b20';
    }

    function getDensityColor(density) {
      if (density === null || density === undefined) return '#1e293b';
      if (density > 1000) return '#081d58';
      if (density > 500) return '#253494';
      if (density > 200) return '#225ea8';
      if (density > 100) return '#1d91c0';
      if (density > 50) return '#41b6c4';
      if (density > 20) return '#78c679';
      if (density > 10) return '#addd8e';
      return '#c2e699';
    }

    function getHDILabel(value) {
      if (value === null || value === undefined) return 'N/A';
      return value.toFixed(3);
    }

    function getIHDILabel(value) {
      if (value === null || value === undefined) return 'N/A';
      return value.toFixed(3);
    }

    function getDensityLabel(value) {
      if (value === null || value === undefined) return 'N/A';
      if (value < 1) return '< 1 hab/km²';
      return value.toLocaleString('fr-FR') + ' hab/km²';
    }

    function getPopLabel(value) {
      if (!value) return 'N/A';
      return value.toLocaleString('fr-FR');
    }

    // ── Helpers ──
    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function formatTooltip(props) {
      const nativeName = props.native_name || props.nativeName || '';
      const frName = props.name_fr || props.name_en || '';
      const pop = props.population;
      const hdi = props.hdi;
      const ihdi = props.ihdi;
      const density = props.density;

      let tip = '<div class="world-tooltip">';
      // Name: native (French)
      if (nativeName && nativeName !== frName) {
        tip += `<strong>${escapeHtml(nativeName)}</strong> <span class="world-tooltip__fr">(${escapeHtml(frName)})</span>`;
      } else {
        tip += `<strong>${escapeHtml(frName)}</strong>`;
      }
      if (pop) {
        tip += `<br>Population\u00a0: <strong>${getPopLabel(pop)}</strong>`;
      }
      if (hdi !== undefined && hdi !== null) {
        tip += `<br>IDH\u00a0: <strong>${getHDILabel(hdi)}</strong>`;
      }
      if (ihdi !== undefined && ihdi !== null) {
        tip += `<br>IDHAI\u00a0: <strong>${getIHDILabel(ihdi)}</strong>`;
      }
      if (density !== undefined && density !== null) {
        tip += `<br>Densité\u00a0: <strong>${getDensityLabel(density)}</strong>`;
      }
      tip += '</div>';
      return tip;
    }

    // ── Legend helpers ──
    function setLegendContent(html) {
      const normalEl = document.getElementById('map-legend-content');
      const infoLegend = document.getElementById('map-info-legend');
      if (normalEl) normalEl.innerHTML = html;
      if (infoLegend) infoLegend.innerHTML = html;
    }

    function clearLegend() {
      setLegendContent(
        '<p class="world-map__legend-placeholder">Sélectionnez une couche pour voir la légende.</p>'
      );
    }

    function setLoading(labelEl, loading) {
      if (labelEl) labelEl.toggleAttribute('data-loading', loading);
    }

    function showMapLoading(visible) {
      const el = document.getElementById('map-loading');
      if (el) el.classList.toggle('world-map__loading--visible', visible);
    }

    // ── Load world data ──
    async function loadWorldData() {
      if (dataFetched && worldData) return;
      showMapLoading(true);
      try {
        const resp = await fetch('/data/geo/world-countries.json');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        worldData = await resp.json();
        dataFetched = true;
        console.log(`✓ World data loaded (${worldData.features.length} countries)`);
        renderCountryLayer();
      } catch (err) {
        console.error('Failed to load world data:', err);
      } finally {
        showMapLoading(false);
      }
    }

    // ── Base country layer ──
    function renderCountryLayer() {
      if (countryLayer) return;

      countryLayer = L.geoJSON(worldData, {
        style: COUNTRY_STYLE,
        onEachFeature: (feature, layer) => {
          const props = feature.properties || {};

          // Each layer stores its own base style so hover highlight can
          // restore the correct colors when a thematic layer is active.
          layer._baseStyle = COUNTRY_STYLE;

          // Bind tooltip
          const tip = formatTooltip(props);
          layer.bindTooltip(tip, {
            sticky: true,
            direction: 'top',
            offset: L.point(0, -8),
            className: 'world-tooltip-leaflet',
          });

          // Highlight on hover — restore _baseStyle, not COUNTRY_STYLE,
          // so choropleth coloring is kept after mouse leaves the feature.
          layer.on('mouseover', () => {
            if (currentHighlight) {
              currentHighlight.setStyle(currentHighlight._baseStyle);
            }
            layer.setStyle(COUNTRY_HIGHLIGHT);
            currentHighlight = layer;
          });

          layer.on('mouseout', () => {
            if (currentHighlight) {
              currentHighlight.setStyle(currentHighlight._baseStyle);
              currentHighlight = null;
            }
          });

          // Click → open country profile
          layer.on('click', () => {
            const iso = (props.iso_a3 || '').toLowerCase();
            if (iso && iso !== '-99') {
              window.open(`/monde/pays/${iso}`, '_blank');
            }
          });
        },
      });

      countryLayer.addTo(map);
    }

    // ── HDI choropleth layer ──
    function applyHDI(active) {
      if (active) {
        if (!countryLayer) return;

        countryLayer.eachLayer((layer) => {
          const props = layer.feature.properties;
          const color = props.ihdi !== undefined ? getIHDIColor(props.ihdi) : (props.hdi !== undefined ? getHDIColor(props.hdi) : '#1e293b');
          const style = {
            fillColor: color,
            fillOpacity: 0.7,
            weight: 1.0,
            color: '#334155',
          };
          layer._baseStyle = style;
          layer.setStyle(style);
        });

        setLegendContent(`
          <p class="world-map__legend-subtitle">Indice de développement humain ajusté aux inégalités (IDHAI)</p>
          <p class="world-map__legend-hint">IDH corrigé des inégalités — source PNUD 2022</p>
          <div class="world-legend">
            ${makeHDILegend()}
          </div>
          <p class="world-map__legend-source"><sup class="citation"><a href="/bibliographie/undp-hdr" data-source-id="undp-hdr" title="Source : PNUD">[1]</a></sup></p>
        `);
      } else {
        // Reset to default
        if (countryLayer) {
          countryLayer.eachLayer((layer) => {
            layer._baseStyle = COUNTRY_STYLE;
            layer.setStyle(COUNTRY_STYLE);
          });
        }
        clearLegend();
      }
    }

    function makeHDILegend() {
      const hdi = [
        { label: '≥ 0,900', color: '#006837' },
        { label: '0,800–0,899', color: '#31a354' },
        { label: '0,700–0,799', color: '#78c679' },
        { label: '0,550–0,699', color: '#addd8e' },
        { label: '0,400–0,549', color: '#f7f7c0' },
        { label: '< 0,400', color: '#f03b20' },
        { label: 'N/A', color: '#1e293b' },
      ];
      return hdi.map(item => `
        <span class="world-legend__item">
          <span class="world-legend__swatch" style="background:${item.color}"></span>
          ${item.label}
        </span>
      `).join('');
    }

    // ── Population density choropleth ──
    function applyDensity(active) {
      if (active) {
        if (!countryLayer) return;

        countryLayer.eachLayer((layer) => {
          const props = layer.feature.properties;
          const density = props.density;
          const style = {
            fillColor: getDensityColor(density),
            fillOpacity: 0.7,
            weight: 1.0,
            color: '#334155',
          };
          layer._baseStyle = style;
          layer.setStyle(style);
        });

        setLegendContent(`
          <p class="world-map__legend-subtitle">Densité de population</p>
          <p class="world-map__legend-hint">Habitants par km² — source Banque mondiale / ONU 2022</p>
          <div class="world-legend">
            ${makeDensityLegend()}
          </div>
          <p class="world-map__legend-source"><sup class="citation"><a href="/bibliographie/world-bank" data-source-id="world-bank" title="Source : Banque mondiale">[2]</a></sup></p>
        `);
      } else {
        // Reset to default
        if (countryLayer) {
          countryLayer.eachLayer((layer) => {
            layer._baseStyle = COUNTRY_STYLE;
            layer.setStyle(COUNTRY_STYLE);
          });
        }
        clearLegend();
      }
    }

    function makeDensityLegend() {
      const items = [
        { label: '≤ 10', color: '#c2e699' },
        { label: '10–20', color: '#addd8e' },
        { label: '20–50', color: '#78c679' },
        { label: '50–100', color: '#41b6c4' },
        { label: '100–200', color: '#1d91c0' },
        { label: '200–500', color: '#225ea8' },
        { label: '500–1 000', color: '#253494' },
        { label: '> 1 000', color: '#081d58' },
      ];
      return items.map(item => `
        <span class="world-legend__item">
          <span class="world-legend__swatch" style="background:${item.color}"></span>
          ${item.label}
        </span>
      `).join('');
    }

    // ── Layer toggles (mutually exclusive: hdi ⇔ density) ──
    let mutexGuard = false;
    function setupToggles() {
      const toggles = document.querySelectorAll('[data-map-toggle]');
      toggles.forEach((toggle) => {
        toggle.addEventListener('change', async (e) => {
          // Guard against re-entrant calls from mutual exclusion
          if (mutexGuard) return;
          mutexGuard = true;

          const layer = e.target.dataset.mapToggle;
          const checked = e.target.checked;

          // Load world data on first toggle
          if (!dataFetched) {
            showMapLoading(true);
            await loadWorldData();
          }

          // Mutually exclusive: uncheck the other layer when this one is activated
          if (checked) {
            const otherId = layer === 'hdi' ? 'toggle-density' : 'toggle-hdi';
            const otherCheck = document.getElementById(otherId);
            if (otherCheck && otherCheck.checked) {
              otherCheck.checked = false;
              // Directly clear the other layer's style without dispatching change
              if (otherId === 'toggle-density') applyDensity(false);
              else applyHDI(false);
            }
          }

          switch (layer) {
            case 'hdi':
              applyHDI(checked);
              break;
            case 'density':
              applyDensity(checked);
              break;
          }

          mutexGuard = false;
        });
      });
    }

    // ── Tippy: layer controls ──
    function setupTippy() {
      const items = document.querySelectorAll('.map-layer-controls__item[data-description]');
      items.forEach((el) => {
        const html = el.getAttribute('data-description');
        if (!html) return;
        tippy(el, {
          content: html,
          allowHTML: true,
          placement: 'top',
          animation: 'shift-away',
          theme: 'dark',
          maxWidth: 320,
          delay: [200, 0],
          interactive: true,
        });
      });
    }

    // ── Fullscreen control ──
    const fullscreenControl = L.control({ position: 'topright' });
    let isFullscreen = false;

    fullscreenControl.onAdd = function () {
      const btn = L.DomUtil.create('button', 'leaflet-control-zoom leaflet-control-fullscreen');
      btn.setAttribute('type', 'button');
      btn.setAttribute('aria-label', 'Plein écran');
      btn.setAttribute('title', 'Plein écran');
      btn.innerHTML = '<span class="fullscreen-icon">⛶</span>';
      btn.style.cssText = `
        font-size: 18px; line-height: 30px; text-align: center;
        cursor: pointer; width: 30px; height: 30px;
        background: #1e293b; border: 1px solid #334155; border-radius: 4px;
      `;

      btn.addEventListener('click', () => {
        const wrapper = document.getElementById('map-page-wrapper');
        if (!wrapper) return;

        if (!document.fullscreenElement) {
          wrapper.requestFullscreen().catch(() => {});
        } else {
          document.exitFullscreen().catch(() => {});
        }
      });

      return btn;
    };

    fullscreenControl.addTo(map);

    // Track fullscreen state
    document.addEventListener('fullscreenchange', () => {
      isFullscreen = !!document.fullscreenElement;
      map.invalidateSize();
      const wrapper = document.getElementById('map-page-wrapper');
      if (wrapper) {
        wrapper.classList.toggle('is-fullscreen', isFullscreen);
      }
      const controls = document.querySelector('.map-layer-controls');
      if (controls) {
        controls.classList.toggle('map-layer-controls--fullscreen', isFullscreen);
        if (!isFullscreen) controls.classList.remove('map-layer-controls--collapsed');
      }
      // Move legend
      const legendContent = document.getElementById('map-legend-content');
      const infoLegend = document.getElementById('map-info-legend');
      if (isFullscreen && legendContent && infoLegend) {
        infoLegend.innerHTML = legendContent.innerHTML;
        legendContent.innerHTML = '';
      } else if (!isFullscreen && infoLegend && legendContent) {
        legendContent.innerHTML = infoLegend.innerHTML;
        infoLegend.innerHTML = '';
      }
      if (isFullscreen) {
        const infoPanel = document.getElementById('map-info-panel');
        if (infoPanel) infoPanel.classList.remove('map-info-panel--collapsed');
      }
      const btn = document.querySelector('.leaflet-control-fullscreen');
      if (btn) {
        btn.innerHTML = isFullscreen
          ? '<span class="fullscreen-icon">✕</span>'
          : '<span class="fullscreen-icon">⛶</span>';
        btn.setAttribute('aria-label', isFullscreen ? 'Quitter le plein écran' : 'Plein écran');
        btn.setAttribute('title', isFullscreen ? 'Quitter le plein écran' : 'Plein écran');
      }
    });

    // ── Collapse toggles ──
    function setupFullscreenCollapse() {
      const collapseBtn = document.querySelector('.map-layer-controls__collapse');
      const controls = document.querySelector('.map-layer-controls');
      if (!collapseBtn || !controls) return;

      collapseBtn.addEventListener('click', () => {
        const isCollapsed = controls.classList.toggle('map-layer-controls--collapsed');
        collapseBtn.setAttribute('aria-label', isCollapsed ? 'Afficher les couches' : 'Masquer les couches');
        collapseBtn.setAttribute('title', isCollapsed ? 'Afficher les couches' : 'Masquer les couches');
        collapseBtn.innerHTML = isCollapsed ? '<span>☰</span>' : '<span>◀</span>';
        map.invalidateSize();
      });
    }

    function setupInfoPanelToggle() {
      const header = document.querySelector('.map-info-panel__header');
      const panel = document.getElementById('map-info-panel');
      if (!header || !panel) return;

      header.addEventListener('click', () => {
        const isCollapsed = panel.classList.toggle('map-info-panel--collapsed');
        const toggleBtn = panel.querySelector('.map-info-panel__toggle');
        if (toggleBtn) {
          toggleBtn.setAttribute('aria-label', isCollapsed ? 'Afficher le panneau d\'information' : 'Masquer le panneau d\'information');
          toggleBtn.setAttribute('title', isCollapsed ? 'Afficher le panneau d\'information' : 'Masquer le panneau d\'information');
        }
        map.invalidateSize();
      });
    }

    // ── Force reset toggles on init ──
    function resetToggles() {
      document.querySelectorAll('[data-map-toggle]').forEach((el) => {
        if (el.type === 'checkbox') el.checked = false;
      });
      clearLegend();
    }

    // ── Init ──
    resetToggles();
    setupToggles();
    setupTippy();
    setupFullscreenCollapse();
    setupInfoPanelToggle();

    setTimeout(() => map.invalidateSize(), 200);

    // Preload data
    setTimeout(() => {
      fetch('/data/geo/world-countries.geojson', { priority: 'low' }).catch(() => {});
    }, 2000);

    document.addEventListener('astro:after-swap', () => {
      resetToggles();
      setTimeout(() => map.invalidateSize(), 200);
    });
  })();
</script>

<style>
  .world-map-section {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--gap-lg);
    position: relative;
  }

  .world-map {
    width: 100%;
    height: 600px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: #1e293b;
  }

  .world-map__noscript {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-text-muted);
    font-size: 1rem;
    padding: var(--gap-lg);
    text-align: center;
  }

  /* ── Loading overlay ── */
  .world-map__loading {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1000;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.25rem;
    background: rgba(11, 17, 32, 0.92);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--color-text-light);
    font-size: 0.9rem;
    pointer-events: none;
  }

  .world-map__loading--visible {
    display: flex;
  }

  .world-map__loading-spinner {
    width: 20px;
    height: 20px;
    border: 2.5px solid var(--color-border);
    border-top-color: var(--color-accent-gold, #d4a843);
    border-radius: 50%;
    animation: world-map-spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  .world-map__loading-text {
    white-space: nowrap;
  }

  @keyframes world-map-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Legend ── */
  .world-map__legend {
    margin-top: var(--gap-md);
    padding: var(--gap-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
  }

  .world-map__legend-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .world-map__legend-content {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .world-map__legend-placeholder {
    font-style: italic;
  }

  .world-map__legend-subtitle {
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .world-map__legend-hint {
    font-size: 0.75rem;
    color: var(--color-accent-gold, #d4a843);
    font-style: italic;
    margin-bottom: var(--gap-xs);
  }

  .world-map__legend-source {
    margin-top: var(--gap-xs);
    font-size: 0.75rem;
  }

  .world-map__legend-source a {
    color: var(--color-link-on-dark);
    text-decoration: none;
  }

  .world-map__legend-source a:hover {
    text-decoration: underline;
  }

  .world-map__legend-source a:focus-visible {
    outline: 2px solid var(--color-link-on-dark);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── World legend items ── */
  .world-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    margin: var(--gap-xs) 0;
  }

  .world-legend__item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .world-legend__swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.1);
    flex-shrink: 0;
  }

  /* ── Tooltip ── */
  :global(.world-tooltip-leaflet) {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.5rem;
