---
import Base from '../layouts/Base.astro';
---

<Base title="Géographie — France en Chiffres" description="La géographie de la France en données — régions, climats, territoires">
  <section class="geography-section">
    <div class="container">
      <h1 class="geography-section__title">Géographie en chiffres</h1>
      <p class="geography-section__subtitle">
        Des Alpes à l'outre-mer — explorez la France à travers ses cartes et ses données.
      </p>
      <div class="french-separator"></div>

      <div class="geo-tiles">
        <!-- Tile 1: Artistic department map -->
        <a href="/geographie/departements-francais" class="geo-tile geo-tile--depts">
          <div class="geo-tile__preview">
            <svg class="geo-tile__svg" viewBox="140 180 280 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M 1024.3329,380.24156 c -2.7985,1.23341 -0.5668,5.37143 -0.5665,5.79772 -2.3227," stroke="#d4a843" stroke-width="40" stroke-linecap="round" stroke-linejoin="round" opacity="0.06" fill="none"/>
              <path d="M 200,250 L 300,200 L 380,280 L 350,380 L 250,380 Z" fill="rgba(212,168,67,0.08)" stroke="#d4a843" stroke-width="1.5" opacity="0.4"/>
            </svg>
          </div>
          <div class="geo-tile__body">
            <h2 class="geo-tile__title">Carte des départements</h2>
            <p class="geo-tile__desc">
              Survolez les 96 départements métropolitains et les 5 DOM-COM.
              Cliquez sur un département pour découvrir sa page dédiée.
            </p>
            <span class="geo-tile__action">Explorer →</span>
          </div>
        </a>

        <!-- Tile 2: Interactive data map -->
        <a href="/geographie/carte-interactive" class="geo-tile geo-tile--data">
          <div class="geo-tile__preview">
            <div class="geo-tile__map-preview">
              <svg viewBox="0 0 60 40" class="geo-tile__grid" aria-hidden="true">
                <rect x="0" y="0" width="10" height="10" fill="rgba(212,168,67,0.3)" rx="1"/>
                <rect x="10" y="0" width="10" height="10" fill="rgba(212,168,67,0.5)" rx="1"/>
                <rect x="20" y="0" width="10" height="10" fill="rgba(78,179,211,0.6)" rx="1"/>
                <rect x="0" y="10" width="10" height="10" fill="rgba(212,168,67,0.2)" rx="1"/>
                <rect x="10" y="10" width="10" height="10" fill="rgba(43,140,190,0.7)" rx="1"/>
                <rect x="20" y="10" width="10" height="10" fill="rgba(8,104,172,0.8)" rx="1"/>
                <rect x="30" y="10" width="10" height="10" fill="rgba(8,64,129,0.9)" rx="1"/>
                <rect x="40" y="10" width="10" height="10" fill="rgba(8,104,172,0.6)" rx="1"/>
                <rect x="10" y="20" width="10" height="10" fill="rgba(43,140,190,0.5)" rx="1"/>
                <rect x="20" y="20" width="10" height="10" fill="rgba(78,179,211,0.4)" rx="1"/>
                <rect x="30" y="20" width="10" height="10" fill="rgba(123,204,196,0.3)" rx="1"/>
                <rect x="0" y="30" width="10" height="10" fill="rgba(212,168,67,0.15)" rx="1"/>
              </svg>
            </div>
          </div>
          <div class="geo-tile__body">
            <h2 class="geo-tile__title">Carte interactive</h2>
            <p class="geo-tile__desc">
              Densité de population, relief, routes, communes — activez les couches
              thématiques pour explorer la France en données. Données IGN, INSEE et OpenStreetMap.
            </p>
            <span class="geo-tile__action">Explorer →</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .geography-section {
    padding-top: var(--gap-xl);
    padding-bottom: var(--gap-2xl);
  }

  .geography-section__title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .geography-section__subtitle {
    color: var(--color-text-muted);
    text-align: center;
    max-width: 500px;
    margin: 0 auto var(--gap-lg);
    font-size: 1rem;
  }

  /* ── Tile grid ── */
  .geo-tiles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--gap-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .geo-tile {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
    text-decoration: none;
    color: inherit;
    background: var(--color-bg-card);
  }

  .geo-tile:hover {
    border-color: var(--color-french-blue);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .geo-tile:focus-visible {
    outline: 2px solid var(--color-accent-gold);
    outline-offset: 2px;
  }

  /* ── Preview area ── */
  .geo-tile__preview {
    height: 180px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0f172a;
  }

  .geo-tile__svg {
    width: 200px;
    height: auto;
    opacity: 0.6;
  }

  .geo-tile--depts .geo-tile__preview {
    background: linear-gradient(135deg, #0f172a, #1a1a2e);
  }

  .geo-tile--data .geo-tile__preview {
    background: linear-gradient(135deg, #0f172a, #0e2a3f);
  }

  .geo-tile__map-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .geo-tile__grid {
    width: 160px;
    height: auto;
    opacity: 0.8;
  }

  /* ── Body ── */
  .geo-tile__body {
    padding: var(--gap-md);
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .geo-tile__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin: 0;
  }

  .geo-tile__desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .geo-tile__action {
    color: var(--color-french-blue);
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: auto;
    transition: gap var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .geo-tile:hover .geo-tile__action {
    gap: 0.5rem;
  }

  @media (max-width: 720px) {
    .geo-tiles {
      grid-template-columns: 1fr;
    }
  }
</style>
