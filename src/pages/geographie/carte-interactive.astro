---
import Base from '../../layouts/Base.astro';
import InteractiveDataMap from '../../components/InteractiveDataMap.astro';
import { getSource, formatSourceLabel } from '../../data/sources';

// Sources used on this page — resolved at build time
const sourceIds = [
  'insee-2024',
  'ign-2024',
  'openstreetmap',
  'opentopomap',
  'openrailwaymap',
  'france-geojson',
];

const sources = (await Promise.all(
  sourceIds.map((id) => getSource(id)),
)).filter(Boolean);
---

<Base
  title="Carte interactive — France en Chiffres"
  description="Carte interactive de la France avec couches thématiques : densité de population, relief, routes, voies ferrées, voies navigables, communes — données IGN, INSEE et OpenStreetMap"
>
  <section id="map-page-wrapper" class="interactive-page">
    <div class="container">
      <h1 class="interactive-page__title">Carte interactive de la France</h1>
      <p class="interactive-page__subtitle">
        Explorez le territoire français à travers ses données géographiques et statistiques.
      </p>
      <div class="french-separator"></div>

      <!-- Layer toggles — titles visible, descriptions appear in Tippy hover popups -->
      <div class="layer-controls" role="group" aria-label="Couches thématiques">
        <button class="layer-controls__collapse" type="button" aria-label="Masquer les couches" title="Masquer les couches">
          <span>◀</span>
        </button>
        <label
          class="layer-controls__item"
          data-map-toggle="density"
          data-description="Habitants par km² par commune — 35&nbsp;228 communes. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/insee-2024&quot; data-source-id=&quot;insee-2024&quot; title=&quot;Source&nbsp;: insee-2024&quot;>[1]</a></sup>"
          for="toggle-density"
        >
          <input type="checkbox" id="toggle-density" data-map-toggle="density" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--density"></span>
          <span class="layer-controls__label">
            <strong>Densité de population</strong>
          </span>
        </label>

        <label
          class="layer-controls__item"
          data-map-toggle="elevation"
          data-description="Carte topographique avec courbes de niveau et ombrage du relief. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/opentopomap&quot; data-source-id=&quot;opentopomap&quot; title=&quot;Source&nbsp;: opentopomap&quot;>[4]</a></sup>"
          for="toggle-elevation"
        >
          <input type="checkbox" id="toggle-elevation" data-map-toggle="elevation" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--elevation"></span>
          <span class="layer-controls__label">
            <strong>Relief</strong>
          </span>
        </label>

        <label
          class="layer-controls__item"
          data-map-toggle="roads"
          data-description="Autoroutes (rouge) et routes nationales (orange). <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openstreetmap&quot; data-source-id=&quot;openstreetmap&quot; title=&quot;Source&nbsp;: openstreetmap&quot;>[3]</a></sup>"
          for="toggle-roads"
        >
          <input type="checkbox" id="toggle-roads" data-map-toggle="roads" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--roads"></span>
          <span class="layer-controls__label">
            <strong>Réseau routier</strong>
          </span>
        </label>

        <label
          class="layer-controls__item"
          data-map-toggle="railways"
          data-description="Réseau ferré français — toutes les lignes (TGV, TER, fret). <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openrailwaymap&quot; data-source-id=&quot;openrailwaymap&quot; title=&quot;Source&nbsp;: openrailwaymap&quot;>[5]</a></sup>"
          for="toggle-railways"
        >
          <input type="checkbox" id="toggle-railways" data-map-toggle="railways" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--railways"></span>
          <span class="layer-controls__label">
            <strong>Réseau ferroviaire</strong>
          </span>
        </label>

        <label
          class="layer-controls__item"
          data-map-toggle="waterways"
          data-description="Canaux et rivières navigables — voies navigables de France. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openstreetmap&quot; data-source-id=&quot;openstreetmap&quot; title=&quot;Source&nbsp;: openstreetmap&quot;>[3]</a></sup>"
          for="toggle-waterways"
        >
          <input type="checkbox" id="toggle-waterways" data-map-toggle="waterways" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--waterways"></span>
          <span class="layer-controls__label">
            <strong>Voies navigables</strong>
          </span>
        </label>

        <label
          class="layer-controls__item"
          data-map-toggle="communes"
          data-description="Limites des 35&nbsp;228 communes de France. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/france-geojson&quot; data-source-id=&quot;france-geojson&quot; title=&quot;Source&nbsp;: france-geojson&quot;>[6]</a></sup>"
          for="toggle-communes"
        >
          <input type="checkbox" id="toggle-communes" data-map-toggle="communes" class="layer-controls__checkbox">
          <span class="layer-controls__swatch layer-controls__swatch--communes"></span>
          <span class="layer-controls__label">
            <strong>Communes</strong>
          </span>
        </label>
      </div>

      <!-- The map -->
      <InteractiveDataMap />

      <!-- "Ça peut vous intéresser aussi" section -->
      <div class="interactive-page__related">
        <h2 class="interactive-page__related-title">Ça peut vous intéresser aussi&nbsp;:</h2>
        <ul class="interactive-page__related-links">
          <li>
            <a href="/geographie/departements-francais/">
              La carte des départements français
            </a>
          </li>
        </ul>
      </div>

      <!-- Structured sources footer (same pattern as histoire/[slug].astro) -->
      <footer class="interactive-page__sources">
        {sources.length > 0 && (
          <>
            <p class="interactive-page__sources-title">Sources des données</p>
            <ol class="interactive-page__sources-list">
              {sources.map((s) => (
                <li class="interactive-page__source-item">
                  <a href={`/bibliographie/${s.id}`}>{formatSourceLabel(s)}</a>
                </li>
              ))}
            </ol>
          </>
        )}
      </footer>
    </div>
  </section>
</Base>

<style>
  .interactive-page {
    padding-top: var(--gap-xl);
    padding-bottom: var(--gap-2xl);
  }

  .interactive-page__title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .interactive-page__subtitle {
    color: var(--color-text-muted);
    text-align: center;
    max-width: 550px;
    margin: 0 auto var(--gap-lg);
    font-size: 1rem;
  }

  /* ── Layer controls ── */
  .layer-controls {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--gap-sm);
    margin-bottom: var(--gap-lg);
  }

  .layer-controls__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast);
    user-select: none;
  }

  .layer-controls__item:hover {
    border-color: var(--color-french-blue);
    background: rgba(59, 130, 246, 0.05);
  }

  .layer-controls__item--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .layer-controls__item--disabled:hover {
    border-color: var(--color-border);
    background: transparent;
  }

  .layer-controls__checkbox {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid #475569;
    border-radius: 4px;
    background: #1e293b;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 0;
    transition: border-color var(--transition-fast), background var(--transition-fast);
    position: relative;
  }

  .layer-controls__checkbox:checked {
    border-color: var(--color-french-blue);
    background: var(--color-french-blue);
  }

  .layer-controls__checkbox:checked::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }

  .layer-controls__checkbox:focus-visible {
    outline: 2px solid var(--color-accent-gold);
    outline-offset: 2px;
  }

  .layer-controls__swatch {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .layer-controls__swatch--density {
    background: linear-gradient(135deg, #f7fcf0, #084081);
  }

  .layer-controls__swatch--elevation {
    background: linear-gradient(135deg, #22c55e, #78716c, #f8fafc);
  }

  .layer-controls__swatch--roads {
    background: #ef4444;
  }

  .layer-controls__swatch--railways {
    background: #a855f7;
  }

  .layer-controls__swatch--waterways {
    background: #06b6d4;
  }

  .layer-controls__swatch--communes {
    background: #6366f1;
  }

  .layer-controls__label {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: 0.85rem;
  }

  .layer-controls__label strong {
    color: var(--color-text-light);
    font-weight: 600;
  }

  /* ── Related links ── */
  .interactive-page__related {
    margin-top: var(--gap-xl);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .interactive-page__related-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-sm);
  }

  .interactive-page__related-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .interactive-page__related-links li {
    margin-bottom: var(--gap-xs);
  }

  .interactive-page__related-links a {
    color: var(--color-link-on-dark);
    text-decoration: none;
    font-weight: 500;
    transition: text-decoration var(--transition-fast);
  }

  .interactive-page__related-links a:hover {
    text-decoration: underline;
  }

  /* ── Sources footer (same pattern as histoire/[slug].astro) ── */
  .interactive-page__sources {
    margin-top: var(--gap-lg);
    padding-top: var(--gap-md);
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  .interactive-page__sources-title {
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .interactive-page__sources-list {
    padding-left: var(--gap-lg);
    margin: 0;
    list-style: decimal;
  }

  .interactive-page__source-item {
    margin-bottom: var(--gap-xs);
    line-height: 1.5;
  }

  .interactive-page__source-item a {
    color: var(--color-link-on-dark);
    text-decoration: none;
  }

  .interactive-page__source-item a:focus-visible {
    outline: 2px solid var(--color-link-on-dark);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .interactive-page__source-item a:hover {
    text-decoration: underline;
  }

  /* ── Layer panel collapse button (visible in fullscreen) ── */
  .layer-controls__collapse {
    display: none;
    position: absolute;
    top: var(--gap-xs);
    right: var(--gap-xs);
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-card);
    color: var(--color-text-light);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    line-height: 1;
    z-index: 10;
    transition: background var(--transition-fast);
  }

  .layer-controls__collapse:hover {
    background: var(--color-bg-hover);
  }

  /* ── Fullscreen layout ── */
  #map-page-wrapper.is-fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    background: var(--color-bg-base);
    display: flex;
    flex-direction: row;
    align-items: stretch;
    padding: 0 !important;
  }

  #map-page-wrapper.is-fullscreen .container {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  #map-page-wrapper.is-fullscreen .interactive-page__title,
  #map-page-wrapper.is-fullscreen .interactive-page__subtitle,
  #map-page-wrapper.is-fullscreen .french-separator,
  #map-page-wrapper.is-fullscreen .interactive-page__related,
  #map-page-wrapper.is-fullscreen .interactive-page__sources {
    display: none;
  }

  /* ── Layer controls in fullscreen: sidebar overlay ── */
  .layer-controls--fullscreen {
    position: absolute;
    top: 0;
    left: 0;
    width: 240px;
    height: 100%;
    overflow-y: auto;
    z-index: 1000;
    background: rgba(15, 23, 42, 0.92);
    border-right: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--gap-lg) var(--gap-md);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    transition: transform var(--transition-normal), opacity var(--transition-normal);
  }

  .layer-controls--fullscreen .layer-controls__collapse {
    display: flex;
  }

  /* Collapsed state: slide out of view (panel hides, button stays) */
  .layer-controls--fullscreen.layer-controls--collapsed {
    transform: translateX(-100%);
  }

  .layer-controls--fullscreen.layer-controls--collapsed .layer-controls__collapse {
    position: fixed;
    top: var(--gap-md);
    left: var(--gap-md);
    width: auto;
    height: auto;
    padding: 0.4rem 0.7rem;
    font-size: 0.85rem;
    border-radius: var(--radius-md);
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .layer-controls--fullscreen.layer-controls--collapsed .layer-controls__item {
    pointer-events: none;
  }

  /* ── Map in fullscreen ── */
  #map-page-wrapper.is-fullscreen .data-map-section {
    flex: 1;
    max-width: none;
    padding: 0;
    display: flex;
    align-items: stretch;
  }

  #map-page-wrapper.is-fullscreen .data-map {
    height: 100vh;
    border-radius: 0;
    border: none;
  }

  /* ── Legend in fullscreen ── */
  #map-page-wrapper.is-fullscreen .data-map__legend {
    display: none;
  }

  /* ── Citation superscripts in map page content ── */
  :global(.layer-controls sup.citation) {
    font-size: 0.75em;
    vertical-align: super;
    line-height: 1;
  }

  :global(.layer-controls sup.citation a) {
    color: var(--color-link-on-dark);
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .layer-controls {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .layer-controls--fullscreen {
      transition: none !important;
    }
    .layer-controls--fullscreen.layer-controls--collapsed {
      transform: none;
      opacity: 1;
    }
  }
</style>
