---
import MapPageLayout from '../../components/MapPageLayout.astro';
import InteractiveDataMap from '../../components/InteractiveDataMap.astro';

// Sources used on this page — resolved at build time
const sourceIds = [
  'insee-2024',
  'ign-2024',
  'openstreetmap',
  'opentopomap',
  'openrailwaymap',
  'france-geojson',
];
---

<MapPageLayout
  wrapperId="map-page-wrapper"
  title="Carte interactive de la France"
  subtitle="Explorez le territoire français à travers ses données géographiques et statistiques."
  sourceIds={sourceIds}
>
  <div slot="controls">
    <label
      class="map-layer-controls__item"
      data-map-toggle="elevation"
      data-description="Carte topographique avec courbes de niveau et ombrage du relief. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/opentopomap&quot; data-source-id=&quot;opentopomap&quot; title=&quot;Source&nbsp;: opentopomap&quot;>[4]</a></sup>"
      for="toggle-elevation"
    >
      <input type="checkbox" id="toggle-elevation" data-map-toggle="elevation" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--elevation"></span>
      <span class="map-layer-controls__label">
        <strong>Relief</strong>
      </span>
    </label>

    <label
      class="map-layer-controls__item"
      data-map-toggle="roads"
      data-description="Autoroutes (rouge) et routes nationales (orange). <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openstreetmap&quot; data-source-id=&quot;openstreetmap&quot; title=&quot;Source&nbsp;: openstreetmap&quot;>[3]</a></sup>"
      for="toggle-roads"
    >
      <input type="checkbox" id="toggle-roads" data-map-toggle="roads" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--roads"></span>
      <span class="map-layer-controls__label">
        <strong>Réseau routier</strong>
      </span>
    </label>

    <label
      class="map-layer-controls__item"
      data-map-toggle="railways"
      data-description="Réseau ferré français — toutes les lignes (TGV, TER, fret). <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openrailwaymap&quot; data-source-id=&quot;openrailwaymap&quot; title=&quot;Source&nbsp;: openrailwaymap&quot;>[5]</a></sup>"
      for="toggle-railways"
    >
      <input type="checkbox" id="toggle-railways" data-map-toggle="railways" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--railways"></span>
      <span class="map-layer-controls__label">
        <strong>Réseau ferroviaire</strong>
      </span>
    </label>

    <label
      class="map-layer-controls__item"
      data-map-toggle="waterways"
      data-description="Canaux et rivières navigables — voies navigables de France. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/openstreetmap&quot; data-source-id=&quot;openstreetmap&quot; title=&quot;Source&nbsp;: openstreetmap&quot;>[3]</a></sup>"
      for="toggle-waterways"
    >
      <input type="checkbox" id="toggle-waterways" data-map-toggle="waterways" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--waterways"></span>
      <span class="map-layer-controls__label">
        <strong>Voies navigables</strong>
      </span>
    </label>

    <!-- Communes group: communes + density suboption -->
    <div class="map-layer-controls__group">
      <label
        class="map-layer-controls__item"
        data-map-toggle="communes"
        data-description="Limites des 35&nbsp;228 communes de France. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/france-geojson&quot; data-source-id=&quot;france-geojson&quot; title=&quot;Source&nbsp;: france-geojson&quot;>[6]</a></sup>"
        for="toggle-communes"
      >
        <input type="checkbox" id="toggle-communes" data-map-toggle="communes" class="map-layer-controls__checkbox">
        <span class="map-layer-controls__swatch map-layer-controls__swatch--communes"></span>
        <span class="map-layer-controls__label">
          <strong>Communes</strong>
        </span>
      </label>

      <label
        class="map-layer-controls__item map-layer-controls__suboption map-layer-controls__suboption--hidden"
        data-map-toggle="density"
        data-description="Habitants par km² par commune — 35&nbsp;228 communes. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/insee-2024&quot; data-source-id=&quot;insee-2024&quot; title=&quot;Source&nbsp;: insee-2024&quot;>[1]</a></sup>"
        for="toggle-density"
      >
        <input type="checkbox" id="toggle-density" data-map-toggle="density" class="map-layer-controls__checkbox">
        <span class="map-layer-controls__swatch map-layer-controls__swatch--density"></span>
        <span class="map-layer-controls__label">
          <strong>Densité de population</strong>
        </span>
      </label>
    </div>
  </div>

  <InteractiveDataMap slot="map" />

  <ul slot="related-links">
    <li>
      <a href="/geographie/departements-francais/">
        La carte des départements français
      </a>
    </li>
  </ul>
</MapPageLayout>

<style>
  /* ── Page-specific swatch colors ── */
  .map-layer-controls__swatch--density {
    background: linear-gradient(135deg, #f7fcf0, #084081);
  }
  .map-layer-controls__swatch--elevation {
    background: linear-gradient(135deg, #22c55e, #78716c, #f8fafc);
  }
  .map-layer-controls__swatch--roads {
    background: #ef4444;
  }
  .map-layer-controls__swatch--railways {
    background: #a855f7;
  }
  .map-layer-controls__swatch--waterways {
    background: #06b6d4;
  }
  .map-layer-controls__swatch--communes {
    background: #6366f1;
  }
</style>
