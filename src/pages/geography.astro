---
import Base from '../layouts/Base.astro';
---

<Base title="Géographie — France en Chiffres" description="La géographie de la France en données — régions, climats, territoires">
  <section class="section">
    <div class="container">
      <h1 class="section__title">Géographie en chiffres</h1>
      <div class="french-separator"></div>
      <p class="section__subtitle">
        Des Alpes à l'outre-mer — la diversité géographique française en données.
      </p>
      <div class="placeholder">
        <p class="placeholder__text">🚧 Cette page est en construction.</p>
        <p class="placeholder__sub">
          Une carte interactive de la France avec les données par région
          (population, PIB, superficie, climat) sera bientôt disponible.
        </p>
        <a href="/" class="btn btn--ghost">← Retour à l'accueil</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .placeholder {
    text-align: center;
    padding: var(--gap-2xl) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-lg);
  }

  .placeholder__text {
    font-family: var(--font-serif);
    font-size: 2rem;
  }

  .placeholder__sub {
    color: var(--color-text-muted);
    max-width: 500px;
  }
</style>
