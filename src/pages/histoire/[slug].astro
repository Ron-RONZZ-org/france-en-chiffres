---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getSource, formatSourceLabel } from '../../data/sources';
import { getMedia } from '../../data/media';
import MediaFigure from '../../components/MediaFigure.astro';
import EventMiniTimeline from '../../components/EventMiniTimeline.astro';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((entry) => ({
    params: { slug: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const event = entry.data;
const { Content } = await entry.render();

// Extract inline source IDs from Markdown body
const sourceIds = [...new Set(
  [...entry.body.matchAll(/\[source:\s*([\w-]+)\]/g)].map((m) => m[1])
)];

const sources = (await Promise.all(
  sourceIds.map((id) => getSource(id)),
)).filter(Boolean);

// Hero media: first from mediaIds, fallback to mediaId
const allMediaIds = [...(event.mediaIds ?? []), ...(event.mediaId ? [event.mediaId] : [])];
const heroMediaId = allMediaIds[0];
const galleryMediaIds = allMediaIds.slice(1);

const heroMedia = heroMediaId ? await getMedia(heroMediaId) : undefined;
const galleryMedia = (await Promise.all(
  galleryMediaIds.map((id) => getMedia(id)),
)).filter(Boolean);
---

<Base title={`${event.title} — Histoire`} description={event.description ?? ''}>
  <article class="event-page">
    <header class="event-page__header">
      <a href="/histoire" class="event-page__back">← Chronologie</a>
      <time class="event-page__year">{event.yearDisplay}</time>
      <h1 class="event-page__title">{event.title}</h1>
    </header>

    {heroMedia && (
      <MediaFigure entry={heroMedia} variant="hero" />
    )}

    {galleryMedia.length > 0 && (
      <div class="event-page__gallery">
        {galleryMedia.map((m) => (
          <MediaFigure entry={m} variant="inline" />
        ))}
      </div>
    )}

    {event.timeline && event.timeline.length > 0 && (
      <EventMiniTimeline
        entries={event.timeline}
        eventStart={event.start}
        eventEnd={event.end}
      />
    )}

    <div class="event-page__body">
      <Content />
    </div>

    <footer class="event-page__footer">
      {sources.length > 0 && (
        <>
          <p class="event-page__sources-title">Sources</p>
          <ol class="event-page__sources-list">
            {sources.map((s) => (
              <li class="event-page__source-item">
                <a href={`/bibliographie/${s.id}`}>{formatSourceLabel(s)}</a>
              </li>
            ))}
          </ol>
        </>
      )}
    </footer>
  </article>
</Base>

<style>
  .event-page {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--gap-xl) var(--gap-lg) var(--gap-2xl);
  }

  .event-page__back {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: var(--gap-lg);
    transition: color var(--transition-fast);
  }

  .event-page__back:hover {
    color: var(--color-link-on-dark);
  }

  .event-page__header {
    margin-bottom: var(--gap-xl);
  }

  .event-page__year {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--gap-sm);
  }

  .event-page__title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-light);
    margin-bottom: var(--gap-md);
  }

  .event-page__gallery {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
    margin-bottom: var(--gap-lg);
    max-width: 720px;
  }

  .event-page__gallery :global(.figure) {
    margin: 0;
  }

  .event-page__body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .event-page__body :global(h2) {
    margin-top: var(--gap-xl);
    margin-bottom: var(--gap-lg);
  }

  .event-page__body :global(h3) {
    margin-top: var(--gap-lg);
    margin-bottom: var(--gap-md);
  }

  .event-page__body :global(h2),
  .event-page__body :global(h3),
  .event-page__body :global(h4) {
    position: relative;                /* anchor for .heading-anchor */
  }

  .event-page__body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: var(--gap-xl);
    margin-bottom: var(--gap-md);
    color: var(--color-text-light);
  }

  .event-page__body :global(p) {
    margin-bottom: var(--gap-md);
  }

  .event-page__body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--gap-lg) 0;
  }

  .event-page__body :global(ul), .event-page__body :global(ol) {
    margin-bottom: var(--gap-md);
    padding-left: var(--gap-lg);
  }

  .event-page__body :global(blockquote) {
    border-left: 3px solid var(--color-french-blue);
    padding-left: var(--gap-md);
    margin: var(--gap-lg) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ── Hidden heading anchors (from remark-heading-ids) ── */

  .event-page__body :global(.heading-anchor) {
    display: block;
    visibility: hidden;
    height: 0;
    width: 0;
    overflow: hidden;
    position: absolute;
    top: -80px;               /* offset for sticky nav */
    pointer-events: none;
  }

  /* ── Inline citation superscripts ── */

  .event-page__body :global(sup.citation) {
    font-size: 0.7em;
    vertical-align: super;
    line-height: 1;
  }

  .event-page__body :global(sup.citation a) {
    color: var(--color-link-on-dark);
    text-decoration: none;
    font-weight: 600;
  }

  .event-page__body :global(sup.citation a:hover),
  .event-page__body :global(sup.citation a:focus) {
    text-decoration: underline;
  }

  .event-page__body :global(sup.citation a:focus-visible) {
    outline: 2px solid var(--color-link-on-dark);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── Inline figure embeddings (from remark plugin) ── */

  .event-page__body :global(.chart-figure__container svg) {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
  }

  .event-page__body :global(.chart-figure__container) {
    padding: var(--gap-md) var(--gap-lg);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  .event-page__body :global(.figure-warning) {
    padding: var(--gap-md);
    border: 1px dashed var(--color-french-red);
    border-radius: var(--radius-md);
    color: var(--color-french-red);
    font-size: 0.85rem;
    text-align: center;
    margin: var(--gap-lg) 0;
  }

  /* ── Footer sources list ── */

  .event-page__footer {
    margin-top: var(--gap-2xl);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    font-size: 0.85rem;
  }

  .event-page__sources-title {
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: var(--gap-xs);
  }

  .event-page__sources-list {
    padding-left: var(--gap-lg);
    margin: 0;
    list-style: decimal;
  }

  .event-page__source-item {
    margin-bottom: var(--gap-xs);
    line-height: 1.5;
  }

  .event-page__source-item a {
    color: var(--color-link-on-dark);
    text-decoration: none;
  }

  .event-page__source-item a:focus-visible {
    outline: 2px solid var(--color-link-on-dark);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .event-page__source-item a:hover {
    text-decoration: underline;
  }
</style>
