---
import Base from '../layouts/Base.astro';
import Timeline from '../components/Timeline.astro';
import data from '../data/history.json';
---

<Base title="Histoire — France en Chiffres" description="L'histoire de France racontée par les nombres — de la Gaule à aujourd'hui">
  <Timeline data={data} />
</Base>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  (() => {
    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
    if (!motionOK) {
      // No-JS / reduced-motion: ensure all events are visible
      document.querySelectorAll('[data-event-id]').forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // ── 1. Timeline line draw ──
    const line = document.querySelector('.timeline__line');
    if (line) {
      const timeline = document.querySelector('.timeline');
      gsap.fromTo(
        line,
        { scaleY: 0, transformOrigin: 'top center' },
        {
          scaleY: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: timeline,
            start: 'top 10%',
            end: 'bottom 70%',
            scrub: 1,
          },
        }
      );
    }

    // ── 2. Era section event stagger ──
    document.querySelectorAll('[data-era-id]').forEach((era) => {
      const events = era.querySelectorAll('[data-event-id]');
      if (!events.length) return;

      // Set initial state
      gsap.set(events, { opacity: 0, y: 30 });

      gsap.to(events, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.18,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: era,
          start: 'top 75%',
          end: 'top 25%',
          toggleActions: 'play none none reverse',
        },
      });
    });

    // ── 3. Year indicator (follows scroll position) ──
    // Get all events sorted by year
    const allEvents = [...document.querySelectorAll('[data-event-id]')];
    if (allEvents.length) {
      const yearBadge = document.createElement('div');
      yearBadge.className = 'year-badge';
      yearBadge.innerHTML = '<span class="year-badge__label">Année</span><span class="year-badge__value"></span>';
      document.body.appendChild(yearBadge);

      const yearValues = allEvents.map((el) => parseInt(el.dataset.year) || 0);
      const minYear = Math.min(...yearValues);
      const maxYear = Math.max(...yearValues);
      const yearSpan = maxYear - minYear;

      ScrollTrigger.create({
        trigger: '.timeline',
        start: 'top top',
        end: 'bottom bottom',
        onUpdate: (self) => {
          const rawYear = minYear + self.progress * yearSpan;
          const displayYear = Math.round(rawYear);
          const formattedYear = displayYear < 0 ? `${Math.abs(displayYear)} av. J.-C.` : String(displayYear);
          yearBadge.querySelector('.year-badge__value').textContent = formattedYear;
        },
        onLeave: () => { yearBadge.style.opacity = '0'; },
        onEnter: () => { yearBadge.style.opacity = '1'; },
        onLeaveBack: () => { yearBadge.style.opacity = '0'; },
        onEnterBack: () => { yearBadge.style.opacity = '1'; },
      });
    }
  })();
</script>

<style>
  /* Re-use section__subtitle from global.css */
  .section__subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto var(--gap-xl);
  }

  /* Year badge — follows scroll */
  .year-badge {
    position: fixed;
    right: var(--gap-lg);
    bottom: var(--gap-lg);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: var(--gap-sm) var(--gap-md);
    background: rgba(11, 17, 32, 0.9);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: opacity var(--transition-normal);
    opacity: 0;
    pointer-events: none;
  }

  .year-badge__label {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .year-badge__value {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-light);
  }

  @media (max-width: 767px) {
    .year-badge {
      right: var(--gap-md);
      bottom: var(--gap-md);
      padding: var(--gap-xs) var(--gap-sm);
    }
    .year-badge__value {
      font-size: 0.85rem;
    }
  }
</style>

<!-- Global preview styles (unscoped — Tippy renders at <body> level) -->
<style is:global>
  /* Custom dark theme for Tippy */
  .tippy-box[data-theme~="dark"] {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
    color: #e2e8f0;
  }

  .tippy-box[data-theme~="dark"] .tippy-arrow {
    color: #111827;
    stroke: #1e293b;
  }

  .tippy-box[data-theme~="dark"] .tippy-content {
    padding: 0.75rem;
  }

  .tippy-box[data-theme~="dark"][data-placement^="bottom"] > .tippy-arrow::before {
    border-bottom-color: #1e293b;
  }
  .tippy-preview {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: 'Inter', system-ui, sans-serif;
    text-align: left;
    border-left: 3px solid var(--accent, #3b82f6);
    padding-left: 0.75rem;
  }

  .tippy-preview__year {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tippy-preview__title {
    font-family: 'Playfair Display', 'Times New Roman', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #e2e8f0;
    line-height: 1.3;
    margin: 0;
  }

  .tippy-preview__divider {
    height: 2px;
    width: 40px;
    border-radius: 1px;
  }

  .tippy-preview__description {
    font-size: 0.85rem;
    color: #e2e8f0;
    line-height: 1.6;
    margin: 0;
  }

  .tippy-preview__summary {
    font-size: 0.8rem;
    color: #94a3b8;
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  .tippy-preview__stat {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent, #3b82f6) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent, #3b82f6) 25%, transparent);
    align-self: flex-start;
  }

  .tippy-preview__stat-label {
    color: #94a3b8;
    font-weight: 500;
  }

  .tippy-preview__stat-value {
    color: #e2e8f0;
    font-weight: 700;
  }

  .tippy-preview__source {
    font-size: 0.65rem;
    color: #94a3b8;
    opacity: 0.5;
    text-decoration: none;
  }

  .tippy-preview__source--link:hover {
    opacity: 1;
    color: #3b82f6;
    text-decoration: underline;
  }

  .tippy-preview__link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #3b82f6;
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border-radius: 0.75rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    transition: background 200ms ease, border-color 200ms ease;
    align-self: flex-start;
  }

  .tippy-preview__link:hover {
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.4);
  }
</style>
