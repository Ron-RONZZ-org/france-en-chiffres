---
// /media/[id]/code/ — Source code viewer for programmatically generated media assets.
// Shows both the authored input data and, when available, the shared rendering code
// that transforms data into the final SVG.

import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import Base from '../../../layouts/Base.astro';
import { getAllMedia } from '../../../data/media';
import SourceCodeBlock from '../../../components/SourceCodeBlock.astro';
import type { ResolvedMedia } from '../../../data/media';

const __dirname = fileURLToPath(new URL('.', import.meta.url));
const PROJECT_ROOT = resolve(__dirname, '../../../../');

export interface Props {
  media: ResolvedMedia;
}

export async function getStaticPaths() {
  const allMedia = await getAllMedia();
  return allMedia
    .filter((m) => m.sourceCode && m.sourceCode.length > 0)
    .map((m) => ({
      params: { id: m.id },
      props: { media: m },
    }));
}

const { media } = Astro.props;
const title = `Code source — ${media.caption ?? media.id}`;

// Read the shared rendering source file (if specified)
let renderingCode = '';
let renderingLabel = '';
let renderingLang = '';

if (media.renderingSource) {
  const filePath = resolve(PROJECT_ROOT, media.renderingSource.filePath);
  if (existsSync(filePath)) {
    renderingCode = readFileSync(filePath, 'utf-8');
    renderingLabel = media.renderingSource.label;
    // Detect language from extension
    const ext = media.renderingSource.filePath.split('.').pop()?.toLowerCase();
    renderingLang = ext === 'js' ? 'javascript' : ext === 'ts' ? 'javascript' : ext ?? 'text';
  }
}
---

<Base title={title} description={`Code source du diagramme : ${media.caption ?? media.id}`}>
  <section class="section">
    <div class="container">
      <a href="/" class="breadcrumb">← Retour à l'accueil</a>

      <article class="code-page">
        <header class="code-page__header">
          <h1>Code source</h1>
          <p class="code-page__subtitle">{media.caption}</p>
        </header>

        {media.sourceCode && media.sourceCode.length > 0 && (
          <section class="code-page__section">
            {media.sourceCode.map((sc, i) => (
              <SourceCodeBlock sourceCode={sc} key={`data-${i}`} />
            ))}
          </section>
        )}

        {renderingCode && (
          <section class="code-page__section">
            <h2 class="code-page__section-title">{renderingLabel}</h2>
            <p class="code-page__section-desc">
              Ce fichier contient la fonction de rendu qui transforme les données JSON en diagramme SVG.
              Il est partagé par tous les diagrammes de ce type — une seule source, pas de duplication.
            </p>
            <SourceCodeBlock sourceCode={{ lang: renderingLang, code: renderingCode, label: renderingLabel }} />
          </section>
        )}

        <footer class="code-page__footer">
          <p>
            Les données ci-dessus sont spécifiques à ce diagramme. Le code de rendu
            {renderingCode ? ' (ci-dessus) est' : ''} partagé par l'ensemble des diagrammes du même type.
            Vous pouvez copier ou télécharger chaque bloc séparément.
          </p>
          {media.license && (
            <p>
              Licence : <a href={media.licenseUrl} target="_blank" rel="license">{media.license}</a>
            </p>
          )}
          <p>
            <a href="/" class="code-page__back">← Retour à l'accueil</a>
          </p>
        </footer>
      </article>
    </div>
  </section>
</Base>

<style>
  .breadcrumb {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: var(--gap-xl);
    transition: color var(--transition-fast);
  }

  .breadcrumb:hover {
    color: var(--color-link-on-dark);
  }

  .code-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .code-page__header {
    margin-bottom: var(--gap-xl);
  }

  .code-page__header h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: var(--gap-sm);
  }

  .code-page__subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .code-page__section {
    margin-bottom: var(--gap-xl);
  }

  .code-page__section-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: var(--gap-sm);
  }

  .code-page__section-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--gap-md);
    line-height: 1.6;
  }

  .code-page__footer {
    margin-top: var(--gap-xl);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .code-page__footer a {
    color: var(--color-link-on-dark);
  }

  .code-page__footer a:hover {
    text-decoration: underline;
  }

  .code-page__back {
    display: inline-block;
    margin-top: var(--gap-sm);
    font-size: 0.9rem;
  }
</style>
