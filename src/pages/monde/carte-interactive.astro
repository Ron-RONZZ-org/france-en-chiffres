---
import MapPageLayout from '../../components/MapPageLayout.astro';
import WorldDataMap from '../../components/WorldDataMap.astro';

// Sources used on this page
const sourceIds = [
  'undp-hdr',
  'world-bank',
  'natural-earth',
  'openstreetmap',
];
---

<MapPageLayout
  wrapperId="map-page-wrapper"
  title="Carte interactive du monde"
  subtitle="Explorez la place de la France dans le monde à travers les données mondiales."
  sourceIds={sourceIds}
>
  <div slot="controls">
    <label
      class="map-layer-controls__item"
      data-map-toggle="hdi"
      data-description="Indice de développement humain ajusté aux inégalités (IDHAI). Mesure le développement humain en tenant compte des inégalités internes. <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/undp-hdr&quot; data-source-id=&quot;undp-hdr&quot; title=&quot;Source&nbsp;: PNUD&quot;>[1]</a></sup>"
      for="toggle-hdi"
    >
      <input type="checkbox" id="toggle-hdi" data-map-toggle="hdi" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--hdi"></span>
      <span class="map-layer-controls__label">
        <strong>IDHAI</strong>
      </span>
    </label>

    <label
      class="map-layer-controls__item"
      data-map-toggle="density"
      data-description="Densité de population — nombre d'habitants par km². <sup class=&quot;citation&quot;><a href=&quot;/bibliographie/world-bank&quot; data-source-id=&quot;world-bank&quot; title=&quot;Source&nbsp;: Banque mondiale&quot;>[2]</a></sup>"
      for="toggle-density"
    >
      <input type="checkbox" id="toggle-density" data-map-toggle="density" class="map-layer-controls__checkbox">
      <span class="map-layer-controls__swatch map-layer-controls__swatch--density"></span>
      <span class="map-layer-controls__label">
        <strong>Densité de population</strong>
      </span>
    </label>
  </div>

  <WorldDataMap slot="map" />

  <ul slot="related-links">
    <li>
      <a href="/monde/pays/fra">
        Profil de la France
      </a>
    </li>
    <li>
      <a href="/geographie/carte-interactive/">
        Carte interactive de la France
      </a>
    </li>
  </ul>
</MapPageLayout>

<style>
  /* ── Page-specific swatch colors ── */
  .map-layer-controls__swatch--hdi {
    background: linear-gradient(135deg, #f03b20, #006837);
  }
  .map-layer-controls__swatch--density {
    background: linear-gradient(135deg, #c2e699, #081d58);
  }
</style>
